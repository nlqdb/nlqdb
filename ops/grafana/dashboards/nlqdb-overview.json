{
  "id": null,
  "uid": "nlqdb-overview",
  "title": "nlqdb — Overview",
  "tags": ["nlqdb"],
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 1,
  "links": [
    { "title": "Ask Pipeline", "url": "/d/nlqdb-ask-pipeline", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Providers",    "url": "/d/nlqdb-providers",    "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Auth",         "url": "/d/nlqdb-auth",         "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ask p99 — cache hit",
      "description": "SLO: < 500 ms",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 300  },
            { "color": "red",    "value": 500  }
          ]},
          "mappings": [{ "type": "special", "options": { "match": "nan", "result": { "text": "No data" } } }]
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "histogram_quantile(0.99, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"true\"}[5m])) by (le))",
        "legendFormat": "p99", "refId": "A", "instant": true
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ask p99 — cache miss",
      "description": "SLO: < 3 500 ms",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null  },
            { "color": "yellow", "value": 2000  },
            { "color": "red",    "value": 3500  }
          ]},
          "mappings": [{ "type": "special", "options": { "match": "nan", "result": { "text": "No data" } } }]
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "histogram_quantile(0.99, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"false\"}[5m])) by (le))",
        "legendFormat": "p99", "refId": "A", "instant": true
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx error rate",
      "description": "SLO: < 0.1 %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red",    "value": 0.1  }
          ]},
          "mappings": [{ "type": "special", "options": { "match": "nan", "result": { "text": "No data" } } }]
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "100 * sum(rate(nlqdb_requests_total{status_class=\"5xx\"}[5m])) / sum(rate(nlqdb_requests_total[5m]))",
        "legendFormat": "5xx %", "refId": "A", "instant": true
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Plan cache hit ratio",
      "description": "Fraction of /v1/ask requests served from cache",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100, "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 50   },
            { "color": "green",  "value": 80   }
          ]},
          "mappings": [{ "type": "special", "options": { "match": "nan", "result": { "text": "No data" } } }]
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "100 * sum(rate(nlqdb_cache_plan_hits_total[5m])) / (sum(rate(nlqdb_cache_plan_hits_total[5m])) + sum(rate(nlqdb_cache_plan_misses_total[5m])))",
        "legendFormat": "hit %", "refId": "A", "instant": true
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1,
            "fillOpacity": 10, "gradientMode": "none", "showPoints": "auto",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "sum(rate(nlqdb_requests_total[5m])) by (route)",
        "legendFormat": "{{route}}", "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Ask latency — p50 & p99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1,
            "fillOpacity": 10, "gradientMode": "none", "showPoints": "auto",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.50, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"true\"}[5m])) by (le))",
          "legendFormat": "hit p50", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.99, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"true\"}[5m])) by (le))",
          "legendFormat": "hit p99", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.50, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"false\"}[5m])) by (le))",
          "legendFormat": "miss p50", "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.99, sum(rate(nlqdb_ask_duration_ms_bucket{cache_hit=\"false\"}[5m])) by (le))",
          "legendFormat": "miss p99", "refId": "D"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1,
            "fillOpacity": 10, "gradientMode": "none", "showPoints": "auto",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "transparent", "value": null },
            { "color": "red",         "value": 0.1  }
          ]}
        },
        "overrides": []
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "expr": "100 * sum(rate(nlqdb_requests_total{status_class=\"5xx\"}[5m])) by (route) / sum(rate(nlqdb_requests_total[5m])) by (route)",
        "legendFormat": "{{route}}", "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Plan cache — hits vs misses",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1,
            "fillOpacity": 20, "gradientMode": "none", "showPoints": "auto",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "sum(rate(nlqdb_cache_plan_hits_total[5m]))",
          "legendFormat": "hits", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "sum(rate(nlqdb_cache_plan_misses_total[5m]))",
          "legendFormat": "misses", "refId": "B"
        }
      ]
    }
  ]
}
