      "type": "timeseries",
      "title": "Failover rate — by from→to provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "calcs": ["mean", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
