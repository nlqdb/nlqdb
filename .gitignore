# Dependencies
node_modules/
.bun/

# Local env / secrets — never commit
.envrc
.envrc.age
.envrc.age.prev
.envrc.pre-restore.*
.env
.env.local
.env.*.local
*.pem
*.key
.claude

# Build / cache
dist/
build/
.next/
.astro/
.turbo/
.wrangler/
.cache/
coverage/

# Formatter / linter / tooling caches
.biome-cache/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Python (uv)
.venv/
__pycache__/
*.pyc

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json

# Logs
*.log
bun-debug.log*

# Quality-eval result snapshots — keep .gitkeep, ignore JSON
tools/eval/results/*.json
# Stranger-test walk JSON output — keep .gitkeep, ignore per-walk files
tools/stranger-test/results/*.json
# SK-STRG-004 composer invite sidecar (mode 600, trap-removed; mirror here
# in case the trap is bypassed by a hard-kill)
tools/stranger-test/results/.invite-*.txt
# BIRD Mini-Dev fixtures (~6 GB) live outside the repo
bird_data/
tools/eval/bird_data/

# E2E test runtime output (Playwright reports, traces, cassette caches)
tests/e2e/**/test-results/
tests/e2e/**/playwright-report/
tests/opencheck/.opencheck-cache/
tests/opencheck/.opencheck-recordings/
tests/opencheck/tests-runtime.yaml

# Go
/cli/bin/
/cli/dist/

# Rust
packages/nlqdb-rs/target/

# Ruby gem build artifacts
packages/nlqdb-rb/*.gem

# Terraform (if/when we add IaC)
*.tfstate
*.tfstate.*
.terraform/

# Tinybird CLI local auth (contains workspace token — never commit)
.tinyb

# quality-eval fixtures — downloaded at runtime (BIRD minidev / Spider 2.0-lite), never committed
/bird_data/
/spider2_data/
