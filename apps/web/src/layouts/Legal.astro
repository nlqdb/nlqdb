---
// Shared shell for the legal pages (/privacy, /terms). Plain Astro,
// zero JS (SK-WEB-001). Holds the prose styling + a neutral legal
// banner in one place so the two pages stay thin. Copy describes only
// practices the codebase actually implements — no aspirational policy.
import Footer from "../components/Footer.astro";
import Topnav from "../components/Topnav.astro";
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  heading: string;
  canonical: string;
  updated: string;
}

const { title, description, heading, canonical, updated } = Astro.props;
---

<Base title={title} description={description} canonical={canonical}>
  <div class="page">
    <Topnav />

    <main class="legal">
      <header class="legal__head">
        <p class="legal__kicker">Legal</p>
        <h1 class="legal__title">{heading}</h1>
        <p class="legal__updated">Last updated: {updated}</p>
        <p class="legal__note">
          Plain-English on purpose, and honest &mdash; this page describes only
          what nlqdb actually does today. Questions:
          <a href="mailto:contact@nlqdb.com">contact@nlqdb.com</a>.
        </p>
      </header>

      <div class="legal__body">
        <slot />
      </div>

      <p class="legal__cta">
        <a class="btn btn--accent" href="/">&larr; Back to nlqdb</a>
      </p>
    </main>

    <Footer />
  </div>
</Base>

<style is:global>
  .legal {
    padding: clamp(48px, 8vw, 96px) 0 clamp(48px, 6vw, 80px);
    max-width: 720px;
    margin: 0 auto;
  }

  .legal__head {
    margin-bottom: clamp(32px, 5vw, 48px);
  }

  .legal__kicker {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .legal__title {
    font-size: clamp(32px, 5vw, 52px);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 16px;
  }

  .legal__updated {
    margin: 0 0 20px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-muted);
  }

  .legal__note {
    margin: 0;
    padding: clamp(16px, 2.5vw, 20px);
    border: 2px solid var(--accent);
    background: var(--bg-elev);
    font-size: clamp(14px, 1.6vw, 15px);
    color: var(--fg-dim);
    line-height: 1.6;
  }

  .legal__body h2 {
    font-family: var(--mono);
    font-size: clamp(18px, 2.4vw, 22px);
    letter-spacing: -0.01em;
    margin: clamp(32px, 5vw, 44px) 0 12px;
  }

  .legal__body p {
    margin: 0 0 14px;
    font-size: clamp(15px, 1.6vw, 16px);
    color: var(--fg-dim);
    line-height: 1.7;
  }

  .legal__body ul {
    margin: 0 0 14px;
    padding-left: 22px;
  }

  .legal__body li {
    margin: 0 0 8px;
    font-size: clamp(15px, 1.6vw, 16px);
    color: var(--fg-dim);
    line-height: 1.6;
  }

  .legal__body a {
    color: var(--accent);
  }

  .legal__body strong {
    color: var(--fg);
  }

  .legal__cta {
    margin: clamp(36px, 5vw, 56px) 0 0;
    padding-top: clamp(20px, 3vw, 28px);
    border-top: 1px solid var(--border);
  }
</style>
