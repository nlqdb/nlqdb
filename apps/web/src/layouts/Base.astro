---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "nlqdb",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description,
  url: Astro.site?.toString(),
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0b0f0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    {/* SK-WEB-001 — pre-hydration fallback. The React ErrorBoundary
        catches throws DURING render; this block catches everything
        that happens BEFORE React mounts (chunk-load failures,
        top-level eval errors, unhandled promise rejections). Hidden
        by default; the inline script below reveals it on
        `window.error` / `unhandledrejection`. The markup is plain
        HTML so it renders even when zero JS executes. */}
    <div id="boot-fallback" hidden role="alert">
      <div class="boot-fallback__card">
        <h2 class="boot-fallback__title">Something broke on this page.</h2>
        <p class="boot-fallback__lede">
          The error has been recorded. Reload to recover; if it persists, sign out and back in.
        </p>
        <p id="boot-fallback-reason" class="boot-fallback__reason"></p>
        <div class="boot-fallback__actions">
          <button type="button" class="btn btn--accent" onclick="location.reload()">Reload</button>
          <a class="btn" href="/auth/sign-out">Sign out</a>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var revealed = false;
        function reveal(reason) {
          if (revealed) return;
          revealed = true;
          try {
            var node = document.getElementById("boot-fallback");
            if (node) {
              node.hidden = false;
              var r = document.getElementById("boot-fallback-reason");
              if (r && reason) r.textContent = String(reason).slice(0, 240);
            }
            try {
              fetch("/v1/errors/web", {
                method: "POST",
                headers: { "content-type": "application/json" },
                credentials: "include",
                body: JSON.stringify({
                  surface: "boot",
                  message: String(reason || "unknown"),
                  href: location.href,
                  userAgent: navigator.userAgent,
                }),
                keepalive: true,
              });
            } catch (_) {}
          } catch (_) {}
        }
        window.addEventListener("error", function (e) {
          reveal((e && e.message) || "Script error.");
        });
        window.addEventListener("unhandledrejection", function (e) {
          var r = e && e.reason;
          reveal((r && r.message) || (typeof r === "string" ? r : "Unhandled promise rejection."));
        });
      })();
    </script>
  </body>
</html>
