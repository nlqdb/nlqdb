---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "nlqdb",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description,
  url: Astro.site?.toString(),
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0b0f0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    {/* SK-WEB-001 — pre-hydration fallback. Catches crashes that fire
        BEFORE the page renders (chunk-load failures, top-level eval
        errors). Hidden by default; the inline script below reveals it
        on `window.error` / `unhandledrejection` strictly within the
        boot window — `DOMContentLoaded` flips `__nlqdbBooted` so any
        later throw belongs to ErrorBoundary (React islands) or the
        report pipeline, not this panel. Cross-origin and extension
        events are filtered out entirely. CSS pins the revealed panel
        as a fixed full-page overlay so it never paints under
        already-rendered content. The markup is plain HTML so it
        renders even when the JS bundle never executes. */}
    <div id="boot-fallback" hidden role="alert">
      <div class="boot-fallback__card">
        <h2 class="boot-fallback__title">Something broke on this page.</h2>
        <p class="boot-fallback__lede">
          The error has been recorded. Reload to recover; if it persists, sign out and back in.
        </p>
        <p id="boot-fallback-reason" class="boot-fallback__reason"></p>
        <div class="boot-fallback__actions">
          <button id="boot-fallback-reload" type="button" class="btn btn--accent">Reload</button>
          <a class="btn" href="/auth/sign-out">Sign out</a>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ apiBase: import.meta.env.PUBLIC_API_BASE ?? "" }}>
      (function () {
        var revealed = false;
        var seen = {};
        var seenCount = 0;
        function extractMessage(e) {
          if (!e) return "Script error.";
          if (e.error && e.error.message) return String(e.error.message);
          if (e.message) return String(e.message);
          var r = e.reason;
          if (r && r.message) return String(r.message);
          if (typeof r === "string") return r;
          return "Unhandled error.";
        }
        // Hand-copy of `lib/boot-fallback.ts#isExternalNoise`. This
        // script is `is:inline` (must run before any bundle) so it
        // can't import; the TS module exists so the rule is unit-
        // tested in `lib/boot-fallback.test.ts`. Keep in sync.
        function isExternalNoise(e, message) {
          if (message === "Script error.") return true;
          var filename = e && e.filename ? String(e.filename) : "";
          if (!filename) return false;
          if (filename.startsWith("chrome-extension://")) return true;
          if (filename.startsWith("moz-extension://")) return true;
          if (filename.startsWith("safari-web-extension://")) return true;
          if (filename.startsWith("safari-extension://")) return true;
          if (filename.startsWith("webkit-masked-url://")) return true;
          return false;
        }
        // W3C Trace Context — mint a fresh traceparent per report so
        // the server-side span attaches to it. Duplicates the helper
        // in `lib/error-report.ts` because this is an `is:inline`
        // boot script that can't import.
        function genHex(bytes) {
          var arr = new Uint8Array(bytes);
          crypto.getRandomValues(arr);
          var out = "";
          for (var i = 0; i < arr.length; i++) {
            out += arr[i].toString(16).padStart(2, "0");
          }
          return out;
        }
        function newTraceparent() {
          return "00-" + genHex(16) + "-" + genHex(8) + "-01";
        }
        function report(message) {
          var stack = (message || "").slice(0, 200);
          var fp = "boot::" + message + "::" + stack;
          if (seen[fp]) return;
          if (seenCount >= 32) { seen = {}; seenCount = 0; }
          seen[fp] = 1; seenCount++;
          try {
            fetch(apiBase + "/v1/errors/web", {
              method: "POST",
              headers: {
                "content-type": "application/json",
                traceparent: newTraceparent(),
              },
              credentials: "omit",
              keepalive: true,
              body: JSON.stringify({
                surface: "boot",
                message: message,
                href: location.href,
                userAgent: navigator.userAgent,
              }),
            }).catch(function () {});
          } catch (_) {}
        }
        function reveal(message) {
          // Past DOMContentLoaded the page has rendered; any further
          // throw belongs to ErrorBoundary (React islands) or the
          // report pipeline. Revealing here would only paint a fake
          // "broken" panel under healthy content. The CSS overlay
          // rule is a second line of defence in case this guard ever
          // regresses — the panel covers the viewport, never flows
          // under the footer.
          if (window.__nlqdbBooted) {
            report(message);
            return;
          }
          if (revealed) { report(message); return; }
          revealed = true;
          try {
            var node = document.getElementById("boot-fallback");
            if (node) {
              node.hidden = false;
              var r = document.getElementById("boot-fallback-reason");
              if (r && message) r.textContent = message.slice(0, 240);
            }
          } catch (_) {}
          report(message);
        }
        function onError(e) {
          var message = extractMessage(e);
          if (isExternalNoise(e, message)) return;
          reveal(message);
        }
        window.addEventListener("error", onError);
        window.addEventListener("unhandledrejection", onError);
        // Close the reveal gate as soon as the static HTML is parsed.
        // This is what makes the fix robust on every page — including
        // marketing pages with no React island. ErrorBoundary still
        // sets the same flag on mount; whichever fires first wins.
        function markBooted() { window.__nlqdbBooted = true; }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", markBooted);
        } else {
          markBooted();
        }
        document.addEventListener("DOMContentLoaded", function () {
          var btn = document.getElementById("boot-fallback-reload");
          if (btn) btn.addEventListener("click", function () { location.reload(); });
        });
      })();
    </script>
  </body>
</html>
