---
// Auto-sliding showcase with per-slide story arc (typewriter prompt
// inside the embed snippet → ignite result → hold → advance).
// Replaces the previous flat cross-fade so each slide tells a
// self-contained "drop this snippet → get this widget" story.
//
// One typewriter target per slide: the goal slot inside the embed
// snippet (HTML / CLI / REST / MCP — varies per example). The
// previous design also had a standalone input row; that was
// visually redundant since the snippet itself contains the goal,
// so it was dropped — visitors now read "this is the integration
// shape" + "and here's the result", with no duplicate input mock.
//
// Story phases (per active slide):
//   1. typing    — typewriter effect populates the embed's goal
//                  slot from empty (~30ms/char). Caret blinks
//                  inside the snippet at the typing position.
//   2. submitted — brief "lock-in" flash on the embed's border
//                  (~250ms) signaling "prompt is committed".
//   3. ignited   — result panel border swells to accent, table
//                  rows / status badges stagger-fade in.
//   4. holding   — settled state, ~2.6s for the eye to land.
//   5. advancing — cross-fade to next slide; story restarts.
//
// Pause semantics (mid-story-aware via AbortController):
//   • pointer hover, keyboard focus, document.hidden, off-screen
//     IntersectionObserver — all pause IMMEDIATELY (typewriter
//     freezes mid-character, hold timer pauses).
//   • prefers-reduced-motion — typing becomes instant, ignite is
//     a simple fade, hold time stays.
//
// Manual nav (prev/next/dot click) skips directly to `ignited`
// state (no replay of the typewriter) so a clicked-through slide
// still feels alive but doesn't make the user wait for the
// animation. After the hold, auto-advance resumes from there.
//
// Reusability: takes `examples` as a prop so a future caller
// (e.g. /docs page) can pass a different slice. `cycleMs` is
// retained as a back-compat knob but the per-slide story timing
// is what actually drives the cadence now (`storySleepMs` adjusts
// the hold-after-ignite portion specifically).

import type { ShowcaseExample } from "../data/showcase-examples";

type Props = {
  examples: ShowcaseExample[];
  // Hold time after the ignite phase before advancing. Default
  // 2600ms, plus the typewriter time (~goal-length × 30ms) → total
  // per-slide cadence ranges ~4-7s depending on goal length.
  storyHoldMs?: number;
  // Container height. Tall enough for the largest slide so phase
  // transitions don't reflow the page.
  minHeight?: string;
};

const {
  examples,
  storyHoldMs = 2600,
  minHeight = "clamp(380px, 60vh, 560px)",
} = Astro.props as Props;
---
<section class="carousel" aria-roledescription="carousel" aria-label="What you can do with nlqdb">
  <div class="carousel__frame" data-carousel data-story-hold-ms={storyHoldMs}>
    <ol class="carousel__slides" role="list" style={`min-height: ${minHeight};`}>
      {examples.map((ex, i) => (
        <li
          id={`slide-${ex.id}`}
          class="carousel__slide"
          data-slide
          data-index={i}
          data-active={i === 0 ? "" : null}
          data-phase="idle"
          aria-hidden={i === 0 ? "false" : "true"}
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${examples.length}: ${ex.goal}`}
        >
          <header class="card__head">
            <span class="card__cat" data-cat={ex.category}>{ex.category}</span>
          </header>

          {(() => {
            // Split the embed template on the `{goal}` placeholder so
            // we can interleave a typewriter span at the slot. Astro
            // auto-escapes the surrounding text on interpolation —
            // `<nlq-data>` etc. renders verbatim (no element-
            // registration risk).
            const [embedBefore = "", embedAfter = ""] = ex.embed.template.split("{goal}");
            // Surface chip — short, scan-friendly identifier so a
            // visitor flicking past several slides sees the surface
            // diversity (HTML widget vs CLI vs REST vs MCP tool call)
            // at a glance.
            const surfaceLabel =
              ex.embed.lang === "html"
                ? "HTML"
                : ex.embed.lang === "bash"
                  ? "CLI"
                  : ex.embed.lang === "rest"
                    ? "REST"
                    : "MCP";
            const surfaceAria =
              ex.embed.lang === "html"
                ? "HTML embed"
                : ex.embed.lang === "bash"
                  ? "CLI command"
                  : ex.embed.lang === "rest"
                    ? "REST API call"
                    : "MCP tool call";
            return (
              <div class="card__embed" data-embed-lang={ex.embed.lang} aria-label={surfaceAria}>
                <span class="card__embed-label" aria-hidden="true">{surfaceLabel}</span>
                <pre class="card__embed-pre"><code>{embedBefore}<span class="card__embed-goal" data-input-text data-goal={ex.goal}></span>{embedAfter}</code></pre>
              </div>
            );
          })()}

          <p class="card__renders" aria-hidden="true">renders ↓</p>

          <div class="card__result" data-result>
            {ex.category === "read" && ex.rows && ex.rows.length > 0 ? (
              <div class="card__rows">
                <table class="card__table">
                  <thead>
                    <tr>
                      {Object.keys(ex.rows[0] ?? {}).map((col) => (
                        <th>{col}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {ex.rows.map((row, ri) => (
                      <tr style={`--row-i: ${ri}`}>
                        {Object.values(row).map((v) => (
                          <td>{v == null ? "" : String(v)}</td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="card__status">{ex.status}</p>
            )}

            {ex.summary && <p class="card__summary">{ex.summary}</p>}

            <details class="card__sql-details">
              <summary class="card__sql-summary">SQL the engine ran</summary>
              <pre class="card__sql"><code>{ex.sql}</code></pre>
            </details>
          </div>
        </li>
      ))}
    </ol>

    <nav class="carousel__nav" aria-label="Slide controls">
      <button type="button" class="carousel__btn" data-prev aria-label="Previous example">‹</button>
      <ol class="carousel__dots" role="tablist" aria-label="Select example">
        {examples.map((ex, i) => (
          <li>
            <button
              type="button"
              class="carousel__dot"
              data-dot
              data-index={i}
              data-active={i === 0 ? "" : null}
              role="tab"
              aria-controls={`slide-${ex.id}`}
              aria-selected={i === 0 ? "true" : "false"}
              aria-label={`Go to example ${i + 1}: ${ex.goal}`}
            ></button>
          </li>
        ))}
      </ol>
      <button type="button" class="carousel__btn" data-next aria-label="Next example">›</button>
    </nav>
  </div>
</section>

<script>
  // Per-slide story-arc carousel. AbortController is the central
  // primitive — every async step (typewriter, hold, ignite delays)
  // takes a signal so pause is instant and resume is clean.
  const root = document.querySelector<HTMLElement>("[data-carousel]");
  if (root && root.querySelectorAll("[data-slide]").length > 0) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const storyHoldMs = Number(root.dataset["storyHoldMs"] ?? "2600");
    const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Tunables — picked for "skim-friendly" cadence:
    //   typeMs        per-character delay; ~30ms reads as natural
    //                 human typing without dragging.
    //   submittedMs   the brief "press enter" flash duration.
    //   igniteMs      time the ignite border/stagger animation plays.
    //   holdMs        eye-rest after ignite finishes.
    const typeMs = reducedMotion ? 0 : 28;
    const submittedMs = reducedMotion ? 0 : 240;
    const holdMs = reducedMotion ? 1200 : storyHoldMs;

    let index = 0;
    let paused = false;
    // Single-flight controller for the running story; aborting
    // cancels mid-typewriter / mid-hold cleanly.
    let storyAbort: AbortController | null = null;
    // Promise of the current loop iteration. Used as a drain-
    // primitive: pause/resume races (notably document.visibilitychange
    // hide-then-show) used to leave the loop in a state where:
    //   • the previous iteration was aborted (catch microtask
    //     pending),
    //   • a new resume() was kicked synchronously,
    //   • the new resume saw `looping = true` (a synchronous flag
    //     that hadn't been reset yet by the still-pending catch),
    //   • bailed early — slide stuck mid-typewriter forever.
    // Awaiting this promise before re-arming guarantees the old
    // iteration has finished draining (the catch + finally have
    // run) before the new one starts.
    let runningLoop: Promise<void> | null = null;

    // Cancellable sleep — resolves on timeout OR rejects on abort.
    function sleep(ms: number, signal: AbortSignal): Promise<void> {
      return new Promise((resolve, reject) => {
        if (signal.aborted) {
          reject(new DOMException("aborted", "AbortError"));
          return;
        }
        const t = setTimeout(() => {
          signal.removeEventListener("abort", onAbort);
          resolve();
        }, ms);
        const onAbort = () => {
          clearTimeout(t);
          reject(new DOMException("aborted", "AbortError"));
        };
        signal.addEventListener("abort", onAbort, { once: true });
      });
    }

    // Typewriter — appends one char at a time to every target in
    // sync. Currently each slide has ONE target (the embed snippet's
    // `{goal}` slot), but we keep the array shape so a future
    // caller — e.g. a "REST + curl + JS-SDK" tabbed slide that
    // shows the same goal landing in multiple snippet variants —
    // can populate them in lockstep without rewriting this loop.
    async function typewrite(
      targets: HTMLElement[],
      text: string,
      perCharMs: number,
      signal: AbortSignal,
    ): Promise<void> {
      for (const t of targets) t.textContent = "";
      if (perCharMs <= 0) {
        for (const t of targets) t.textContent = text;
        return;
      }
      for (let i = 0; i < text.length; i++) {
        if (signal.aborted) throw new DOMException("aborted", "AbortError");
        const slice = text.slice(0, i + 1);
        for (const t of targets) t.textContent = slice;
        // Slight cadence variation on whitespace — punchier reading.
        const isSpace = text[i] === " ";
        await sleep(isSpace ? Math.max(8, perCharMs / 2) : perCharMs, signal);
      }
    }

    function setPhase(slide: HTMLElement, phase: "idle" | "typing" | "submitted" | "ignited") {
      slide.dataset["phase"] = phase;
    }

    // Plays the active slide's story arc. Throws AbortError on
    // pause/cancellation. Caller (the auto-advance loop) catches
    // and exits silently.
    async function playStory(slide: HTMLElement, signal: AbortSignal): Promise<void> {
      const inputs = Array.from(slide.querySelectorAll<HTMLElement>("[data-input-text]"));
      const goal = inputs[0]?.dataset["goal"] ?? "";
      if (inputs.length === 0) return;

      setPhase(slide, "typing");
      await typewrite(inputs, goal, typeMs, signal);

      setPhase(slide, "submitted");
      await sleep(submittedMs, signal);

      setPhase(slide, "ignited");
      await sleep(holdMs, signal);
    }

    // Fast-forward to ignited — used by manual nav. Skips
    // typewriter so a clicked-through slide doesn't make the user
    // wait. The auto-advance loop will continue from "holding"
    // after the next call.
    function fastForward(slide: HTMLElement) {
      const inputs = slide.querySelectorAll<HTMLElement>("[data-input-text]");
      for (const input of inputs) {
        const goal = (input as HTMLElement).dataset["goal"] ?? "";
        input.textContent = goal;
      }
      setPhase(slide, "ignited");
    }

    function show(next: number, opts: { animate: boolean }) {
      const n = ((next % slides.length) + slides.length) % slides.length;
      const prev = slides[index];
      const cur = slides[n];
      if (prev && prev !== cur) {
        prev.removeAttribute("data-active");
        prev.setAttribute("aria-hidden", "true");
        // Reset the prev slide's story state so re-visits replay
        // cleanly from `idle`. We iterate over all targets rather
        // than the single embed slot directly, so the multi-target
        // future case (see typewrite() comment) keeps working.
        setPhase(prev, "idle");
        for (const input of prev.querySelectorAll<HTMLElement>("[data-input-text]")) {
          input.textContent = "";
        }
      }
      if (cur) {
        cur.setAttribute("data-active", "");
        cur.setAttribute("aria-hidden", "false");
        if (!opts.animate) fastForward(cur);
      }
      const prevDot = dots[index];
      const curDot = dots[n];
      if (prevDot) {
        prevDot.removeAttribute("data-active");
        prevDot.setAttribute("aria-selected", "false");
      }
      if (curDot) {
        curDot.setAttribute("data-active", "");
        curDot.setAttribute("aria-selected", "true");
      }
      index = n;
    }

    // Cancel the in-flight story (caller arms a new one when
    // appropriate via `runLoop`).
    function cancelStory() {
      storyAbort?.abort();
      storyAbort = null;
    }

    // Inner loop body. Cooperative cancellation: every iteration
    // checks `paused` between awaits so a mid-flight pause exits
    // promptly without an extra wakeup tick.
    async function loopBody(): Promise<void> {
      while (!paused) {
        const slide = slides[index];
        if (!slide) break;
        storyAbort = new AbortController();
        try {
          await playStory(slide, storyAbort.signal);
        } catch {
          return; // aborted; caller (startLoop) is responsible for re-arming
        }
        if (paused) return;
        show(index + 1, { animate: true });
      }
    }

    // Start (or restart) the auto-advance loop. Awaits any in-
    // flight iteration's full drain before kicking a new one.
    // Called from: initial mount, resume(), manualNav. Idempotent.
    async function startLoop(): Promise<void> {
      // Cancel any in-flight story so the previous loop exits its
      // current await; then wait for that loop's promise to resolve
      // (catch + finally have run) before starting fresh.
      if (runningLoop) {
        cancelStory();
        try {
          await runningLoop;
        } catch {
          /* drained */
        }
      }
      if (paused) return;
      // Placeholder init so TS's control-flow analysis can prove
      // `p` is assigned before the IIFE's finally references it
      // (closure captures by reference; the IIFE's await queues a
      // microtask, so by the time finally runs, `p` IS assigned —
      // but TS can't see that without the placeholder).
      let p: Promise<void> = Promise.resolve();
      p = (async () => {
        try {
          await loopBody();
        } finally {
          if (runningLoop === p) {
            runningLoop = null;
            storyAbort = null;
          }
        }
      })();
      runningLoop = p;
    }

    function pause() {
      if (paused) return;
      paused = true;
      cancelStory();
    }
    function resume() {
      if (!paused) return;
      paused = false;
      // Fire-and-forget — startLoop awaits the drain internally.
      // We don't `await` here because the resume() callers (event
      // handlers) don't expect to block.
      startLoop();
    }

    // Keyboard-focus pause stays — a user tabbing through the
    // prev/next/dot controls expects the carousel to hold still.
    // Hover pause (`pointerenter` / `pointerleave`) was dropped:
    // the carousel is the page's main attraction; pausing every
    // time the cursor passes over it (including incidental
    // pointermoves on touchpads + tablets) made the showcase feel
    // unresponsive.
    root.addEventListener("focusin", pause);
    root.addEventListener("focusout", resume);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) pause();
      else resume();
    });

    // Manual nav: cancel the in-flight story, jump to the target
    // slide, PLAY THE STORY from the start (typing → ignite →
    // hold). Goes through startLoop so any in-flight iteration is
    // properly drained before we re-arm — same race-prevention
    // path as resume().
    function manualNav(targetIndex: number) {
      cancelStory();
      show(targetIndex, { animate: true });
      if (!paused) startLoop();
    }

    root.querySelector<HTMLElement>("[data-prev]")?.addEventListener("click", () =>
      manualNav(index - 1),
    );
    root.querySelector<HTMLElement>("[data-next]")?.addEventListener("click", () =>
      manualNav(index + 1),
    );
    for (const dot of dots) {
      dot.addEventListener("click", () => {
        const i = Number(dot.dataset["index"]);
        if (Number.isInteger(i)) manualNav(i);
      });
    }

    // Pause when off-screen, resume when visible. The initial
    // observe fires synchronously with isIntersecting=true if the
    // carousel is in view at mount — but `resume()` is a no-op
    // when `paused` is false (its initial value), so we route the
    // first visible-intersect through startLoop() directly so the
    // first visit animates without needing a stray pause first.
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            if (paused) resume();
            else startLoop();
          } else {
            pause();
          }
        }
      });
      io.observe(root);
    } else {
      startLoop();
    }
  }
</script>

<style>
  .carousel {
    margin: 32px 0 16px;
  }
  .carousel__frame {
    position: relative;
    border: 3px solid var(--border-strong);
    background: var(--bg-elev);
    box-shadow: var(--shadow-hard);
    overflow: hidden;
  }
  .carousel__slides {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .carousel__slide {
    position: absolute;
    inset: 0;
    padding: 28px clamp(20px, 4vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }
  .carousel__slide[data-active] {
    opacity: 1;
    pointer-events: auto;
  }

  .card__head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .card__cat {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 2px solid currentColor;
    color: var(--accent);
  }
  .card__cat[data-cat="write"],
  .card__cat[data-cat="schema"] {
    color: #ffb84d;
  }
  .card__cat[data-cat="create"] {
    color: #b3ff99;
  }

  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  /* Result panel — dim by default, "ignites" when phase=ignited.
     Border swells to accent, table rows stagger-fade in. */
  .card__result {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px 14px;
    border: 2px solid var(--border);
    background: var(--bg-elev);
    opacity: 0.45;
    transition: opacity 320ms ease, border-color 320ms ease,
                background 320ms ease, box-shadow 320ms ease;
  }
  .carousel__slide[data-phase="ignited"] .card__result {
    opacity: 1;
    border-color: var(--accent);
    background: var(--bg);
    box-shadow: 0 0 0 2px var(--accent), 4px 4px 0 0 var(--border-strong);
  }

  /* Embed code block — the only typewriter target on each slide.
     The {goal} slot inside the snippet fills via the typewriter,
     so visitors read the integration shape AND watch the prompt
     get inscribed into it in a single animation. Surface label
     (HTML / CLI / REST / MCP) sits as a chip tucked above the
     pre block so the surface kind is identifiable at a glance.
     Border flash on the pre block tracks the story phases —
     a subtle "lock-in" beat at `submitted` before the result
     panel ignites. */
  .card__embed {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }
  .card__embed-label {
    /* Chip-style surface tag — sits above the pre block, slightly
       overlapping its top border so it reads as "this code's
       language is X". Acid-on-near-black matches the carousel's
       neo-brutalist palette. */
    align-self: flex-start;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 3px 10px;
    color: var(--bg);
    background: var(--accent);
    border: 2px solid var(--accent);
    /* Tuck flush against the pre's top border. Negative margin
       overlaps by 2px so the chip's bottom edge becomes the pre's
       top edge — no double-line. */
    margin-bottom: -2px;
    position: relative;
    z-index: 1;
  }
  .card__embed-pre {
    margin: 0;
    padding: 12px 14px;
    font-family: var(--mono);
    font-size: clamp(12px, 1.4vw, 14px);
    line-height: 1.55;
    color: var(--fg);
    background: var(--bg);
    border: 3px solid var(--border-strong);
    box-shadow: 4px 4px 0 0 var(--border-strong);
    overflow-x: auto;
    /* Preserve template whitespace exactly — embed snippets have
       intentional spacing inside attributes / multi-line REST
       templates rely on it. */
    white-space: pre;
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }
  /* Lock-in flash + ignited state — the embed's border swells to
     accent when the prompt is "committed", mirroring the previous
     input-row treatment. Carries the visual beat across the
     story arc without needing a separate input mock. */
  .carousel__slide[data-phase="submitted"] .card__embed-pre,
  .carousel__slide[data-phase="ignited"] .card__embed-pre {
    border-color: var(--accent);
    box-shadow: 4px 4px 0 0 var(--accent);
  }
  .card__embed-goal {
    /* Highlight the typewriter slot so the eye tracks the live-
       typing portion separately from the static template text.
       Inline-block lets it grow as chars stream in without
       reflowing the surrounding snippet. */
    color: var(--accent);
    font-weight: 600;
    display: inline-block;
    /* Reserve a min-width so the empty slot doesn't collapse the
       line on idle/typing-start (otherwise the surrounding
       template text would jump on every char tick). */
    min-width: 1ch;
    /* Anchor a `::after` caret that blinks during `phase=typing`. */
    position: relative;
  }
  .carousel__slide[data-phase="typing"] .card__embed-goal::after {
    /* Typewriter caret pinned at the end of the typed-so-far
       slice. The caret rides along as chars stream in (because
       the span sizes to its content). Replaces the standalone
       input's `▌` — same affordance, different home. */
    content: "▌";
    color: var(--accent);
    margin-left: 1px;
    animation: cursor-blink 1s steps(2, jump-none) infinite;
  }

  /* Caption that bridges embed → rendered result. The arrow points
     at the result panel below; visible from the start (idle phase
     too) so the layout reads correctly even before the typewriter
     fires. */
  .card__renders {
    margin: 4px 0 -4px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-align: center;
  }

  /* `<details>` for the engine's SQL — collapsed by default so
     the rendered widget gets the visual emphasis. Open behavior
     lets curious visitors verify what the engine ran without
     forcing it on every slide. */
  .card__sql-details {
    margin-top: 4px;
    font-family: var(--mono);
    font-size: 11px;
  }
  .card__sql-summary {
    cursor: pointer;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    list-style: none;
    padding: 4px 0;
  }
  .card__sql-summary::-webkit-details-marker { display: none; }
  .card__sql-summary::before {
    content: "▸ ";
    transition: transform 150ms ease;
    display: inline-block;
  }
  .card__sql-details[open] .card__sql-summary::before {
    transform: rotate(90deg);
  }
  .card__sql-summary:hover { color: var(--fg); }

  .card__sql {
    margin: 8px 0 0;
    padding: 10px 12px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    overflow-x: auto;
  }
  .card__status {
    margin: 0;
    padding: 10px 14px;
    font-family: var(--mono);
    font-size: 14px;
    color: var(--accent);
    background: var(--bg);
    border: 2px dashed currentColor;
  }
  .card__rows {
    overflow-x: auto;
  }
  .card__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 13px;
  }
  .card__table th,
  .card__table td {
