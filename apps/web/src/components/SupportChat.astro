---
// Tawk.to support chat — product `/app/*` surfaces ONLY, mounted beside
// <AppAnalytics /> (same scoping as SK-WEB-024): marketing/blog/vs/solve
// pages stay third-party-SDK-free per GLOBAL-034 (Lighthouse-100 +
// no-cookie-banner posture). Official async embed snippet; its throws are
// ignored by the boot-fallback panel (lib/boot-fallback.ts).
---
<script is:inline>
  var Tawk_API = Tawk_API || {},
    Tawk_LoadStart = new Date();
  (function () {
    var s1 = document.createElement("script"),
      s0 = document.getElementsByTagName("script")[0];
    s1.async = true;
    s1.src = "https://embed.tawk.to/6a58f0cc096ab21d402a6b88/1jtlmp8d1";
    s1.charset = "UTF-8";
    s1.setAttribute("crossorigin", "*");
    s0.parentNode.insertBefore(s1, s0);
  })();
</script>
