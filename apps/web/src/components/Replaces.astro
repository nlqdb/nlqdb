---
// "What this replaces" — the third and final homepage beat
// (redesign-plan §5 `/` beat 3). Eight things a normal stack forces
// you to wire up, struck through, collapsing into the single
// `<nlq-data>` line. The strikethrough sweep is the page's one
// earned scroll moment (motion budget §6 step 9); the final
// `<nlq-data>` row keeps mono — code earns it here — with lime on
// the tag identifier. One CTA below; no supporting paragraph.

import Cta from "./Cta.astro";

const replaces = ["Database", "Schema", "ORM", "Endpoint", "Auth", "Cache", "Migrations", "Deploy"];
---

<section class="replaces" aria-labelledby="replaces-title">
  <h2 class="replaces__title" id="replaces-title">
    Eight boxes&hairsp;&mdash;&hairsp;or one tag.
  </h2>

  <ul class="replaces__list" aria-label="Things you no longer build">
    {
      replaces.map((item, i) => (
        <li class="replaces__item" style={`--i:${i}`}>
          <span class="replaces__strike">{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="replaces__final" aria-hidden="false">
    <code class="replaces__code">
      &lt;<span class="replaces__tag">nlq-data</span>&gt;
    </code>
  </div>

  <Cta href="/app/new" label="Start with one sentence →" />
</section>

<style is:global>
  .replaces {
    padding: clamp(64px, 12vw, 120px) 0 clamp(80px, 14vw, 140px);
    max-width: var(--col);
    border-top: 1px solid var(--rule);
    margin-top: clamp(40px, 6vw, 80px);
  }

  .replaces__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
    text-wrap: balance;
    max-width: 18ch;
    margin: 0 0 clamp(28px, 4vw, 40px);
  }

  .replaces__list {
    list-style: none;
    margin: 0 0 clamp(36px, 5vw, 56px);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .replaces__item {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 400;
    line-height: 1.15;
    color: var(--muted);
    position: relative;
    display: inline-block;
    width: max-content;
    max-width: 100%;
  }

  .replaces__strike {
    position: relative;
    display: inline-block;
  }

  /* The page's one earned scroll moment — strikes sweep left-to-right
   * as the section enters the viewport, staggered by --i. */
  @media (prefers-reduced-motion: no-preference) {
    .replaces__strike::after {
      content: "";
      position: absolute;
      top: 52%;
      left: -2px;
      right: -2px;
      height: 3px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left center;
      animation: replaces-strike linear both;
      animation-timeline: view();
      animation-range: entry 30% cover 60%;
      animation-delay: calc(var(--i, 0) * 40ms);
    }

    @keyframes replaces-strike {
      to {
        transform: scaleX(1);
      }
    }

    /* Browsers without scroll-driven timelines: show the strike at rest. */
    @supports not (animation-timeline: view()) {
      .replaces__strike::after {
        transform: scaleX(1);
        animation: none;
      }
    }
  }

  /* Reduced motion + scroll-timeline missing: pre-draw the strike. */
  @media (prefers-reduced-motion: reduce) {
    .replaces__strike::after {
      content: "";
      position: absolute;
      top: 52%;
      left: -2px;
      right: -2px;
      height: 3px;
      background: var(--accent);
    }
  }

  .replaces__final {
    margin: 0 0 clamp(28px, 4vw, 40px);
  }

  .replaces__code {
    font-family: var(--mono);
    font-size: clamp(22px, 3.4vw, 36px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .replaces__tag {
    color: var(--accent);
  }
</style>
