---
// "What this replaces" strip (DESIGN §3.1, §0.1). Eight things a
// normal stack forces you to set up — DB, schema, ORM, endpoint,
// auth, cache, migration, deploy — collapsing into a single line of
// HTML. Pure CSS scroll animation; no JS. Strikes are staggered via
// `--i` so they sweep left-to-right as the section scrolls into
// view; the @supports fallback shows them at rest on browsers
// without scroll-driven timelines.

const replaces = ["Database", "Schema", "ORM", "Endpoint", "Auth", "Cache", "Migrations", "Deploy"];
---

<section class="replaces" aria-labelledby="replaces-title">
  <h2 class="replaces__title" id="replaces-title">
    Eight boxes&hairsp;&mdash;&hairsp;or one tag.
  </h2>
  <p class="replaces__lede">
    Everything a normal backend forces you to wire together, replaced by
    a single element on the page.
  </p>

  <div class="replaces__grid">
    <ul class="replaces__list" aria-label="Things you no longer build">
      {
        replaces.map((item, i) => (
          <li class="replaces__item" style={`--i:${i}`}>
            <span class="replaces__strike">{item}</span>
          </li>
        ))
      }
    </ul>

    <div class="replaces__arrow" aria-hidden="true">
      <span>&rarr;</span>
    </div>

    <div class="replaces__final">
      <code class="replaces__code">&lt;nlq-data&gt;</code>
      <p class="replaces__final-note">
        One element. Schema, plan, cache, auth — all server-side, all
        invisible.
      </p>
    </div>
  </div>
</section>

<style is:global>
  .replaces {
    padding: clamp(48px, 8vw, 96px) 0;
    border-top: 1px solid var(--border);
  }

  .replaces__title {
    font-family: var(--mono);
    font-size: clamp(24px, 3.6vw, 36px);
    letter-spacing: -0.02em;
    max-width: 22ch;
  }

  .replaces__lede {
    margin: 12px 0 clamp(28px, 4vw, 40px);
    color: var(--fg-dim);
    max-width: 60ch;
    font-size: clamp(15px, 1.6vw, 16px);
  }

  .replaces__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }

  @media (min-width: 880px) {
    .replaces__grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 32px;
    }
  }

  .replaces__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  @media (min-width: 540px) {
    .replaces__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 880px) {
    .replaces__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .replaces__item {
    padding: 16px 18px;
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    font-family: var(--mono);
    font-size: clamp(15px, 1.4vw, 17px);
    font-weight: 500;
    color: var(--fg-muted);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .replaces__strike {
    position: relative;
    display: inline-block;
  }

  .replaces__strike::after {
    content: "";
    position: absolute;
    top: 50%;
    left: -4px;
    right: -4px;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left center;
    animation: replaces-strike linear both;
    animation-timeline: view();
    animation-range: entry 30% cover 60%;
    animation-delay: calc(var(--i, 0) * 40ms);
  }

  @keyframes replaces-strike {
    to {
      transform: scaleX(1);
    }
  }

  /* Browsers without scroll-driven timelines: show the strike at rest. */
  @supports not (animation-timeline: view()) {
    .replaces__strike::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .replaces__strike::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  .replaces__arrow {
    font-family: var(--mono);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--accent);
    text-align: center;
    line-height: 1;
  }

  @media (max-width: 879px) {
    .replaces__arrow {
      transform: rotate(90deg);
    }
  }

  .replaces__final {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: clamp(20px, 3vw, 28px);
    background: var(--accent);
    color: var(--accent-fg);
    border: 2px solid var(--accent-fg);
    box-shadow: 6px 6px 0 0 var(--accent-fg);
  }

  .replaces__code {
    font-family: var(--mono);
    font-size: clamp(20px, 3vw, 30px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--accent-fg);
  }

  .replaces__final-note {
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--accent-fg);
    opacity: 0.85;
    max-width: 30ch;
  }
</style>
