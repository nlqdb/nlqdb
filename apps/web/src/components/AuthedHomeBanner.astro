---
// Surfaces a "Welcome back — open chat" banner at the top of the
// home page when the visitor already has a session. The marketing
// hero stays in place underneath (some authed users genuinely want
// to copy a snippet for a side project), but the banner gives the
// quick-jump path the user expects: "I'm signed in, take me to my
// chat".
//
// Hidden by default; revealed by the inline script after the
// /api/auth/get-session probe resolves authed. This keeps signed-
// out visitors from ever seeing a flash of authed chrome.
---

<aside id="authed-home-banner" class="authed-home-banner" hidden>
  <p class="authed-home-banner__text">
    Welcome back. Pick up where you left off.
  </p>
  <a href="/app" class="btn btn--accent authed-home-banner__cta">
    Open chat &rarr;
  </a>
</aside>

<script>
  import { fetchSession } from "../lib/session";

  const banner = document.getElementById("authed-home-banner");
  if (banner) {
    void (async () => {
      const user = await fetchSession();
      if (user) banner.hidden = false;
    })();
  }
</script>

<style>
  .authed-home-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 18px;
    margin: 8px 0 24px;
    border: 1px solid var(--accent);
    background: rgba(198, 244, 50, 0.06);
    font-family: var(--mono);
    font-size: 14px;
  }

  .authed-home-banner__text {
    margin: 0;
    color: var(--fg);
  }

  .authed-home-banner__cta {
    flex-shrink: 0;
  }
</style>
