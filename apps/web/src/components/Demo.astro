---
// Homepage beat 2 — the agent loop, server-rendered as proof
// (SK-WEB-003 "code is the proof", SK-PIVOT-004 crawlable/no-JS).
//
// Closes the headline-demo gap WS-13 left: the headline talks about
// agent memory, so the demo shows the agent loop, not a generalist
// orders table. Two MCP tool calls (`nlqdb_remember` → typed row,
// `nlqdb_recall` → NL question), the exact SQL nlqdb compiled, the
// answer rows. Same proof shape `/agents` uses, in compact form;
// `/agents` keeps the deeper version (matrix, trust boundary,
// self-host).
//
// The lime moments are the two MCP tool identifiers — the only
// accent on this beat. No React island; pre-rendered HTML.

// The remember/recall pair. Kept in sync with /agents/index.astro;
// if you change one, change the other (same story, two depths). The
// tool-call code blocks are inlined in the JSX below so the lime
// `.demo__tag` span can wrap just the identifier without splitting
// the literal.

const rememberResult = `→ { id: 4129, ok: true }`;

const recallSql = `SELECT user_id, COUNT(*) AS feedback
  FROM agent_memory
 WHERE category = 'user_preference'
   AND created_at >= date_trunc('month', now())
 GROUP BY user_id
 ORDER BY feedback DESC;`;

const recallRows = [
  { user_id: "u_412", feedback: 14 },
  { user_id: "u_207", feedback: 9 },
  { user_id: "u_388", feedback: 6 },
  { user_id: "u_104", feedback: 4 },
];
---

<section class="demo" aria-labelledby="demo-eyebrow">
  <p class="demo__eyebrow" id="demo-eyebrow">What your agent does with it.</p>
  <h2 class="demo__title">
    Your agent writes a row, then asks a question.
  </h2>

  <div class="demo__pair">
    <article class="demo__col" aria-label="Remember">
      <p class="demo__col-label">1 · Remember</p>
      <pre class="demo__code"><code><span class="demo__tag">nlqdb_remember</span>(&#123;
  category: "user_preference",
  content: "prefers concise replies",
  user_id: "u_412"
&#125;)</code></pre>
      <p class="demo__col-out"><code>{rememberResult}</code></p>
      <p class="demo__col-note">
        The row lands in <code>agent_memory</code> — typed columns, not an
        opaque vector blob.
      </p>
    </article>

    <article class="demo__col" aria-label="Recall">
      <p class="demo__col-label">2 · Recall</p>
      <pre class="demo__code"><code><span class="demo__tag">nlqdb_recall</span>(&#123;
  question: "feedback per user, ranked by count this month"
&#125;)</code></pre>
      <p class="demo__col-sub">Compiled SQL (the exact statement nlqdb ran):</p>
      <pre class="demo__sql"><code>{recallSql}</code></pre>
      <div class="demo__data" role="region" aria-label="Result rows">
        <table class="nlq-table">
          <thead>
            <tr>
              <th>User ID</th>
              <th>Feedback</th>
            </tr>
          </thead>
          <tbody>
            {recallRows.map((r) => (
              <tr>
                <td>{r.user_id}</td>
                <td>{r.feedback}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>
  </div>
</section>

<style is:global>
  .demo {
    padding: clamp(64px, 12vw, 120px) 0 clamp(48px, 8vw, 80px);
    max-width: var(--bleed);
  }

  .demo__eyebrow {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .demo__title {
    margin: 0 0 clamp(28px, 4vw, 40px);
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-wrap: balance;
    max-width: 22ch;
  }

  .demo__pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: start;
  }

  @media (min-width: 880px) {
    .demo__pair {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }

  .demo__col {
    margin: 0;
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .demo__col-label {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .demo__code,
  .demo__sql {
    margin: 0;
    padding: 16px 18px;
    background: var(--ground);
    border: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.55;
    color: var(--body);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: normal;
  }

  .demo__code code,
  .demo__sql code {
    font-family: inherit;
  }

  .demo__col-out {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .demo__col-out code,
  .demo__col-note code {
    font-family: inherit;
    color: var(--body);
  }

  .demo__col-note {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.55;
    max-width: 46ch;
  }

  .demo__col-sub {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .demo__data {
    overflow-x: auto;
  }

  /* The lime moment for this beat — only the two MCP tool identifiers glow. */
  .demo__tag {
    color: var(--accent);
    font-weight: 600;
  }
</style>
