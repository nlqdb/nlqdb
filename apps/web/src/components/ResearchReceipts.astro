---
// Below-the-fold "we did our homework" section. Cites the prior-art
// and incident research that shaped the design — Replit incident,
// Cortex Analyst's 90% accuracy, Pinterest's table-card RAG,
// Keysight's prompt-injection-via-rows class, dbt 2026 semantic-layer
// benchmark. Pulls from a curated subset of `docs/research-receipts.md`
// so the homepage stays in lockstep with the canonical source.
//
// Why on the homepage: a pre-alpha making technical claims has to
// show its work. The carousel pitches a polished surface; this
// section gives a skeptical visitor receipts. Inspiration: Maggie
// Appleton's "garden" pattern of citing where each idea came from.

import { RECEIPTS } from "../data/research-receipts";
---

<section class="research-receipts" aria-labelledby="research-receipts-title">
  <header class="research-receipts__head">
    <p class="research-receipts__kicker">Backed by the work</p>
    <h2 class="research-receipts__title" id="research-receipts-title">
      We didn't make this up. Here's where each idea comes from.
    </h2>
    <p class="research-receipts__lede">
      Pre-alpha making technical claims has to show its work. Each
      design call below is anchored to a specific paper, postmortem,
      or production system that taught us the lesson.
    </p>
  </header>

  <ol class="research-receipts__list">
    {
      RECEIPTS.map((r, i) => (
        <li class="research-receipts__item">
          <span class="research-receipts__num" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          <h3 class="research-receipts__lesson">{r.lesson}</h3>
          <p class="research-receipts__why">{r.why}</p>
          <p class="research-receipts__src">
            <a
              class="research-receipts__src-link"
              href={r.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {r.source} <span aria-hidden="true">↗</span>
            </a>
          </p>
          <p class="research-receipts__applied">
            Applied at <span class="research-receipts__applied-loc">{r.appliedAt.label}</span>
          </p>
        </li>
      ))
    }
  </ol>

  {/* Full receipts doc link is intentionally omitted for now —
      the doc lives at `/docs/research-receipts.md` in the repo,
      which is private during pre-alpha. When the repo flips public
      we'll link to it here (or render a public `/research` route).
      The five cards above are a complete standalone artifact. */}
</section>

<style is:global>
  .research-receipts {
    padding: clamp(48px, 8vw, 96px) 0;
    border-top: 1px solid var(--border);
  }

  .research-receipts__head {
    margin-bottom: clamp(28px, 4vw, 40px);
    max-width: 60ch;
  }

  .research-receipts__kicker {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .research-receipts__title {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: clamp(24px, 3.6vw, 36px);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .research-receipts__lede {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-dim);
  }

  .research-receipts__list {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(24px, 4vw, 32px);
    display: grid;
    gap: 16px;
  }

  @media (min-width: 720px) {
    .research-receipts__list {
      /* Five cards lay out as 3+2 on wide screens; auto-fit keeps
         smaller breakpoints readable. */
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }
  }

  .research-receipts__item {
    padding: clamp(20px, 2.5vw, 28px);
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    box-shadow: var(--shadow-hard);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .research-receipts__num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--accent);
  }

  .research-receipts__lesson {
    margin: 0;
    font-family: var(--mono);
    font-size: clamp(15px, 1.7vw, 17px);
    letter-spacing: -0.01em;
    color: var(--fg);
    line-height: 1.25;
  }

  .research-receipts__why {
    margin: 0;
    font-size: 13px;
    color: var(--fg-dim);
    line-height: 1.55;
    flex: 1;
  }

  .research-receipts__src {
    margin: 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  .research-receipts__src-link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .research-receipts__src-link:hover {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .research-receipts__applied {
    margin: 0;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .research-receipts__applied-loc {
    color: var(--fg-dim);
    text-transform: none;
    letter-spacing: 0;
  }

  .research-receipts__more {
    margin: 0;
    font-family: var(--mono);
    font-size: 14px;
  }

  .research-receipts__more-link {
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 2px;
  }

  .research-receipts__more-link:hover {
    color: var(--accent);
  }
</style>
