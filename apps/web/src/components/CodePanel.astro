---
import { snippets } from "../data/snippets";
import { highlight } from "../lib/highlight";
import CodeBlock from "./CodeBlock.astro";
import Tabs from "./Tabs.astro";

// Tabbed code-example panel (DESIGN §3.1). Three install methods,
// content sourced from `data/snippets`, highlighted at build time.
// Each copy click bubbles `nlqdb:snippet-copied`; we relay to the
// DESIGN-spec'd `home.snippet_copied` for the analytics funnel.

const tabs = snippets.map(({ id, label, sub }) => ({ id, label, sub }));

// SK-EVENTS-011: wishlist clicks fan out to `POST /v1/events/wishlist`
// so the click becomes a typed `home.surface_wishlist` event in the
// LogSnag demand-signal channel. The base lives in PUBLIC_API_BASE
// just like every other apps/web → apps/api call.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";

const rendered = Object.fromEntries(
  snippets.map((s) => [
    s.id,
    {
      lang: s.lang,
      label: s.label,
      domId: `src-${s.id}`,
      highlightedHtml: highlight(s.lang, s.source),
    },
  ]),
);

// Static slot names below — Astro forbids dynamic `slot={…}` in
// JSX, so we list one Fragment per tab id. The data still drives
// the content (lang, label, highlighted markup) via `rendered`.
---

<section class="codepanel" aria-labelledby="codepanel-title" data-api-base={apiBase}>
  <header class="codepanel__head">
    <h2 class="codepanel__title" id="codepanel-title">
      Three ways in. Same backend &mdash; the one that doesn&rsquo;t exist.
    </h2>
    <p class="codepanel__lede">
      Each snippet is the entire integration. No boilerplate omitted, no
      &ldquo;configure your client&rdquo; step elided. The contrast is
      the message.
    </p>
  </header>

  <Tabs tabs={tabs} ariaLabel="Install methods">
    <Fragment slot="cli">
      <CodeBlock
        id={rendered.cli.domId}
        lang={rendered.cli.lang}
        highlightedHtml={rendered.cli.highlightedHtml}
        copyLabel={`Copy ${rendered.cli.label} snippet`}
      />
    </Fragment>
    <Fragment slot="html">
      <CodeBlock
        id={rendered.html.domId}
        lang={rendered.html.lang}
        highlightedHtml={rendered.html.highlightedHtml}
        copyLabel={`Copy ${rendered.html.label} snippet`}
      />
    </Fragment>
    <Fragment slot="sdk">
      <CodeBlock
        id={rendered.sdk.domId}
        lang={rendered.sdk.lang}
        highlightedHtml={rendered.sdk.highlightedHtml}
        copyLabel={`Copy ${rendered.sdk.label} snippet`}
      />
    </Fragment>
  </Tabs>

  <div class="codepanel__matrix">
    {/*
      Surface status matrix — mirror of `docs/progress.md §0`.
      `progress.md` is the source of truth; this table is the homepage
      reflection. When a surface flips status, edit progress.md FIRST
      and update this block to match in the same PR.
    */}
    <p class="codepanel__matrix-row">
      <span class="codepanel__matrix-label">Shipped</span>
      <span class="badge badge--shipped">&lt;nlq-data&gt;</span>
      <span class="badge badge--shipped">&lt;nlq-action&gt;</span>
      <span class="badge badge--shipped">TS SDK</span>
      <span class="badge badge--shipped">anon /v1/ask</span>
      <span class="badge badge--shipped">React / Next</span>
      <span class="badge badge--shipped">Vue / Nuxt</span>
      <span class="badge badge--shipped">Svelte / Kit</span>
      <span class="badge badge--shipped">Astro</span>
      <span class="badge badge--shipped">Solid</span>
      <span class="badge badge--shipped">Swift</span>
    </p>
    <p class="codepanel__matrix-row">
      <span class="codepanel__matrix-label">Phase 1</span>
      <span class="badge">chat surface</span>
      <span class="badge">db.create</span>
      <span class="badge">curl recipes</span>
    </p>
    <p class="codepanel__matrix-row">
      <span class="codepanel__matrix-label">Phase 2</span>
      <span class="badge">CLI</span>
      <span class="badge">MCP server</span>
      <span class="badge">Python SDK</span>
      <span class="badge">Go SDK</span>
      <span class="badge">BYOLLM</span>
    </p>
    {/*
      Wishlist surfaces (SK-EVENTS-011). The `data-wishlist` values
      below MUST match the `WishlistSurface` union in
      `packages/events/src/types.ts` and the `WISHLIST_SURFACES` set in
      `apps/api/src/events-feature.ts`. Adding a badge is a three-place
      edit; the API rejects unknown surfaces with 400 `invalid_surface`
      so a missed edit fails loud.
    */}
    <p class="codepanel__matrix-row">
      <span class="codepanel__matrix-label">Wishlist</span>
      <a class="badge badge--wishlist" data-wishlist="vscode" href="mailto:hello@nlqdb.com?subject=Surface%20wishlist%3A%20VSCode%20extension">VSCode</a>
      <a class="badge badge--wishlist" data-wishlist="jetbrains" href="mailto:hello@nlqdb.com?subject=Surface%20wishlist%3A%20JetBrains%20plugin">JetBrains</a>
      <a class="badge badge--wishlist" data-wishlist="slack" href="mailto:hello@nlqdb.com?subject=Surface%20wishlist%3A%20Slack%20bot">Slack</a>
      <a class="badge badge--wishlist" data-wishlist="discord" href="mailto:hello@nlqdb.com?subject=Surface%20wishlist%3A%20Discord%20bot">Discord</a>
    </p>
    <p class="codepanel__matrix-note">
      Each one is a thin wrapper over the same element &mdash; full matrix in
      <a href="https://github.com/nlqdb/nlqdb/blob/main/docs/progress.md#0-surface-status-matrix--single-source-of-truth">progress.md</a>.
      Tap a wishlist surface to nudge it up the list.
    </p>
  </div>
</section>

<script>
  // Relay the generic `nlqdb:snippet-copied` event up to the
  // DESIGN §3.1 analytics name. `surface` is the snippet id (cli /
  // html / sdk) — leading indicator for which framework wrapper to
  // ship next.
  for (const root of document.querySelectorAll<HTMLElement>(".codepanel")) {
    root.addEventListener("nlqdb:snippet-copied", (e) => {
      const detail = (e as CustomEvent<{ id: string | null }>).detail;
      const surface = detail?.id?.replace(/^src-/, "") ?? "unknown";
      document.dispatchEvent(
        new CustomEvent("home.snippet_copied", { detail: { surface } }),
      );
    });
  }

  // Wishlist nudge (SK-EVENTS-011). Each click does two things, in this
  // order — keep both: the local CustomEvent is the legacy listener
  // surface that other analytics might attach to; the fire-and-forget
  // fetch is the typed-event capture pipe the §6 monetization trigger
  // reads off. The default mailto: action runs as well so the user
  // also has the direct channel to us.
  const codepanelRoot = document.querySelector<HTMLElement>(".codepanel");
  const wishlistApiBase = codepanelRoot?.dataset.apiBase ?? "";
  for (const el of document.querySelectorAll<HTMLAnchorElement>("[data-wishlist]")) {
    el.addEventListener("click", () => {
      const surface = el.dataset.wishlist ?? "unknown";
      document.dispatchEvent(
        new CustomEvent("home.surface_wishlist", { detail: { surface } }),
      );
      // sendBeacon would be ideal here (survives the page navigation
      // the mailto: link triggers in some browsers), but it can't set
      // a content-type header — the API parses JSON only. Fall back to
      // fetch with `keepalive: true` so the request still rides the
      // navigation; failures are silent (CTA emit must never surface
      // as an error).
      try {
        const base = wishlistApiBase.replace(/\/$/, "");
        if (base) {
          void fetch(`${base}/v1/events/wishlist`, {
            method: "POST",
            headers: { "content-type": "application/json" },
            credentials: "omit",
            keepalive: true,
            body: JSON.stringify({ surface }),
          });
        }
      } catch {
        // Best-effort. The mailto: is the durable user-to-us channel.
      }
    });
  }
</script>

<style is:global>
  .codepanel {
    padding: clamp(48px, 8vw, 96px) 0 clamp(32px, 5vw, 56px);
    border-top: 1px solid var(--border);
  }

  .codepanel__head {
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  .codepanel__title {
    font-family: var(--mono);
    font-size: clamp(24px, 3.6vw, 36px);
    letter-spacing: -0.02em;
    max-width: 22ch;
  }

  .codepanel__lede {
    margin: 12px 0 0;
    color: var(--fg-dim);
    max-width: 60ch;
    font-size: clamp(15px, 1.6vw, 16px);
  }

  .codepanel__matrix {
    margin: clamp(20px, 3vw, 28px) 0 0;
    display: grid;
    gap: 10px;
  }

  .codepanel__matrix-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-dim);
  }

  .codepanel__matrix-label {
    min-width: 72px;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-dim);
    text-decoration: none;
  }

  .badge--shipped {
    border-color: var(--accent);
    color: var(--accent);
  }

  .badge--wishlist {
    border-style: dashed;
    cursor: pointer;
  }

  .badge--wishlist:hover,
  .badge--wishlist:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }

  .codepanel__matrix-note {
    margin: 8px 0 0;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .codepanel__matrix-note a {
    color: var(--fg-dim);
    text-decoration: underline;
  }
</style>
