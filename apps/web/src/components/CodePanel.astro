---
// Tabbed code-example panel (DESIGN §3.1). Three install methods —
// CLI, HTML element, typed SDK — each ≤10 lines. Switching tabs is
// vanilla JS, no framework. Copy buttons emit `home.snippet_copied`
// to the page (analytics wires up later).

const tabs = [
  {
    id: "cli",
    label: "CLI",
    sub: "one binary, three verbs",
    lang: "bash",
  },
  {
    id: "html",
    label: "HTML",
    sub: "drop a tag, ship the page",
    lang: "html",
  },
  {
    id: "sdk",
    label: "SDK",
    sub: "fetch is the SDK",
    lang: "ts",
  },
] as const;
---

<section class="codepanel" aria-labelledby="codepanel-title">
  <header class="codepanel__head">
    <h2 class="codepanel__title" id="codepanel-title">
      Three ways in. Same backend &mdash; the one that doesn&rsquo;t exist.
    </h2>
    <p class="codepanel__lede">
      Each snippet is the entire integration. No boilerplate omitted, no
      &ldquo;configure your client&rdquo; step elided. The contrast is the
      message.
    </p>
  </header>

  <div class="tabs" data-tabs>
    <div class="tabs__list" role="tablist" aria-label="Install methods">
      {tabs.map((t, i) => (
        <button
          type="button"
          role="tab"
          id={`tab-${t.id}`}
          class="tabs__tab"
          data-tab-target={t.id}
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`panel-${t.id}`}
          tabindex={i === 0 ? 0 : -1}
        >
          <span class="tabs__label">{t.label}</span>
          <span class="tabs__sub">{t.sub}</span>
        </button>
      ))}
    </div>

    <div
      class="tabs__panel"
      role="tabpanel"
      id="panel-cli"
      aria-labelledby="tab-cli"
      data-tab-panel="cli"
    >
      <div class="codeblock">
        <div class="codeblock__chrome">
          <span class="codeblock__lang">bash</span>
          <button
            type="button"
            class="codeblock__copy"
            data-copy-source="src-cli"
            aria-label="Copy CLI snippet"
          >
            <span class="codeblock__copy-text">Copy</span>
          </button>
        </div>
        <pre class="codeblock__pre"><code id="src-cli"><span class="tk-c"># 1. install (curl, brew, npm — pick one)</span>
<span class="tk-fn">curl</span> -fsSL <span class="tk-s">https://nlqdb.com/install</span> | sh

<span class="tk-c"># 2. create from a goal — the DB is a side effect</span>
<span class="tk-fn">nlq</span> new <span class="tk-s">"an orders tracker for my coffee shop"</span>

<span class="tk-c"># 3. talk to it</span>
<span class="tk-fn">nlq</span> <span class="tk-s">"add an order: alice, latte, $5.50, just now"</span>
<span class="tk-fn">nlq</span> <span class="tk-s">"how many orders today, by drink"</span></code></pre>
      </div>
    </div>

    <div
      class="tabs__panel"
      role="tabpanel"
      id="panel-html"
      aria-labelledby="tab-html"
      data-tab-panel="html"
      hidden
    >
      <div class="codeblock">
        <div class="codeblock__chrome">
          <span class="codeblock__lang">html</span>
          <button
            type="button"
            class="codeblock__copy"
            data-copy-source="src-html"
            aria-label="Copy HTML snippet"
          >
            <span class="codeblock__copy-text">Copy</span>
          </button>
        </div>
        <pre class="codeblock__pre"><code id="src-html"><span class="tk-c">&lt;!-- one CDN script registers the elements --&gt;</span>
<span class="tk-pn">&lt;</span><span class="tk-t">script</span> <span class="tk-a">src</span>=<span class="tk-s">"https://elements.nlqdb.com/v1.js"</span> <span class="tk-a">type</span>=<span class="tk-s">"module"</span><span class="tk-pn">&gt;&lt;/</span><span class="tk-t">script</span><span class="tk-pn">&gt;</span>

<span class="tk-c">&lt;!-- describe what you want; the DB is created on first call --&gt;</span>
<span class="tk-pn">&lt;</span><span class="tk-t">nlq-data</span>
  <span class="tk-a">goal</span>=<span class="tk-s">"today's orders, newest first, with customer + total"</span>
  <span class="tk-a">api-key</span>=<span class="tk-s">"pk_live_..."</span>
  <span class="tk-a">template</span>=<span class="tk-s">"table"</span>
  <span class="tk-a">refresh</span>=<span class="tk-s">"5s"</span>
<span class="tk-pn">&gt;&lt;/</span><span class="tk-t">nlq-data</span><span class="tk-pn">&gt;</span></code></pre>
      </div>
    </div>

    <div
      class="tabs__panel"
      role="tabpanel"
      id="panel-sdk"
      aria-labelledby="tab-sdk"
      data-tab-panel="sdk"
      hidden
    >
      <div class="codeblock">
        <div class="codeblock__chrome">
          <span class="codeblock__lang">typescript</span>
          <button
            type="button"
            class="codeblock__copy"
            data-copy-source="src-sdk"
            aria-label="Copy SDK snippet"
          >
            <span class="codeblock__copy-text">Copy</span>
          </button>
        </div>
        <pre class="codeblock__pre"><code id="src-sdk"><span class="tk-k">import</span> {`{ `}<span class="tk-fn">nlq</span>{` }`} <span class="tk-k">from</span> <span class="tk-s">"@nlqdb/sdk"</span>;

<span class="tk-k">const</span> client = <span class="tk-fn">nlq</span>({`{`} apiKey: process.env.<span class="tk-v">NLQDB_KEY</span>! {`}`});

<span class="tk-c">// no schema, no SQL, no ORM. one verb.</span>
<span class="tk-k">const</span> {`{`} data, trace {`}`} = <span class="tk-k">await</span> client.<span class="tk-fn">ask</span>(
  <span class="tk-s">"today's orders, newest first"</span>,
);

<span class="tk-v">console</span>.<span class="tk-fn">table</span>(data);</code></pre>
      </div>
    </div>
  </div>

  <p class="codepanel__matrix">
    Coming next:
    <span class="badge">React</span>
    <span class="badge">Vue / Nuxt</span>
    <span class="badge">MCP (agent)</span>
    <span class="badge">curl</span>
    <span class="codepanel__matrix-note">— each one is a thin wrapper over the same element, ≤200 LOC.</span>
  </p>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-tabs]");
    if (!root) return;
    const tabs = Array.from(root.querySelectorAll("[role=tab]"));
    const panels = Array.from(root.querySelectorAll("[data-tab-panel]"));

    const select = (target) => {
      tabs.forEach((t) => {
        const on = t.getAttribute("data-tab-target") === target;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.setAttribute("tabindex", on ? "0" : "-1");
        if (on) t.focus({ preventScroll: true });
      });
      panels.forEach((p) => {
        const on = p.getAttribute("data-tab-panel") === target;
        if (on) p.removeAttribute("hidden");
        else p.setAttribute("hidden", "");
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        select(tab.getAttribute("data-tab-target"));
      });
      tab.addEventListener("keydown", (e) => {
        const i = tabs.indexOf(tab);
        if (e.key === "ArrowRight") {
          e.preventDefault();
          select(tabs[(i + 1) % tabs.length].getAttribute("data-tab-target"));
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          select(
            tabs[(i - 1 + tabs.length) % tabs.length].getAttribute(
              "data-tab-target",
            ),
          );
        } else if (e.key === "Home") {
          e.preventDefault();
          select(tabs[0].getAttribute("data-tab-target"));
        } else if (e.key === "End") {
          e.preventDefault();
          select(tabs[tabs.length - 1].getAttribute("data-tab-target"));
        }
      });
    });

    document.querySelectorAll("[data-copy-source]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-copy-source");
        const src = id ? document.getElementById(id) : null;
        if (!src) return;
        const text = src.innerText;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // browser refused clipboard access — user can select manually
          return;
        }
        const label = btn.querySelector(".codeblock__copy-text");
        if (label) {
          const prev = label.textContent;
          label.textContent = "Copied";
          btn.setAttribute("data-copied", "");
          setTimeout(() => {
            label.textContent = prev;
            btn.removeAttribute("data-copied");
          }, 1400);
        }
      });
    });
  })();
</script>
