---
// Marketing hero — the goal-first input that morphs into a real-LLM
// chat (SK-WEB-002 / SK-WEB-008). Backed by the same `<CreateForm>`
// React island as `/app/new`; both routes hit `/v1/ask` with an
// anonymous bearer (SK-ANON-008), gated by the global anon cap
// (SK-ANON-010) and the prompt-persistence guarantee (SK-ANON-011).
//
// `Hero.tsx` is intentionally retired — its old fixture client used
// `/v1/demo/ask`, which no longer exists. The component is replaced
// in-place by the marketing-chrome wordmark + lede + sub above the
// shared form below.

import CreateForm from "./CreateForm.tsx";

// Default to "" (same-origin) — `apps/web` is bundled into the
// `nlqdb-api` Worker's [assets] binding (SK-AUTH-016), so `app.nlqdb.com`
// and the per-PR preview URL (`<hash>-nlqdb-api.<account>.workers.dev`)
// both serve the page and `/v1/ask` from the same origin. Hardcoding
// `https://app.nlqdb.com` previously broke the preview hero with a
// CORS preflight rejection (the preview origin isn't in the API's
// allowlist). When the standalone marketing worker (`nlqdb-web`,
// future `nlqdb.com`) goes live, set `PUBLIC_API_BASE=https://app.nlqdb.com`
// for that build target.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<section class="hero">
  <h1 class="hero__wordmark">nlqdb</h1>
  <p class="hero__lede">Natural-language databases.</p>
  <p class="hero__sub">
    Create one in a word. Talk to it in English. The schema, the engine,
    the indexes, the backups — all invisible. The escape hatch to raw
    SQL stays one click away, always.
  </p>

  {/* Form gated behind Cmd+G; the marketing chrome above renders
      unconditionally. The shared Cmd+G keydown handler in
      `apps/web/src/components/Topnav.astro` toggles every
      `[data-cmdg-gate]` element in lockstep. */}
  <div id="hero-gate" data-cmdg-gate hidden>
    <CreateForm client:load apiBase={apiBase} />
  </div>
</section>
