---
// Marketing hero — the goal-first input that morphs into a real-LLM
// chat (SK-WEB-002 / SK-WEB-008). Two text layers + the form: a
// display-serif lede that leads with the agent-memory wedge (WS-13 /
// SK-PIVOT-013, the founder-gated 2026-06-24 reposition), one
// sans-serif explainer line, then the same `<CreateForm>` React
// island as `/app/new`. The form posts to `/v1/ask` with an
// anonymous bearer (SK-ANON-008), gated by the global anon cap
// (SK-ANON-010) with prompt-persistence (SK-ANON-011).
//
// Wordmark moved to the topnav (redesign-plan §3, §5/`/`): the
// hero's lime moment is the form's submit CTA — nothing above it
// competes. Credo line ("Also a natural-language database for any
// app…") removed: the demo block below this hero shows that idea
// rather than apologising for the headline in text.

import CreateForm from "./CreateForm.tsx";

// Default to "" (same-origin) — `apps/web` is bundled into the
// `nlqdb-api` Worker's [assets] binding (SK-AUTH-016), so `app.nlqdb.com`
// and the per-PR preview URL (`<hash>-nlqdb-api.<account>.workers.dev`)
// both serve the page and `/v1/ask` from the same origin. Hardcoding
// `https://app.nlqdb.com` previously broke the preview hero with a
// CORS preflight rejection (the preview origin isn't in the API's
// allowlist). When the standalone marketing worker (`nlqdb-web`,
// future `nlqdb.com`) goes live, set `PUBLIC_API_BASE=https://app.nlqdb.com`
// for that build target.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<section class="hero">
  <h1 class="hero__lede">Analytical memory for AI agents.</h1>
  <p class="hero__say">
    Connect a database your agent can write to and query in English.
  </p>

  <CreateForm client:load apiBase={apiBase} />
</section>
