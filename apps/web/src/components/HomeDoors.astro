---
// SK-WEB-018 — Two-door home. Replaces the SK-WEB-015/017 three-beat
// scroll on `/` with a clean chooser: one headline + sub-line, then two
// side-by-side doors (stacked on narrow). The literal expression of
// GLOBAL-036's dual front door.
//
// Door A — "Use as agent memory": the SK-WEB-016 `<McpInstall>` host row
// (click → reveal-fallback-in-place) + a quiet `/app/new` link that
// preserves GLOBAL-007's no-login-wall first value.
//
// Door B — "Question your ClickHouse": one primary `.cta` →
// `/auth/sign-in?return_to=/app/connect` (sign-in then the BYO-connect
// page, SK-WEB-019).
//
// Brutalism budget (SK-WEB-015): one promoted lime moment per door —
// Door A's lime lives inside `<McpInstall>` (its promoted host button);
// Door B's is the single `.cta`. Tokens only, no new tokens.

import McpInstall from "./McpInstall.astro";
---
<section class="doors" aria-labelledby="doors-h1">
  <header class="doors__head">
    <h1 class="doors__h1" id="doors-h1">Analytical memory for AI agents.</h1>
    <p class="doors__say">
      A real database your agent writes to and you query in English — or connect the ClickHouse
      you already have. Pick a door.
    </p>
  </header>

  <div class="doors__grid">
    {/* Door A — agent memory. McpInstall owns the lime moment. */}
    <article class="door" aria-labelledby="door-a-title">
      <p class="door__eyebrow">Door A</p>
      <h2 class="door__title" id="door-a-title">Use as agent memory</h2>
      <p class="door__lede">
        Give your agent a real Postgres database as memory — typed rows it writes as it learns,
        queried in English. Install it in your host over MCP.
      </p>

      <McpInstall compact={false} />

      <p class="door__quiet">
        Not building an agent?
        <a class="door__quiet-link" href="/app/new">or just describe your data &rarr;</a>
      </p>
    </article>

    {/* Door B — connect your ClickHouse. One primary CTA. */}
    <article class="door" aria-labelledby="door-b-title">
      <p class="door__eyebrow">Door B</p>
      <h2 class="door__title" id="door-b-title">Question your ClickHouse</h2>
      <p class="door__lede">
        Point nlqdb at the warehouse you already run — ClickHouse or Postgres. It reads your
        schema; you ask in English. Your connection string is sealed server-side, never stored
        in your browser.
      </p>

      <div class="door__cta-row">
        <a class="cta door__cta" href="/auth/sign-in?return_to=/app/connect">
          Connect your ClickHouse &rarr;
        </a>
      </div>
      <p class="door__quiet">Sign in (always free) — then paste a read connection string.</p>
    </article>
  </div>
</section>

<style>
  /* Two-door chooser. Side-by-side from 900px; single column below.
   * `var(--bleed)` so the two cards have room to breathe on wide
   * screens. Tokens only (SK-WEB-015). */
  .doors {
    padding: clamp(48px, 9vw, 96px) 0 clamp(40px, 6vw, 64px);
    max-width: var(--bleed);
  }

  .doors__head {
    max-width: var(--col);
    margin: 0 0 clamp(32px, 5vw, 56px);
  }

  .doors__h1 {
    margin: 0 0 clamp(12px, 2vw, 18px);
    font-family: var(--display);
    font-size: var(--t-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
    text-wrap: balance;
    max-width: 16ch;
  }

  .doors__say {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.45;
    max-width: 54ch;
    text-wrap: balance;
  }

  .doors__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .doors__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .door {
    margin: 0;
    padding: clamp(24px, 3.5vw, 36px);
    background: var(--raised);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 2vw, 18px);
  }

  .door__eyebrow {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .door__title {
    margin: 0;
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
    text-wrap: balance;
  }

  .door__lede {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.55;
    max-width: 48ch;
  }

  /* Push the quiet demotion / sub-line to the card foot so the two doors
   * stay visually balanced even when their bodies differ in height. */
  .door__quiet {
    margin: auto 0 0;
    padding-top: clamp(8px, 1.5vw, 12px);
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.6;
  }

  .door__quiet-link {
    color: var(--body);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .door__quiet-link:hover,
  .door__quiet-link:focus-visible {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .door__cta-row {
    display: flex;
  }

  .door__cta {
    /* The door's one promoted lime moment. */
    width: 100%;
    justify-content: center;
  }

  @media (min-width: 560px) {
    .door__cta {
      width: auto;
    }
  }
</style>
