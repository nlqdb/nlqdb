---
// Waitlist signup. Replaces the /sign-in CTA while the chat surface
// is tabled. POSTs to /v1/waitlist same-origin (apps/web is bundled
// into the nlqdb-api Worker's [assets] binding per SK-AUTH-016).
//
// Returns the same UX whether the email is new or already on the
// list — Better Auth-style "confirmed received" without leaking
// list membership.

// Same-origin default — see Hero.astro for the SK-AUTH-016 rationale.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<section id="waitlist" class="waitlist" aria-labelledby="waitlist-title">
  <h2 id="waitlist-title" class="waitlist__title">Join the waitlist</h2>
  <p class="waitlist__lede">
    Pre-alpha — we'll email when nlqdb opens up. No marketing fluff, just
    one note when there's a button to push.
  </p>

  <form id="waitlist-form" class="waitlist__form" data-api-base={apiBase}>
    <label class="visually-hidden" for="waitlist-email">Email address</label>
    <input
      id="waitlist-email"
      name="email"
      type="email"
      autocomplete="email"
      required
      placeholder="you@example.com"
      class="waitlist__field"
    />
    <label class="visually-hidden" for="waitlist-persona">
      Which best describes you? (optional)
    </label>
    <select
      id="waitlist-persona"
      name="persona"
      class="waitlist__field"
    >
      <option value="">Which best describes you? (optional)</option>
      <option value="solo-builder">Solo builder / founder</option>
      <option value="agent-builder">Building LLM agents or assistants</option>
      <option value="data-analyst">Analyst / PM / ops (data-curious)</option>
      <option value="backend-engineer">Backend engineer at a small startup</option>
      <option value="student">Student / learning to code</option>
      <option value="analytics-engineer">Analytics / observability engineer</option>
      <option value="other">Other</option>
    </select>
    <button type="submit" id="waitlist-submit" class="btn btn--accent waitlist__submit">
      Join the waitlist
    </button>
    <p id="waitlist-error" class="waitlist__error" hidden role="alert"></p>
  </form>

  <div id="waitlist-done" class="waitlist__done" hidden>
    <p class="waitlist__done-body">
      You're on the list. We'll send one note when there's something to try.
    </p>
  </div>
</section>

<script>
  import { isValidEmail } from "../lib/email";

  const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
  if (form) {
    const apiBase = (form.dataset["apiBase"] ?? "").replace(/\/$/, "");
    const emailInput = document.getElementById("waitlist-email") as HTMLInputElement;
    const personaInput = document.getElementById("waitlist-persona") as HTMLSelectElement;
    const submitBtn = document.getElementById("waitlist-submit") as HTMLButtonElement;
    const errorEl = document.getElementById("waitlist-error") as HTMLParagraphElement;
    const doneEl = document.getElementById("waitlist-done") as HTMLDivElement;

    // Show an error in the role="alert" region and tie it to the field so
    // assistive tech announces it and keyboard users land on the problem
    // input (mirrors CreateForm's run-82 aria-invalid/-describedby pattern).
    const showError = (msg: string) => {
      errorEl.textContent = msg;
      errorEl.hidden = false;
      emailInput.setAttribute("aria-invalid", "true");
      emailInput.setAttribute("aria-describedby", "waitlist-error");
      emailInput.focus();
    };
    const clearError = () => {
      errorEl.hidden = true;
      emailInput.removeAttribute("aria-invalid");
      emailInput.removeAttribute("aria-describedby");
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      clearError();
      if (!isValidEmail(email)) {
        showError("That doesn't look like a valid email.");
        return;
      }
      submitBtn.disabled = true;
      const idle = submitBtn.textContent ?? "Join the waitlist";
      submitBtn.textContent = "Submitting…";
      try {
        const persona = personaInput?.value || null;
        const res = await fetch(`${apiBase}/v1/waitlist`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email, persona }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        form.hidden = true;
        doneEl.hidden = false;
      } catch {
        // Show a single, generic message — never echo the network
        // error verbatim (could leak proxy/CDN internals on misconfig).
        showError("Couldn't add you. Try again in a moment.");
        submitBtn.disabled = false;
        submitBtn.textContent = idle;
      }
    });
  }
</script>

<style>
  .waitlist {
    max-width: 520px;
    margin: 32px auto 24px;
    padding: 24px;
    border: 3px solid var(--border-strong);
    background: var(--bg-elev);
    box-shadow: var(--shadow-hard);
  }
  .waitlist__title {
    font-size: clamp(22px, 3vw, 28px);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .waitlist__lede {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-dim);
    margin: 0 0 16px;
  }
  .waitlist__form {
    display: grid;
    gap: 10px;
  }
  .waitlist__field {
    width: 100%;
    padding: 12px 14px;
    font-family: var(--mono);
    font-size: 15px;
    color: var(--fg);
    background: var(--bg);
    border: 2px solid var(--border-strong);
    outline: none;
  }
  .waitlist__field:focus {
    border-color: var(--accent);
  }
  .waitlist__submit {
    justify-content: center;
  }
  .waitlist__error {
    margin: 4px 0 0;
    padding: 8px 10px;
    font-family: var(--mono);
    font-size: 13px;
    color: #ff8a8a;
    background: #2a1212;
    border: 2px solid #ff8a8a;
  }
  .waitlist__done {
    padding: 16px;
    border: 3px solid var(--accent);
    background: var(--bg);
  }
  .waitlist__done-body {
    margin: 0;
    font-family: var(--mono);
    font-size: 14px;
    color: var(--fg);
  }
</style>
