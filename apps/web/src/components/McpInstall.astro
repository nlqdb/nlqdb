---
// SK-WEB-016 — One-click MCP install affordance.
//
// One component, three venues: `/agents` final connect card, the
// post-create CreateResultView, and `/integrations` MCP-hosts section.
// Four hosts: Claude, Cursor, Windsurf, Zed. Where the host ships a
// documented deep-link install scheme, the button is an `<a>` whose
// `href` is the resolved URI (the OS hands the click to the host's
// URI handler); where no scheme exists, the button copies the host's
// JSON config block and points the user at the one place to paste it.
//
// Research outputs (canonical) live in `lib/mcp-install.ts` — see its header
// for the per-host deep-link / command syntax and the source URLs. Hosts:
// Cursor + VS Code (deep-link), Claude Code + Codex (command), Claude +
// Windsurf + Zed (fallback-only config).
//
// Founder request: clicking ANY host button ALSO reveals that host's manual
// fallback instructions in place (an inline panel under the row), on top of
// its primary action (deep-link nav / copy). One reveal region per component;
// the clicked host's panel opens, others collapse.
//
// Per `SK-WEB-010` / `SK-ANON-012`: any anon-side caller passes the
// `pk_live_REPLACE_ME` placeholder (the marketing surface burned its
// 1-call cap on create). When a real key arrives post-sign-in, the
// `apiKey` prop carries it and the "sign in to inline" hint is hidden.
// Lime is reserved to one promoted button per row (the `<Cta>` ladder
// in `SK-WEB-015`); we promote "Add to Claude" by default since Claude
// is the first-party hosted MCP target.
//
// The host descriptors (deep-link URIs, fallback config blocks,
// promoted host, endpoint URL) live in `lib/mcp-install.ts` — the one
// source of truth shared with the React post-create venue. This
// component only renders them; it does NOT rebuild them, so the two
// venues can never drift (the original `/mcp`-vs-root bug was exactly
// such a drift).

import {
  buildMcpHosts,
  MCP_ENDPOINT_URL,
  type McpHostEntry,
  PLACEHOLDER_KEY,
  PROMOTED_HOST,
} from "../lib/mcp-install.ts";

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

// The manual-fallback panel revealed in place on any host click. Hidden by
// default (`hidden` attribute); the inline script toggles it. Shows the one
// manual step (the host's pasteHint) plus the command / config text so the
// user can copy it by hand if the deep-link / clipboard path failed.
function renderPanel(host: McpHostEntry, panelId: string): string {
  const text = host.command ?? host.config ?? "";
  const step =
    host.status === "deep-link"
      ? `If ${escapeHtml(host.name)} didn't open, paste this config manually:`
      : host.pasteHint
        ? escapeHtml(host.pasteHint)
        : `Use this in ${escapeHtml(host.name)}:`;
  return `<div class="mcpinstall__panel" id="${panelId}" role="region" aria-label="${escapeHtml(host.name)} manual install" hidden><p class="mcpinstall__panel-step">${step}</p><pre class="mcpinstall__panel-code"><code>${escapeHtml(text)}</code></pre></div>`;
}

interface Props {
  /** The per-DB `pk_live_…` key, or `"pk_live_REPLACE_ME"` for anon. */
  apiKey?: string;
  /** Hosted MCP endpoint. Override only for staging/preview environments. */
  mcpUrl?: string;
  /**
   * `true` packs the buttons into one row with terse labels (post-create);
   * `false` stacks them with descriptive secondary labels (/integrations).
   */
  compact?: boolean;
}

const { apiKey = PLACEHOLDER_KEY, mcpUrl = MCP_ENDPOINT_URL, compact = false } = Astro.props;

const isPlaceholder = apiKey === PLACEHOLDER_KEY;
const HOSTS = buildMcpHosts(mcpUrl);

const rowClass = compact ? "mcpinstall__row mcpinstall__row--compact" : "mcpinstall__row";
---

<section class="mcpinstall" aria-labelledby="mcpinstall-eyebrow">
  <p class="mcpinstall__eyebrow" id="mcpinstall-eyebrow">Install in your agent.</p>

  <ul class={rowClass} role="list">
    {HOSTS.map((host) => {
      const promoted = host.id === PROMOTED_HOST;
      const ctaClass = promoted ? "cta mcpinstall__btn" : "cta cta--ghost mcpinstall__btn";
      const panelId = `mcpinstall-panel-${host.id}`;
      // The text the manual-fallback panel shows + the copy buttons grab.
      // Command hosts copy the command (or the config block, e.g. Codex's
      // TOML); deep-link + fallback hosts copy/show the config block.
      const copyText = host.command ?? host.config ?? "";
      if (host.status === "deep-link" && host.href) {
        return (
          <li class="mcpinstall__cell">
            <a
              class={ctaClass}
              href={host.href}
              data-mcp-host={host.id}
              data-mcp-mode="deeplink"
              data-mcp-panel={panelId}
              aria-expanded="false"
              aria-controls={panelId}
              target="_self"
              title={host.versionHint}
            >
              Add to {host.name}
            </a>
            {!compact && (
              <p class="mcpinstall__sub">
                Opens {host.name} and asks you to confirm before writing the config.
              </p>
            )}
            <Fragment set:html={renderPanel(host, panelId)} />
          </li>
        );
      }
      // command + fallback-only — both copy text and reveal the panel.
      const label = host.command ? `Copy ${host.name} command` : `Copy ${host.name} config`;
      return (
        <li class="mcpinstall__cell">
          <button
            type="button"
            class={ctaClass}
            data-mcp-host={host.id}
            data-mcp-mode="copy"
            data-mcp-config={copyText}
            data-mcp-panel={panelId}
            aria-expanded="false"
            aria-controls={panelId}
            title={host.versionHint}
          >
            <span data-mcp-label>{label}</span>
          </button>
          {!compact && host.pasteHint && (
            <p class="mcpinstall__sub">{host.pasteHint}</p>
          )}
          <Fragment set:html={renderPanel(host, panelId)} />
        </li>
      );
    })}
  </ul>

  {/* Compact mode lists the paste hints once below the row to avoid
      duplicating the row's vertical rhythm. */}
  {compact && (
    <ul class="mcpinstall__hints" aria-label="Where to paste the config">
      {HOSTS.filter((h) => h.status !== "deep-link" && h.pasteHint).map((host) => (
        <li class="mcpinstall__hint">
          <span class="mcpinstall__hint-host">{host.name}:</span> {host.pasteHint}
        </li>
      ))}
    </ul>
  )}

  {isPlaceholder && (
    <p class="mcpinstall__placeholder">
      Anonymous — the configs ship with the
      <code>pk_live_REPLACE_ME</code> placeholder.
      <a href="/auth/sign-in?return_to=/app" class="mcpinstall__signin">
        Sign in (free) to inline your live key →
      </a>
    </p>
  )}
</section>

<script>
  // One inline handler for every host button on the page. Each button
  // carries `data-mcp-host` (demand-signal label), `data-mcp-panel` (the
  // id of its manual-fallback panel), and — for copy buttons —
  // `data-mcp-config` (the command/config to copy). Founder request:
  // EVERY click reveals the clicked host's manual instructions in place,
  // on top of its primary action (deep-link nav / copy). Clipboard
  // failure is swallowed silently (the panel still shows the text). We
  // gate the success animation on reduced-motion (one motion moment,
  // SK-WEB-015).
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const COPY_RESET_MS = 1600;

  function emitSignal(host: string) {
    void (async () => {
      try {
        const { emit } = await import("../lib/logsnag");
        emit("home.snippet_copied", { surface: `mcp_install_${host}` });
      } catch {
        /* logsnag stub absent — no-op */
      }
    })();
  }

  // Reveal the clicked host's panel in place; collapse every other panel
  // so only one set of manual instructions is open at a time (keeps the
  // one-motion-moment budget honest). The trigger's aria-expanded tracks
  // its own panel's state.
  const triggers = Array.from(
    document.querySelectorAll<HTMLElement>("[data-mcp-panel]"),
  );
  function revealPanel(trigger: HTMLElement) {
    const targetId = trigger.dataset["mcpPanel"];
    if (!targetId) return;
    for (const t of triggers) {
      const id = t.dataset["mcpPanel"];
      const panel = id ? document.getElementById(id) : null;
      const open = id === targetId;
      if (panel) panel.hidden = !open;
      t.setAttribute("aria-expanded", open ? "true" : "false");
    }
  }

  // Copy buttons (command + fallback-only hosts).
  document.querySelectorAll<HTMLButtonElement>('[data-mcp-mode="copy"]').forEach((btn) => {
    btn.addEventListener("click", async () => {
      const config = btn.dataset["mcpConfig"] ?? "";
      const host = btn.dataset["mcpHost"] ?? "unknown";
      const label = btn.querySelector<HTMLSpanElement>("[data-mcp-label]");
      const original = label?.textContent ?? "";
      revealPanel(btn);
      try {
        await navigator.clipboard.writeText(config);
        if (label) label.textContent = "Copied ✓";
        if (!reducedMotion) btn.classList.add("is-copied");
        window.setTimeout(() => {
          if (label) label.textContent = original;
          btn.classList.remove("is-copied");
        }, COPY_RESET_MS);
      } catch {
        // Non-secure context / locked-down extension — the revealed
        // panel still shows the text for a manual copy.
      }
      emitSignal(host);
    });
  });

  // Deep-link anchors (Cursor + VS Code). The OS handoff still happens on
  // the same click (we don't preventDefault); the panel reveal is the
  // added behaviour so the user sees the manual fallback if the host
  // didn't open.
  document.querySelectorAll<HTMLAnchorElement>('[data-mcp-mode="deeplink"]').forEach((a) => {
    a.addEventListener("click", () => {
      revealPanel(a);
      emitSignal(a.dataset["mcpHost"] ?? "unknown");
    });
  });
</script>

<style>
  /* Quiet-brutalism token system (SK-WEB-015) — no new tokens,
   * only `--ground` / `--raised` / `--rule` / `--muted` / `--body`
   * / `--ink` / `--accent` and the type steps. The component sits
   * on whatever ground its parent renders against and reuses the
   * `.cta` / `.cta--ghost` primitives for its buttons. */
  .mcpinstall {
    margin: clamp(20px, 3vw, 28px) 0 0;
  }

  .mcpinstall__eyebrow {
    margin: 0 0 clamp(10px, 1.6vw, 14px);
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .mcpinstall__row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(14px, 2vw, 20px);
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .mcpinstall__row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .mcpinstall__row {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  /* Compact mode — one row at every breakpoint that fits four
   * buttons. The post-create surface drops the descriptive subline,
   * so the buttons can shrink to a tight bar. */
  .mcpinstall__row--compact {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .mcpinstall__row--compact .mcpinstall__cell {
    flex: 1 1 auto;
    min-width: 140px;
  }

  .mcpinstall__cell {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .mcpinstall__btn {
    width: 100%;
    /* Keep the buttons compact so the four-up layout fits the
     * /integrations grid without hard wraps. The base `.cta` height
     * (~46px) is too tall for a quad row; shave the inner padding. */
    padding: 11px 16px;
    font-size: 13px;
    white-space: nowrap;
  }

  .mcpinstall__sub {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.45;
  }

  .mcpinstall__hints {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    gap: 4px;
  }

  .mcpinstall__hint {
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.45;
  }

  .mcpinstall__hint-host {
    color: var(--body);
    font-weight: 600;
  }

  .mcpinstall__placeholder {
    margin: clamp(14px, 2vw, 18px) 0 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.5;
  }

  .mcpinstall__placeholder code {
    font-family: var(--mono);
    font-size: 0.92em;
    color: var(--body);
  }

  .mcpinstall__signin {
    margin-left: 6px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }

  .mcpinstall__signin:hover {
    text-decoration-color: var(--accent);
    color: var(--accent);
  }

  /* Transient "Copied ✓" state on the ghost buttons. Lime tint
   * borrows the promoted-CTA shadow so the success feedback reads
   * as the same vocabulary. One motion moment, gated. */
  .mcpinstall__btn.is-copied {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Manual-fallback panel, revealed in place on any host click. Hidden
   * via the `hidden` attribute until the script opens it. */
  .mcpinstall__panel[hidden] {
    display: none;
  }

  .mcpinstall__panel {
    margin-top: 8px;
    padding: 10px 12px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--raised);
  }

  .mcpinstall__panel-step {
    margin: 0 0 6px;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.45;
  }

  .mcpinstall__panel-code {
    margin: 0;
    padding: 8px 10px;
    overflow-x: auto;
    border-radius: 6px;
    background: var(--ground);
    font-family: var(--mono);
    font-size: 12px;
    color: var(--body);
    white-space: pre;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mcpinstall__btn {
      transition:
        transform 80ms ease-out,
        box-shadow 80ms ease-out,
        border-color 120ms ease-out,
        color 120ms ease-out;
    }
  }
</style>
