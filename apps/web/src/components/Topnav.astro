---
// Top navigation. Two reveal mechanics:
//   1. Cmd+G tester gate — toggles `[data-cmdg-gate]` elements,
//      sticky via localStorage.
//   2. Auth-aware swap — `/api/auth/get-session` probe; authed
//      users MUST never see "Sign in" even with Cmd+G held.
//
// Marketing-side caveat (`SK-WEB-009`): probe returns null on
// `nlqdb.com` because the session cookie is host-only on
// `app.nlqdb.com` — authed visitors see the "Sign in" link.
interface Props {
  current?: "manifesto" | "chat";
}
const { current } = Astro.props;
const inChat = current === "chat";
---

<header class="topnav">
  <a class="topnav__brand" href="/">nlqdb</a>
  <nav class="topnav__links" aria-label="Primary">
    <a
      href="/manifesto"
      aria-current={current === "manifesto" ? "page" : undefined}
    >
      Manifesto
    </a>
    <a href="mailto:hello@nlqdb.com">Contact</a>

    {/* Sign-in link — gated behind Cmd+G for internal testers, AND
        suppressed entirely once the auth probe resolves authed. */}
    <span id="topnav-signin-gate" data-cmdg-gate hidden>
      <a href="/auth/sign-in">Sign in</a>
    </span>

    {/* Authed slot — hidden by default; revealed only after the
        probe resolves authed. Replaces the sign-in gate. The
        "Open chat" link is suppressed when the visitor is already
        inside the chat (current === "chat") — no reason to offer
        a jump to the page they're on. */}
    <span id="topnav-authed" class="topnav__authed" hidden>
      {!inChat && (
        <a href="/app" class="topnav__chat-link">Open chat &rarr;</a>
      )}
      <button type="button" id="topnav-signout" class="topnav__signout">
        Sign out
      </button>
    </span>
  </nav>
</header>

<script>
  import { fetchSession, signOut } from "../lib/session";

  // ---- Cmd+G shared reveal gate (from main, preserved verbatim) ----
  // Toggles every `[data-cmdg-gate]` element on the page in lockstep
  // — currently the hero <CreateForm> on `/` and the "Sign in" link
  // above. preventDefault() because Chrome binds Cmd+G to "find
  // next" and we want the chord exclusive while iterating. State
  // sticks via localStorage["nlqdb_hero_visible"] (name kept for
  // continuity with the original hero gate).
  const FLAG = "nlqdb_hero_visible";

  function applyVisibility(on: boolean) {
    const gates = document.querySelectorAll<HTMLElement>("[data-cmdg-gate]");
    for (const gate of gates) {
      if (on) gate.removeAttribute("hidden");
      else gate.setAttribute("hidden", "");
    }
  }

  if (localStorage.getItem(FLAG) === "1") applyVisibility(true);

  document.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "g") {
      event.preventDefault();
      const next = localStorage.getItem(FLAG) !== "1";
      if (next) localStorage.setItem(FLAG, "1");
      else localStorage.removeItem(FLAG);
      applyVisibility(next);
    }
  });

  // ---- Auth-aware swap ---------------------------------------------
  const signinGate = document.getElementById("topnav-signin-gate");
  const authed = document.getElementById("topnav-authed");
  const signoutBtn = document.getElementById("topnav-signout");

  if (signoutBtn) {
    signoutBtn.addEventListener("click", () => {
      void signOut();
    });
  }

  void (async () => {
    const user = await fetchSession();
    if (!user) return;
    if (authed) authed.hidden = false;
    if (signinGate) {
      // Strip the Cmd+G gate AND force-hide so a chord press can't
      // resurface the "Sign in" link for an authed visitor.
      signinGate.removeAttribute("data-cmdg-gate");
      signinGate.setAttribute("hidden", "");
    }
  })();
</script>
