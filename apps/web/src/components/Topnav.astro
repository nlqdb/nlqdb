---
// Top navigation. One reveal mechanic — the auth-aware swap:
// `/api/auth/get-session` probe runs on every page load; when it
// resolves authed, the "Sign in" link is hidden and the "Open chat"
// + "Sign out" pair takes its place.
//
// Marketing-side caveat (`SK-WEB-009`): probe returns null on
// `nlqdb.com` because the session cookie is host-only on
// `app.nlqdb.com` — authed visitors see the "Sign in" link.
interface Props {
  current?: "manifesto" | "agents" | "chat" | "vs" | "pricing";
}
const { current } = Astro.props;
const inChat = current === "chat";
---

<header class="topnav">
  <a class="topnav__brand" href="/">nlqdb</a>
  <nav class="topnav__links" aria-label="Primary">
    <a
      href="/manifesto"
      aria-current={current === "manifesto" ? "page" : undefined}
    >
      Manifesto
    </a>
    <a
      href="/agents"
      aria-current={current === "agents" ? "page" : undefined}
    >
      Agents
    </a>
    <a
      href="/vs"
      aria-current={current === "vs" ? "page" : undefined}
    >
      Compare
    </a>
    <a
      href="/pricing"
      aria-current={current === "pricing" ? "page" : undefined}
    >
      Pricing
    </a>
    <a href="mailto:hello@nlqdb.com">Contact</a>

    {/* Sign-in link — suppressed once the auth probe resolves authed. */}
    <span id="topnav-signin">
      <a href="/auth/sign-in">Sign in</a>
    </span>

    {/* Authed slot — hidden by default; revealed only after the
        probe resolves authed. Replaces the sign-in link. The
        "Open chat" link is suppressed when the visitor is already
        inside the chat (current === "chat") — no reason to offer
        a jump to the page they're on. */}
    <span id="topnav-authed" class="topnav__authed" hidden>
      {!inChat && (
        <a href="/app" class="topnav__chat-link">Open chat &rarr;</a>
      )}
      <button type="button" id="topnav-signout" class="topnav__signout">
        Sign out
      </button>
    </span>
  </nav>
</header>

<script>
  import { fetchSession } from "../lib/session";

  // Hop the "Sign in" link from the marketing origin to the merged
  // app worker (`app.nlqdb.com`) so the sign-in page loads on the
  // same origin as the API (SK-AUTH-015 / SK-AUTH-016). The Astro
  // build is shared by both workers, so the link is a relative
  // path on disk and rewritten here for the marketing surface only;
  // dev (`localhost`), the merged app worker, and PR previews keep
  // the relative path.
  const signinAnchor = document.querySelector<HTMLAnchorElement>(
    "#topnav-signin a",
  );
  if (
    signinAnchor &&
    (location.hostname === "nlqdb.com" || location.hostname === "www.nlqdb.com")
  ) {
    signinAnchor.href = "https://app.nlqdb.com/auth/sign-in";
  }

  // ---- Auth-aware swap ---------------------------------------------
  const signinSlot = document.getElementById("topnav-signin");
  const authed = document.getElementById("topnav-authed");
  const signoutBtn = document.getElementById("topnav-signout");

  if (signoutBtn) {
    // All sign-out triggers funnel through /auth/sign-out (SK-AUTH-019).
    signoutBtn.addEventListener("click", () => {
      window.location.assign("/auth/sign-out");
    });
  }

  void (async () => {
    const user = await fetchSession();
    if (!user) return;
    if (authed) authed.hidden = false;
    if (signinSlot) signinSlot.setAttribute("hidden", "");
  })();
</script>
