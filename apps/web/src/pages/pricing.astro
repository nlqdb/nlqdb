---
import Footer from "../components/Footer.astro";
import Topnav from "../components/Topnav.astro";
import Base from "../layouts/Base.astro";

// PUBLIC_API_BASE is "" on app.nlqdb.com (relative URLs work),
// and "https://app.nlqdb.com" on nlqdb.com (marketing origin).
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---

<Base
  title="Pricing — nlqdb"
  description="Free forever. Upgrade when you need more. No credit card for the free tier, ever."
  canonical="/pricing"
>
  <div class="page">
    <Topnav />

    <main class="pricing">
      <header class="pricing__head">
        <p class="pricing__eyebrow">Pricing</p>
        <h1 class="pricing__title">Simple pricing. No surprises.</h1>
        <p class="pricing__sub">
          Start free — no card. Upgrade only when you outgrow it, and pay only for what you use.
        </p>
      </header>

      <div class="pricing__grid" id="pricing-grid">

        <!-- Free -->
        <article class="pricing__card">
          <div class="pricing__card-inner">
            <header class="pricing__card-header">
              <h2 class="pricing__tier">Free</h2>
              <div class="pricing__price">
                <span class="pricing__amount">$0</span>
                <span class="pricing__cadence">/ month</span>
              </div>
              <p class="pricing__pitch">For trying it out.</p>
              <p class="pricing__payon">Free forever. No card, ever.</p>
            </header>
            <ul class="pricing__features">
              <li>1,000 queries a month</li>
              <li>500 MB database</li>
              <li>Built-in LLM free — or bring your own key at 0% markup</li>
              <li class="pricing__feature--quiet">Sleeps after 7 days idle · wakes in &lt;2s</li>
            </ul>
            <a href="/app/" class="cta cta--ghost pricing__cta">Start free &rarr;</a>
          </div>
        </article>

        <!-- Hobby — our recommended default (honest editorial pick, not a
             "most popular" claim; see PR note). Gets the single accent CTA. -->
        <article class="pricing__card pricing__card--featured">
          <div class="pricing__card-inner">
            <p class="pricing__rec">Recommended</p>
            <header class="pricing__card-header">
              <h2 class="pricing__tier">Hobby</h2>
              <div class="pricing__price">
                <span class="pricing__amount">$10</span>
                <span class="pricing__cadence">/ month</span>
              </div>
              <p class="pricing__pitch">For projects you're shipping.</p>
              <p class="pricing__payon">Flat monthly. No usage fees.</p>
            </header>
            <p class="pricing__inherit">Everything in Free, plus:</p>
            <ul class="pricing__features">
              <li>50,000 queries a month</li>
              <li>5 GB database</li>
              <li>Always on — no sleeping</li>
              <li>Email support</li>
            </ul>
            <button
              type="button"
              class="cta pricing__cta"
              data-plan="hobby"
              data-api-base={apiBase}
            >
              Choose Hobby &rarr;
            </button>
          </div>
        </article>

        <!-- Pro -->
        <article class="pricing__card">
          <div class="pricing__card-inner">
            <header class="pricing__card-header">
              <h2 class="pricing__tier">Pro</h2>
              <div class="pricing__price">
                <span class="pricing__amount">$25</span>
                <span class="pricing__cadence">/ month + usage</span>
              </div>
              <p class="pricing__pitch">For apps with real traffic.</p>
              <p class="pricing__payon">Flat base, then pay per use — with a cap you set.</p>
            </header>
            <p class="pricing__inherit">Everything in Hobby, plus:</p>
            <ul class="pricing__features">
              <li>50,000 queries included, then <strong>$0.0005</strong> each</li>
              <li>5 GB included, then <strong>$0.10</strong> / GB-month</li>
              <li>Opt-in hard cap — never a surprise bill</li>
            </ul>
            <button
              type="button"
              class="cta cta--ghost pricing__cta"
              data-plan="pro"
              data-api-base={apiBase}
            >
              Choose Pro &rarr;
            </button>
          </div>
        </article>

      </div>

      <!-- Manage billing — revealed only for signed-in users (SK-STRIPE-008) -->
      <section class="pricing__manage" id="pricing-manage" hidden>
        <p>
          Already subscribed?
          <button
            type="button"
            class="pricing__manage-link"
            id="pricing-manage-btn"
            data-api-base={apiBase}
          >
            Manage billing
          </button>
          — update your card, switch plan, download invoices, or cancel.
        </p>
      </section>

      <!-- Honest billing — the promise, tightened. Reads as reassurance
           (relaxing), not fine print. -->
      <section class="pricing__promise">
        <h2 class="pricing__section-title">No surprises. Ever.</h2>
        <ul class="pricing__promise-list">
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>No card for Free.</strong> Not "to verify," not for "spam." Never.</span></li>
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>Hit a limit? You're paused, not charged.</strong> You choose what's next.</span></li>
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>Heads-up at 80%,</strong> hard stop at 100%. No runaway bills.</span></li>
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>Cancel or downgrade in one click.</strong> Pro-rated refund, no exit survey.</span></li>
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>Your data is yours.</strong> Pull all of it out anytime with plain SQL — free, on every tier.</span></li>
          <li><span class="pricing__check" aria-hidden="true"></span><span><strong>We email before the first charge</strong> — exact amount and date.</span></li>
        </ul>
      </section>

      <!-- Good to know — BYO-LLM · self-host · enterprise, one tight row. -->
      <section class="pricing__notes">
        <div class="pricing__note">
          <h3 class="pricing__note-title">Bring your own LLM</h3>
          <p>Anthropic, OpenAI, Gemini, or OpenRouter key at <strong>0% markup</strong> — every tier. <a href="/app/keys/">Settings &rarr; Keys</a>.</p>
        </div>
        <div class="pricing__note">
          <h3 class="pricing__note-title">Self-host the source</h3>
          <p>Engine, CLI, MCP, and SDKs under <a href="https://github.com/nlqdb/nlqdb/blob/main/LICENSE">FSL-1.1</a> — converts to Apache&nbsp;2.0 in two years.</p>
        </div>
        <div class="pricing__note">
          <h3 class="pricing__note-title">Enterprise</h3>
          <p>VPC peering, SSO, audit logs, annual billing. <a href="mailto:hello@nlqdb.com">Email us</a> with what you need.</p>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Upgrade CTA handler. Checks auth state, creates a Stripe Checkout
  // Session via POST /v1/billing/checkout, redirects to the session URL.
  // Unauthenticated clicks redirect to sign-in with a `return_to=/pricing` hint.

  import { fetchSession } from "../lib/session";
  import { fetchBillingStatus, formatPlanEndDate, openBillingPortal } from "../lib/billing";

  const buttons = document.querySelectorAll<HTMLButtonElement>("button[data-plan]");

  for (const btn of buttons) {
    btn.addEventListener("click", async () => {
      const plan = btn.dataset.plan as "hobby" | "pro";
      const apiBase = (btn.dataset.apiBase ?? "").replace(/\/$/, "");

      // An existing subscriber changing tier goes through the Billing Portal
      // (Stripe prorates), never a second Checkout — that would create a
      // parallel subscription and double-bill (SK-STRIPE-010). The status
      // pass below marks the non-current paid CTA with data-switch.
      if (btn.dataset.switch === "1") {
        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = "Redirecting…";
        const outcome = await openBillingPortal(apiBase);
        if (outcome === "ok") return; // browser is already navigating to Stripe
        btn.disabled = false;
        btn.textContent = original;
        alert("Couldn't open the billing portal. Please try “Manage billing” below or email hello@nlqdb.com.");
        return;
      }

      const user = await fetchSession();
      if (!user) {
        // Relative on purpose — the local sign-in page hops to the app
        // origin itself, carrying localStorage state (SK-ANON-015).
        window.location.assign("/auth/sign-in/?return_to=/pricing/");
        return;
      }

      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Redirecting…";

      try {
        const res = await fetch(`${apiBase}/v1/billing/checkout`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ plan }),
          credentials: "include",
        });

        if (!res.ok) {
          if (res.status === 503) {
            // Price IDs or Stripe key not yet configured — show a helpful message.
            btn.textContent = "Not available yet";
            return;
          }
          if (res.status === 409) {
            // Already subscribed (server backstop if the status pass was stale
            // or failed) — switch tier in the portal, where Stripe prorates.
            // openBillingPortal never throws, so restore the button here if it
            // couldn't redirect rather than leaving it stuck on "Redirecting…".
            const outcome = await openBillingPortal(apiBase);
            if (outcome !== "ok") {
              btn.disabled = false;
              btn.textContent = original;
              alert("Couldn't open the billing portal. Please try “Manage billing” below or email hello@nlqdb.com.");
            }
            return;
          }
          throw new Error(`checkout failed: ${res.status}`);
        }

        const { url } = (await res.json()) as { url: string };
        window.location.assign(url);
      } catch {
        btn.disabled = false;
        btn.textContent = original;
        alert("Something went wrong. Please try again or email hello@nlqdb.com.");
      }
    });
  }

  // Reflect the caller's real plan. GET /v1/billing/status is a plain D1
  // read (no Stripe call), so this stays cheap and works before live keys
  // exist. We badge the active tier and reveal "Manage billing" only for
  // actual subscribers — a free user who never checked out would otherwise
  // see the control and hit a 404 on click.
  const manageSection = document.getElementById("pricing-manage");
  const manageBtn = document.getElementById("pricing-manage-btn") as HTMLButtonElement | null;

  // Display hint only: statuses where the subscriber holds the tier, so the
  // "Current plan" badge + "Switch plan" relabel are honest. It need NOT match
  // the server's broader checkout guard — the 409 from /v1/billing/checkout is
  // the authority, so a status it blocks but this omits still routes to the
  // portal via the 409 handler above, just without the nicer label.
  const ACTIVE_STATUSES = new Set(["active", "trialing", "past_due"]);

  void (async () => {
    const user = await fetchSession();
    if (!user) return;

    // Status is a progressive enhancement — on failure the page stays in
    // its default state (upgrade CTAs live, manage hidden) rather than
    // blocking the user.
    const status = await fetchBillingStatus(manageBtn?.dataset.apiBase ?? "");
    if (!status) return;

    if (status.manageable && manageSection) manageSection.hidden = false;
    if (
      (status.plan === "hobby" || status.plan === "pro") &&
      ACTIVE_STATUSES.has(status.status)
    ) {
      // A subscriber who cancelled keeps access until period end (Stripe sets
      // cancel_at_period_end, status stays `active`). Surfacing the end date is
      // an honest-billing duty (no silent lapse) and the CTA stays live as a
      // one-click "Resubscribe" — Stripe un-cancels in the portal (SK-WEB-013).
      const ending = status.cancelAtPeriodEnd;
      const endDate = ending ? formatPlanEndDate(status.currentPeriodEnd) : null;

      // Badge + lock the current plan; turn every other paid CTA into a
      // portal-routed "Switch plan" so a subscriber never starts a second
      // Checkout (which would double-bill — SK-STRIPE-010).
      for (const cta of buttons) {
        if (cta.dataset.plan === status.plan) {
          const header = cta.closest(".pricing__card")?.querySelector(".pricing__card-header");
          if (header) {
            const badge = document.createElement("span");
            badge.className = ending ? "pricing__badge pricing__badge--ending" : "pricing__badge";
            badge.textContent = ending ? (endDate ? `Ends ${endDate}` : "Ending") : "Current plan";
            header.prepend(badge);
          }
          if (ending) {
            cta.dataset.switch = "1";
            cta.textContent = "Resubscribe";
          } else {
            cta.disabled = true;
            cta.textContent = "Current plan";
          }
        } else {
          cta.dataset.switch = "1";
          cta.textContent = "Switch plan";
        }
      }
    }
  })();

  manageBtn?.addEventListener("click", async () => {
    manageBtn.disabled = true;
    const original = manageBtn.textContent;
    manageBtn.textContent = "Redirecting…";
    const outcome = await openBillingPortal(manageBtn.dataset.apiBase ?? "");
    if (outcome === "ok") return; // browser is already navigating to Stripe
    if (outcome === "no_customer") {
      manageBtn.textContent = "No active subscription yet";
      return;
    }
    if (outcome === "not_configured") {
      manageBtn.textContent = "Not available yet";
      return;
    }
    manageBtn.disabled = false;
    manageBtn.textContent = original;
    alert("Something went wrong. Please try again or email hello@nlqdb.com.");
  });
</script>

{/* Spotlight interaction — the hovered card's radial glow tracks the cursor
    via CSS custom properties (--x/--y). rAF-throttled; only on real-hover
    pointers (skips touch). Setting a property isn't motion, so it's safe
    under prefers-reduced-motion; the lift/opacity transitions are gated in
    CSS. Pattern: Aceternity/MagicUI/Vercel "spotlight card". */}
<script is:inline>
  (function () {
    var grid = document.getElementById("pricing-grid");
    if (!grid || !window.matchMedia("(hover: hover)").matches) return;
    var raf = 0;
    var pending = null;
    function apply() {
      raf = 0;
      if (!pending) return;
      pending.card.style.setProperty("--x", pending.x + "px");
      pending.card.style.setProperty("--y", pending.y + "px");
    }
    grid.addEventListener(
      "pointermove",
      function (e) {
        var card = e.target.closest(".pricing__card");
        if (!card) return;
        var r = card.getBoundingClientRect();
        pending = { card: card, x: e.clientX - r.left, y: e.clientY - r.top };
        if (!raf) raf = requestAnimationFrame(apply);
      },
      { passive: true },
    );
  })();
</script>

<style>
  /* /pricing — calm system (SK-WEB-020). Three side-by-side spotlight
   * cards (cursor-tracked radial glow via --x/--y), aligned so prices and
   * CTAs form clean horizontal bands. Middle tier (Hobby) carries the one
   * accent moment: the promoted `.cta` + a subtle persistent glow + an
   * honest editorial "Recommended" tag (no fabricated "most popular"). */

  .pricing {
    max-width: var(--bleed);
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) 0 var(--gap-beat);
  }

  .pricing__head {
    max-width: 640px;
    margin: 0 auto clamp(40px, 6vw, 64px);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pricing__eyebrow {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .pricing__title {
    font-family: var(--display);
    font-size: var(--t-display);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--ink);
    text-wrap: balance;
    margin: 0;
  }

  .pricing__sub {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.5;
    max-width: 52ch;
    margin-inline: auto;
    text-wrap: balance;
  }

  /* Side-by-side from 900px; stacked below. Extra top padding lets the
   * featured card's lift breathe. */
  .pricing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2vw, 22px);
    margin: 0 auto clamp(48px, 7vw, 80px);
    padding-top: 12px;
  }

  @media (min-width: 900px) {
    .pricing__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Spotlight card. The element paints the base surface + border; the
   * cursor-tracked glow is `::after` (above the surface, below content);
   * content lives in `.pricing__card-inner` (z-index 1, transparent). */
  .pricing__card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: var(--r-lg);
    background: linear-gradient(180deg, var(--raised), var(--bg-2));
    box-shadow: var(--shadow-1);
  }

  .pricing__card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      280px circle at var(--x, 50%) var(--y, 50%),
      var(--accent-soft),
      transparent 62%
    );
  }

  .pricing__card:hover {
    border-color: var(--accent-line);
    box-shadow:
      var(--shadow-3),
      0 0 44px -14px var(--accent-line);
  }

  .pricing__card:hover::after {
    opacity: 1;
  }

  /* Featured (Hobby) — honest editorial emphasis: persistent accent border,
   * a faint centred glow, and the "Recommended" tag. No transform so it
   * doesn't fight the hover lift; no "most popular" claim. */
  .pricing__card--featured {
    border-color: var(--accent-line);
    box-shadow: 0 12px 40px -20px rgba(0, 0, 0, 0.6);
  }

  .pricing__card--featured::after {
    opacity: 0.4;
  }

  .pricing__card-inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: clamp(24px, 3vw, 34px);
  }

  /* Corner ribbon — out of flow so every card's header (and price row)
   * starts at the same y. */
  .pricing__rec {
    position: absolute;
    top: clamp(16px, 2vw, 20px);
    right: clamp(16px, 2vw, 20px);
    z-index: 2;
    margin: 0;
    display: inline-flex;
    align-items: center;
    padding: 4px 11px;
    border-radius: var(--r-pill);
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--sans);
    font-size: var(--t-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .pricing__card-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rule);
  }

  .pricing__tier {
    font-family: var(--sans);
    font-size: var(--t-section);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .pricing__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  /* Mono earns its keep here — digits are data. */
  .pricing__amount {
    font-family: var(--mono);
    font-size: clamp(38px, 5vw, 52px);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .pricing__cadence {
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .pricing__pitch {
    margin: 4px 0 0;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.45;
  }

  .pricing__payon {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.4;
  }

  .pricing__inherit {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .pricing__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
    flex: 1;
  }

  .pricing__features li {
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.45;
    padding-left: 26px;
    position: relative;
  }

  /* Accent check glyph, drawn with CSS (no icon dep). */
  .pricing__features li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 6px;
    width: 6px;
    height: 10px;
    border: solid var(--accent);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .pricing__features .pricing__feature--quiet {
    color: var(--muted);
    font-size: var(--t-small);
  }

  .pricing__features .pricing__feature--quiet::before {
    border-color: var(--muted);
  }

  .pricing__features li strong {
    color: var(--ink);
    font-family: var(--mono);
    font-weight: 600;
  }

  /* Stretch the foundation `.cta` full-width; the CTAs align in a band at
   * the card foot because `.pricing__features` is `flex: 1`. */
  .pricing__cta {
    width: 100%;
  }

  .pricing__cta:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  /* SK-WEB-013 — scheduled-cancel badge (prepended by the billing script). */
  .pricing__badge {
    align-self: flex-start;
    font-family: var(--sans);
    font-size: var(--t-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent-ink);
    background: var(--accent);
    border-radius: var(--r-pill);
    padding: 4px 11px;
  }

  .pricing__badge--ending {
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--rule-2);
  }

  .pricing__manage {
    max-width: var(--col);
    margin: 0 auto clamp(40px, 6vw, 64px);
    text-align: center;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
  }

  .pricing__manage p {
    margin: 0;
  }

  .pricing__manage-link {
    background: none;
    border: 0;
    padding: 0;
    color: var(--ink);
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .pricing__manage-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent-line);
  }

  .pricing__manage-link:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* "No surprises" — the honest-billing promise as a reassuring two-column
   * checklist. */
  .pricing__promise {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 48px) 0;
    border-top: 1px solid var(--rule);
    text-align: center;
  }

  .pricing__section-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
  }

  .pricing__promise-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px 28px;
    text-align: left;
  }

  @media (min-width: 680px) {
    .pricing__promise-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pricing__promise-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--sans);
