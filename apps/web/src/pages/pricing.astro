---
import Footer from "../components/Footer.astro";
import Topnav from "../components/Topnav.astro";
import Base from "../layouts/Base.astro";

// PUBLIC_API_BASE is "" on app.nlqdb.com (relative URLs work),
// and "https://app.nlqdb.com" on nlqdb.com (marketing origin).
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---

<Base
  title="Pricing — nlqdb"
  description="Free forever. Upgrade when you need more. No credit card for the free tier, ever."
  canonical="/pricing"
>
  <div class="page">
    <Topnav />

    <main class="pricing">
      <header class="pricing__head">
        <p class="pricing__eyebrow">Pricing</p>
        <h1 class="pricing__title">Simple, honest pricing.</h1>
        <p class="pricing__sub">
          Free forever. No credit card to start. Upgrade only when you need to.
        </p>
      </header>

      <div class="pricing__grid">

        <!-- Free -->
        <article class="pricing__card">
          <header class="pricing__card-header">
            <h2 class="pricing__tier">Free</h2>
            <div class="pricing__price">
              <span class="pricing__amount">$0</span>
              <span class="pricing__cadence">/ month</span>
            </div>
            <p class="pricing__pitch">For learning the shape of the thing.</p>
          </header>
          <ul class="pricing__features">
            <li>1,000 queries / month</li>
            <li>500 MB per database</li>
            <li>Pauses after 7 days idle (resumes in &lt;2s)</li>
            <li>7-day backups</li>
            <li>Free LLM chain — forever</li>
            <li>Paste your own provider key (BYO-LLM) at 0% markup</li>
          </ul>
          <a href="/app" class="cta cta--ghost pricing__cta">Start for free &rarr;</a>
        </article>

        <!-- Hobby -->
        <article class="pricing__card">
          <header class="pricing__card-header">
            <h2 class="pricing__tier">Hobby</h2>
            <div class="pricing__price">
              <span class="pricing__amount">$10</span>
              <span class="pricing__cadence">/ month</span>
            </div>
            <p class="pricing__pitch">For projects past the proof.</p>
          </header>
          <ul class="pricing__features">
            <li>50,000 queries / month</li>
            <li>5 GB per database</li>
            <li>No database pausing</li>
            <li>30-day backups</li>
            <li>Email support</li>
            <li>Everything in Free</li>
          </ul>
          <button
            type="button"
            class="cta pricing__cta"
            data-plan="hobby"
            data-api-base={apiBase}
          >
            Upgrade to Hobby &rarr;
          </button>
        </article>

        <!-- Pro -->
        <article class="pricing__card">
          <header class="pricing__card-header">
            <h2 class="pricing__tier">Pro</h2>
            <div class="pricing__price">
              <span class="pricing__amount">$25</span>
              <span class="pricing__cadence">/ month + usage</span>
            </div>
            <p class="pricing__pitch">For traffic that earns its keep.</p>
          </header>
          <ul class="pricing__features">
            <li>50,000 queries included + $0.0005 / extra query</li>
            <li>5 GB included + $0.10 / GB-month extra</li>
            <li>Hard cap opt-in (no surprise bills)</li>
            <li>Everything in Hobby</li>
          </ul>
          <button
            type="button"
            class="cta cta--ghost pricing__cta"
            data-plan="pro"
            data-api-base={apiBase}
          >
            Upgrade to Pro &rarr;
          </button>
        </article>

      </div>

      <!-- Manage billing — revealed only for signed-in users (SK-STRIPE-008) -->
      <section class="pricing__manage" id="pricing-manage" hidden>
        <p>
          Already subscribed?
          <button
            type="button"
            class="pricing__manage-link"
            id="pricing-manage-btn"
            data-api-base={apiBase}
          >
            Manage billing
          </button>
          — update your card, switch plan, download invoices, or cancel.
        </p>
      </section>

      <!-- Enterprise footnote — kept off the tier chrome to honour the "three tiers, same metric" rule. -->
      <section class="pricing__enterprise">
        <h2 class="pricing__section-title">Need VPC peering, SSO, or annual billing?</h2>
        <p>
          Enterprise terms include VPC peering, SAML SSO, audit-log export, on-premises deployment, and annual
          contracts. <a href="mailto:hello@nlqdb.com">Email us</a> with what you need.
        </p>
      </section>

      <!-- BYOLLM callout -->
      <section class="pricing__aside">
        <h2 class="pricing__section-title">Bring your own LLM — free on every tier</h2>
        <p>
          Paste an Anthropic, OpenAI, Gemini, or OpenRouter key in <a href="/app/keys">Settings &rarr; Keys</a>.
          Your queries route through your key at <strong>0% markup</strong>. Works on the free tier, no card needed.
        </p>
      </section>

      <!-- Self-host callout (FSL-1.1, SK-PIVOT-005) — source-available, not a turnkey image yet -->
      <section class="pricing__aside">
        <h2 class="pricing__section-title">Or self-host the source — no pricing page at all</h2>
        <p>
          The engine, CLI, MCP server, and SDKs are source-available under
          <a href="https://github.com/nlqdb/nlqdb/blob/main/LICENSE">FSL-1.1-ALv2</a> — yours to read, fork, and
          self-host for any non-competing use. Bring your own LLM key at <strong>0% markup</strong>: no per-call fees,
          no &ldquo;contact sales.&rdquo; The license auto-converts to Apache&nbsp;2.0 two years after each release.
        </p>
      </section>

      <!-- Honest billing rules -->
      <section class="pricing__rules">
        <h2 class="pricing__section-title">Honest billing — hard rules</h2>
        <ul class="pricing__rules-list">
          <li><strong>No credit card for the free tier, ever.</strong> Not "to verify identity." Not for "spam protection." No.</li>
          <li><strong>Hitting a limit rate-limits — never silently upgrades.</strong> You'll see a clear message; you decide what to do next.</li>
          <li><strong>Soft cap email at 80%</strong> of your monthly budget. Hard cap at 100%. No surprise bills.</li>
          <li><strong>Export is always free.</strong> Your data is yours. One click, any time.</li>
          <li><strong>Cancellation is one click.</strong> No call, no chat, no exit survey.</li>
          <li><strong>First charge confirmation.</strong> Email before the first charge with the exact amount and date.</li>
          <li><strong>Downgrade is as easy as upgrade.</strong> One click. Pro-rated refund on the unused portion.</li>
        </ul>
      </section>
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Upgrade CTA handler. Checks auth state, creates a Stripe Checkout
  // Session via POST /v1/billing/checkout, redirects to the session URL.
  // Unauthenticated clicks redirect to sign-in with a `return_to=/pricing` hint.

  import { fetchSession } from "../lib/session";
  import { fetchBillingStatus, formatPlanEndDate, openBillingPortal } from "../lib/billing";

  const buttons = document.querySelectorAll<HTMLButtonElement>("button[data-plan]");

  for (const btn of buttons) {
    btn.addEventListener("click", async () => {
      const plan = btn.dataset.plan as "hobby" | "pro";
      const apiBase = (btn.dataset.apiBase ?? "").replace(/\/$/, "");

      // An existing subscriber changing tier goes through the Billing Portal
      // (Stripe prorates), never a second Checkout — that would create a
      // parallel subscription and double-bill (SK-STRIPE-010). The status
      // pass below marks the non-current paid CTA with data-switch.
      if (btn.dataset.switch === "1") {
        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = "Redirecting…";
        const outcome = await openBillingPortal(apiBase);
        if (outcome === "ok") return; // browser is already navigating to Stripe
        btn.disabled = false;
        btn.textContent = original;
        alert("Couldn't open the billing portal. Please try “Manage billing” below or email hello@nlqdb.com.");
        return;
      }

      const user = await fetchSession();
      if (!user) {
        const signinUrl =
          location.hostname === "nlqdb.com" || location.hostname === "www.nlqdb.com"
            ? `https://app.nlqdb.com/auth/sign-in?return_to=/pricing`
            : `/auth/sign-in?return_to=/pricing`;
        window.location.assign(signinUrl);
        return;
      }

      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Redirecting…";

      try {
        const res = await fetch(`${apiBase}/v1/billing/checkout`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ plan }),
          credentials: "include",
        });

        if (!res.ok) {
          if (res.status === 503) {
            // Price IDs or Stripe key not yet configured — show a helpful message.
            btn.textContent = "Not available yet";
            return;
          }
          if (res.status === 409) {
            // Already subscribed (server backstop if the status pass was stale
            // or failed) — switch tier in the portal, where Stripe prorates.
            // openBillingPortal never throws, so restore the button here if it
            // couldn't redirect rather than leaving it stuck on "Redirecting…".
            const outcome = await openBillingPortal(apiBase);
            if (outcome !== "ok") {
              btn.disabled = false;
              btn.textContent = original;
              alert("Couldn't open the billing portal. Please try “Manage billing” below or email hello@nlqdb.com.");
            }
            return;
          }
          throw new Error(`checkout failed: ${res.status}`);
        }

        const { url } = (await res.json()) as { url: string };
        window.location.assign(url);
      } catch {
        btn.disabled = false;
        btn.textContent = original;
        alert("Something went wrong. Please try again or email hello@nlqdb.com.");
      }
    });
  }

  // Reflect the caller's real plan. GET /v1/billing/status is a plain D1
  // read (no Stripe call), so this stays cheap and works before live keys
  // exist. We badge the active tier and reveal "Manage billing" only for
  // actual subscribers — a free user who never checked out would otherwise
  // see the control and hit a 404 on click.
  const manageSection = document.getElementById("pricing-manage");
  const manageBtn = document.getElementById("pricing-manage-btn") as HTMLButtonElement | null;

  // Display hint only: statuses where the subscriber holds the tier, so the
  // "Current plan" badge + "Switch plan" relabel are honest. It need NOT match
  // the server's broader checkout guard — the 409 from /v1/billing/checkout is
  // the authority, so a status it blocks but this omits still routes to the
  // portal via the 409 handler above, just without the nicer label.
  const ACTIVE_STATUSES = new Set(["active", "trialing", "past_due"]);

  void (async () => {
    const user = await fetchSession();
    if (!user) return;

    // Status is a progressive enhancement — on failure the page stays in
    // its default state (upgrade CTAs live, manage hidden) rather than
    // blocking the user.
    const status = await fetchBillingStatus(manageBtn?.dataset.apiBase ?? "");
    if (!status) return;

    if (status.manageable && manageSection) manageSection.hidden = false;
    if (
      (status.plan === "hobby" || status.plan === "pro") &&
      ACTIVE_STATUSES.has(status.status)
    ) {
      // A subscriber who cancelled keeps access until period end (Stripe sets
      // cancel_at_period_end, status stays `active`). Surfacing the end date is
      // an honest-billing duty (no silent lapse) and the CTA stays live as a
      // one-click "Resubscribe" — Stripe un-cancels in the portal (SK-WEB-013).
      const ending = status.cancelAtPeriodEnd;
      const endDate = ending ? formatPlanEndDate(status.currentPeriodEnd) : null;

      // Badge + lock the current plan; turn every other paid CTA into a
      // portal-routed "Switch plan" so a subscriber never starts a second
      // Checkout (which would double-bill — SK-STRIPE-010).
      for (const cta of buttons) {
        if (cta.dataset.plan === status.plan) {
          const header = cta.closest(".pricing__card")?.querySelector(".pricing__card-header");
          if (header) {
            const badge = document.createElement("span");
            badge.className = ending ? "pricing__badge pricing__badge--ending" : "pricing__badge";
            badge.textContent = ending ? (endDate ? `Ends ${endDate}` : "Ending") : "Current plan";
            header.prepend(badge);
          }
          if (ending) {
            cta.dataset.switch = "1";
            cta.textContent = "Resubscribe";
          } else {
            cta.disabled = true;
            cta.textContent = "Current plan";
          }
        } else {
          cta.dataset.switch = "1";
          cta.textContent = "Switch plan";
        }
      }
    }
  })();

  manageBtn?.addEventListener("click", async () => {
    manageBtn.disabled = true;
    const original = manageBtn.textContent;
    manageBtn.textContent = "Redirecting…";
    const outcome = await openBillingPortal(manageBtn.dataset.apiBase ?? "");
    if (outcome === "ok") return; // browser is already navigating to Stripe
    if (outcome === "no_customer") {
      manageBtn.textContent = "No active subscription yet";
      return;
    }
    if (outcome === "not_configured") {
      manageBtn.textContent = "Not available yet";
      return;
    }
    manageBtn.disabled = false;
    manageBtn.textContent = original;
    alert("Something went wrong. Please try again or email hello@nlqdb.com.");
  });
</script>

<style>
  /* /pricing — quiet brutalism token sweep (SK-WEB-015, redesign-plan §5).
   * Same card chrome on every tier (no "popular" badge unless measured).
   * Tier names in display serif; prices in mono — digits are data here.
   * Every tier CTA uses the foundation `.cta` primitive; this file adds
   * `.pricing__cta` only to stretch it full-width inside the card. */

  .pricing {
    max-width: var(--bleed);
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) 0 var(--gap-beat);
  }

  .pricing__head {
    max-width: var(--col);
    margin: 0 auto clamp(48px, 7vw, 80px);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pricing__eyebrow {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .pricing__title {
    font-family: var(--display);
    font-size: var(--t-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
    text-wrap: balance;
    margin: 0;
  }

  .pricing__sub {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.45;
    max-width: 48ch;
    margin-inline: auto;
    text-wrap: balance;
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--gap-block);
    margin-bottom: clamp(56px, 8vw, 96px);
  }

  /* Same metric chrome on every tier — no "popular" lift, no accent border. */
  .pricing__card {
    background: var(--raised);
    border: 1px solid var(--rule);
    padding: clamp(24px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pricing__card-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule);
  }

  .pricing__tier {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.015em;
  }

  .pricing__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Mono earns its keep here — digits are data. */
  .pricing__amount {
    font-family: var(--mono);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .pricing__cadence {
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .pricing__pitch {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.45;
  }

  .pricing__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .pricing__features li {
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.5;
    padding-left: 20px;
    position: relative;
  }

  .pricing__features li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.6;
  }

  /* Stretch the foundation `.cta` full-width inside each card; no per-tier
   * visual variants — the lime/ghost split is the same primitive used in
   * the hero, just composed via `.cta` / `.cta--ghost`. */
  .pricing__cta {
    width: 100%;
  }

  .pricing__cta:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  /* SK-WEB-013 — scheduled-cancel badge. Same neutral chrome as the rest of
   * the card; "Current plan" gets the lime fill, "Ends {date}" stays quiet
   * because it's the user's own choice ending, not an error. */
  .pricing__badge {
    align-self: flex-start;
    font-family: var(--mono);
    font-size: var(--t-small);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-ink);
    background: var(--accent);
    padding: 4px 10px;
  }

  .pricing__badge--ending {
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--rule);
  }

  .pricing__manage {
    max-width: var(--col);
    margin: 0 auto clamp(48px, 6vw, 72px);
    text-align: center;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
  }

  .pricing__manage p {
    margin: 0;
  }

  .pricing__manage-link {
    background: none;
    border: 0;
    padding: 0;
    color: var(--ink);
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .pricing__manage-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .pricing__manage-link:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Asides — Enterprise mention, BYOLLM, self-host. Quiet typographic
   * blocks, no card chrome. The tier grid is the only place cards live. */
  .pricing__enterprise,
  .pricing__aside,
  .pricing__rules {
    max-width: var(--col);
    margin: 0 auto;
    padding: clamp(32px, 5vw, 48px) 0;
    border-top: 1px solid var(--rule);
  }

  .pricing__section-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 16px;
    text-wrap: balance;
  }

  .pricing__enterprise p,
  .pricing__aside p {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.65;
    max-width: 60ch;
  }

  .pricing__rules-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing__rules-list li {
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.6;
    padding-left: 20px;
    position: relative;
    max-width: 70ch;
  }

  .pricing__rules-list li::before {
    content: "·";
    position: absolute;
    left: 4px;
    top: 0;
    color: var(--muted);
    font-weight: 700;
  }

  .pricing__rules-list strong {
    color: var(--ink);
    font-weight: 600;
  }
</style>
