---
// Index of `/solve/<slug>` pages — sits at /solve as a fallback for
// people who typed the prefix without a slug, and as the canonical
// internal-link hub the per-pain pages cross-link to.

import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import { SOLVE_ENTRIES, SOLVE_PERSONA_ORDER, SOLVE_PERSONAS } from "../../data/solve";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/itemlist-jsonld";

// ItemList JSON-LD (SK-SOLVE-005) — enumerate the full solve-guide set for
// answer engines, built from the same SOLVE_ENTRIES the lists below render so
// the two can't drift. `name` mirrors the visible search-query heading.
const itemListLd = itemListJsonLd(
  "Solve a specific problem with nlqdb",
  SOLVE_ENTRIES.map((s) => ({ name: s.searchTitle, path: `/solve/${s.slug}` })),
  Astro.site,
);

const groupedByPersona = SOLVE_PERSONA_ORDER.map((persona) => ({
  persona,
  info: SOLVE_PERSONAS[persona],
  entries: SOLVE_ENTRIES.filter((s) => s.persona === persona),
  sectionId: `group-${persona.split(" ").slice(1).join("-")}`,
})).filter((g) => g.entries.length > 0);
---
<Base
  title="Solve a specific problem with nlqdb — natural-language databases"
  description="Pain-driven pages: each one starts with a natural-language search query and answers it with a working snippet. Honest about what nlqdb does and doesn't do for each shape."
  canonical="/solve"
>
  <div class="page">
    <Topnav />

    <main class="slvidx">
      <header class="slvidx__head">
        <p class="slvidx__kicker">Solve</p>
        <h1 class="slvidx__title">Specific problems, with a working snippet</h1>
        <p class="slvidx__lede">
          One page per recurring search query — each answers the question with a working
          {' '}<code>&lt;nlq-data&gt;</code>{' '}embed and names what nlqdb doesn't do for
          that shape. Pages that hide their limits don't earn citations, and they don't
          earn trust.
        </p>
      </header>

      {
        groupedByPersona.map((g) => (
          <section class="slvidx__group" aria-labelledby={g.sectionId}>
            <header class="slvidx__group-head">
              <h2 class="slvidx__group-title" id={g.sectionId}>
                {g.info.label}
              </h2>
              <p class="slvidx__group-desc">{g.info.description}</p>
            </header>
            <ul class="slvidx__list">
              {g.entries.map((s) => (
                <li class="slvidx__item">
                  <a href={`/solve/${s.slug}`} class="slvidx__link">
                    <h3 class="slvidx__name">{s.searchTitle}</h3>
                    <p class="slvidx__one-liner">{s.oneLiner}</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      <section class="slvidx__cta">
        <h2>Have a problem we don't cover?</h2>
        <p>
          <a href="mailto:hello@nlqdb.com?subject=Solve page request">Email the search query</a>
          {' '}you typed; if it matches a recurring theme in our ICP-mining cluster file,
          {' '}the page ships the same week. See also{' '}
          <a href="/vs">competitor comparisons</a>.
        </p>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
</Base>

<style>
  .slvidx {
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) clamp(16px, 4vw, 32px);
  }
  .slvidx__kicker {
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-dim);
    font-size: 13px;
    margin: 0 0 12px;
  }
  .slvidx__title {
    font-family: var(--mono);
    font-size: clamp(28px, 4.5vw, 44px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .slvidx__lede {
    font-size: clamp(15px, 1.7vw, 17px);
    color: var(--fg);
    max-width: 62ch;
    margin: 0 0 48px;
    line-height: 1.55;
  }
  .slvidx__lede code {
    font-family: var(--mono);
    font-size: 0.92em;
  }
  .slvidx__group {
    margin: 0 0 56px;
  }
  .slvidx__group-head {
    margin: 0 0 20px;
  }
  .slvidx__group-title {
    font-family: var(--mono);
    font-size: clamp(20px, 2.6vw, 26px);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  .slvidx__group-desc {
    color: var(--fg-dim);
    font-size: 14px;
    line-height: 1.55;
    max-width: 62ch;
    margin: 0;
  }
  .slvidx__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }
  .slvidx__link {
    display: block;
    padding: 20px;
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    text-decoration: none;
    color: inherit;
  }
  .slvidx__link:hover {
    border-color: var(--accent);
  }
  .slvidx__name {
    font-family: var(--mono);
    font-size: 16px;
    margin: 0 0 8px;
    color: var(--fg);
    line-height: 1.3;
  }
  .slvidx__one-liner {
    color: var(--fg-dim);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }
  .slvidx__cta {
    padding: 24px;
    border: 1px dashed var(--border-strong);
    text-align: center;
  }
  .slvidx__cta h2 {
    font-family: var(--mono);
    font-size: 18px;
    margin: 0 0 8px;
  }
  .slvidx__cta p {
    margin: 0;
    color: var(--fg-dim);
    font-size: 14px;
  }
  .slvidx__cta a {
    color: var(--accent);
  }
</style>
