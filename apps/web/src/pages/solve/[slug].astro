---
// One template, N pain-driven pages — generated at build via
// `getStaticPaths()` from `data/solve.ts`. AEO patterning: direct-
// answer capsule above the fold, named search query in <h1>, FAQPage
// + HowTo + BreadcrumbList JSON-LD, honest "what nlqdb doesn't do"
// section, cited public-discussion hubs as evidence trail.
//
// SK-WEB-015 page sweep (redesign-plan §5 `/solve/*`): same template
// treatment as `/vs`. Three beats: (1) Hero — the one-line problem
// statement; (2) Demo — the snippet that solves it, side-by-side
// (mirrors the homepage Demo block, lime tag highlight only on the
// `<nlq-data>` identifier); (3) "What this replaces" — short
// strikethrough list. The AEO-mandated sections (honest limits,
// FAQs, sources, final CTA) ride below as quiet supporting beats.

import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import { SOLVE_ENTRIES, SOLVE_PERSONAS, solveBySlug } from "../../data/solve";
import Base from "../../layouts/Base.astro";
import { breadcrumbJsonLd } from "../../lib/breadcrumb";
import { faqPageJsonLd } from "../../lib/faq-jsonld";

export function getStaticPaths() {
  return SOLVE_ENTRIES.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const s = solveBySlug(slug as string);
if (!s) {
  return Astro.redirect("/solve");
}

const pageTitle = `${s.searchTitle} — nlqdb`;
const description = s.oneLiner;
const canonical = `/solve/${s.slug}`;

// Bespoke share card for the P2 agent-builder solve cluster (parity with the
// `/vs` cluster's WS-08 cards). Other personas fall back to the site-wide
// default. PNGs are committed under public/og/ by scripts/og/gen-og.mjs.
const ogImage = s.persona === "P2 agent builder" ? `/og/solve-${s.slug}.png` : undefined;
const ogImageAlt = `${s.searchTitle} — answered with a GROUP BY in nlqdb.`;

const faqJsonLd = faqPageJsonLd(s.faqs);

// HowTo JSON-LD — per §3.1 of automated-icp-validation-plan.md. The
// three steps map to the canonical anonymous-mode arc: read, embed,
// adopt. Cited-source heuristics on Perplexity / ChatGPT lift
// structured HowTo step text into "how to" answer boxes.
const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: s.searchTitle,
  description: s.oneLiner,
  totalTime: "PT2M",
  tool: [{ "@type": "HowToTool", name: "<nlq-data> element" }],
  step: [
    {
      "@type": "HowToStep",
      name: "Drop the element in your HTML",
      text: `Add <nlq-data goal="${s.demoGoal}"></nlq-data> to any page. No build step, no script tag besides the loader.`,
    },
    {
      "@type": "HowToStep",
      name: "First answer mints the database",
      text: "The first request provisions a real Postgres database in the user's anonymous-mode tenant. The schema is inferred from the goal; subsequent goals reuse the same DB.",
    },
    {
      "@type": "HowToStep",
      name: "Adopt to keep it past 72 hours",
      text: "Anonymous databases auto-sweep after 72 hours unless adopted. Sign in and click 'Adopt this database' to re-key it to your account with no data loss.",
    },
  ],
};

const breadcrumbLd = breadcrumbJsonLd(
  [
    { name: "Home", path: "/" },
    { name: "Solve", path: "/solve" },
    { name: s.searchTitle, path: canonical },
  ],
  Astro.site,
);
---
<Base
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={ogImage ? ogImageAlt : undefined}
>
  <div class="page">
    <Topnav current="solve" />

    <main class="slv">
      <nav class="slv__crumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/solve">Solve</a></li>
          <li aria-current="page">{s.searchTitle}</li>
        </ol>
      </nav>

      {/* Beat 1 — Hero. One-line problem statement. */}
      <header class="slv__head">
        <p class="slv__eyebrow">Solve · {SOLVE_PERSONAS[s.persona].label}</p>
        <h1 class="slv__title">{s.searchTitle}</h1>
        <p class="slv__lede">{s.oneLiner}</p>
        <p class="slv__context">{s.painContext}</p>
      </header>

      {/* Beat 2 — Demo. The snippet that solves it, side-by-side. */}
      <section class="slv__demo" aria-labelledby="slv-demo-eyebrow">
        <p class="slv__demo-eyebrow" id="slv-demo-eyebrow">The snippet that solves it.</p>
        <p class="slv__demo-goal">
          <span class="slv__demo-arrow">&gt;</span>
          <code>{s.demoGoal}</code>
        </p>

        <div class="slv__demo-pair">
          <article class="slv__demo-card" aria-label="What nlqdb does for this">
            <p class="slv__demo-label">What nlqdb does for this</p>
            <ul class="slv__demo-bullets">
              {s.howNlqdbAnswers.map((b) => <li>{b}</li>)}
            </ul>
          </article>

          <article class="slv__demo-card" aria-label="Embed snippet">
            <p class="slv__demo-label">Drop into any HTML page</p>
            <pre class="slv__demo-snippet"><code>&lt;<span class="slv__demo-tag">nlq-data</span> goal=&quot;{s.demoGoal}&quot;&gt;&lt;/<span class="slv__demo-tag">nlq-data</span>&gt;</code></pre>
            <p class="slv__demo-foot">{s.demoWhy}</p>
            <button
              type="button"
              class="cta slv__try-btn"
              data-try-goal={s.demoGoal}
              data-solve-slug={s.slug}
            >
              Try this query &rarr;
            </button>
          </article>
        </div>
      </section>

      {/* Beat 3 — What this replaces. Strikethrough list. */}
      <section class="slv__replaces" aria-labelledby="slv-replaces-title">
        <p class="slv__replaces-eyebrow">What this replaces</p>
        <h2 class="slv__replaces-title" id="slv-replaces-title">
          What nlqdb doesn't try to do here
        </h2>
        <ul class="slv__strike-list">
          {s.whatItDoesnt.map((b) => <li><span class="slv__strike">{b}</span></li>)}
        </ul>
      </section>

      <section class="slv__faqs" aria-labelledby="slv-faqs-title">
        <h2 class="slv__faqs-title" id="slv-faqs-title">Questions buyers ask</h2>
        <dl>
          {
            s.faqs.map((f) => (
              <div class="slv__faq">
                <dt>{f.q}</dt>
                <dd>{f.a}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <section class="slv__sources" aria-labelledby="slv-sources-title">
        <h2 class="slv__sources-title" id="slv-sources-title">Where this pain shows up in public</h2>
        <p class="slv__sources-lede">
          Enduring discussion hubs where you can verify the theme without
          taking our word for it. We don't quote individual posts; we cite
          search-result and subreddit URLs that stay live as new threads land.
        </p>
        <ul class="slv__sources-list">
          {
            s.sources.map((src) => (
              <li>
                <a href={src.url} rel="nofollow noopener noreferrer" target="_blank">
                  {src.label}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="slv__cta">
        <h2 class="slv__cta-title">Try nlqdb in 30 seconds</h2>
        <p>No sign-in. The anonymous database lasts 72 hours; adopt it with one click if you keep it.</p>
        <a class="cta slv__cta-btn" href="/app/new">Start with a goal &rarr;</a>
        <p class="slv__cta-meta">
          Looking at this from a different angle?{" "}
          <a href="/solve">Browse all solve pages</a>
          {" "}or{" "}
          <a href="/vs">browse competitor comparisons</a>.
        </p>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script>
    // "Try this query" → seed the anonymous-create input via the same
    // `nlqdb_draft` localStorage slot CreateForm rehydrates from
    // (SK-ANON-011), emit a per-slug demand signal (GLOBAL-024), then
    // navigate. No URL param so the goal can't be sniffed from
    // referrer / access logs.
    import { emit } from "../../lib/logsnag";
    import { saveDraft } from "../../lib/prompt-storage";
    document.querySelectorAll<HTMLButtonElement>(".slv__try-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const goal = btn.dataset["tryGoal"] ?? "";
        const slug = btn.dataset["solveSlug"] ?? "";
        if (goal) saveDraft(goal);
        emit("solve.try_query_clicked", { slug, goal });
        location.assign("/app/new");
      });
    });
  </script>
</Base>

<style>
  .slv {
    max-width: var(--bleed);
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) 0;
  }

  .slv__crumbs {
    font-family: var(--mono);
    font-size: var(--t-small);
    margin: 0 0 var(--gap-block);
  }
  .slv__crumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--muted);
  }
  .slv__crumbs li + li::before {
    content: "/";
    margin-right: 8px;
    opacity: 0.6;
  }
  .slv__crumbs a {
    color: var(--muted);
    text-decoration: none;
  }
  .slv__crumbs a:hover {
    color: var(--ink);
  }
  .slv__crumbs [aria-current="page"] {
    color: var(--ink);
  }

  /* Beat 1 — Hero. One-line problem statement, display-serif title. */
  .slv__head {
    max-width: var(--col);
    margin: 0 0 var(--gap-beat);
  }
  .slv__eyebrow {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .slv__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
  }
  .slv__lede {
    margin: 0 0 20px;
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.5;
    max-width: 60ch;
    text-wrap: balance;
  }
  .slv__context {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--muted);
    line-height: 1.6;
    max-width: 60ch;
  }

  /* Beat 2 — Demo. Mirrors the homepage Demo block + /vs treatment:
     two cards on --raised, --rule border, --ground snippet ground,
     lime tag-highlight on the `<nlq-data>` identifier only. */
  .slv__demo {
    margin: 0 0 var(--gap-beat);
    max-width: var(--bleed);
  }
  .slv__demo-eyebrow {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .slv__demo-goal {
    margin: 0 0 clamp(20px, 3vw, 32px);
    font-family: var(--mono);
    font-size: var(--t-large);
    color: var(--ink);
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .slv__demo-goal code {
    font-family: inherit;
  }
  .slv__demo-arrow {
    color: var(--muted);
    font-weight: 700;
  }
  .slv__demo-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: stretch;
  }
  @media (min-width: 880px) {
    .slv__demo-pair {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }
  .slv__demo-card {
    margin: 0;
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .slv__demo-label {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .slv__demo-bullets {
    margin: 0;
    padding-left: 20px;
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.55;
  }
  .slv__demo-bullets li + li {
    margin-top: 10px;
  }
  .slv__demo-snippet {
    margin: 0;
    padding: 18px;
    background: var(--ground);
    border: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--body);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .slv__demo-snippet code {
    font-family: inherit;
  }
  /* The lime moment for this page — only the tag identifier glows. */
  .slv__demo-tag {
    color: var(--accent);
    font-weight: 600;
  }
  .slv__demo-foot {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.55;
  }
  .slv__try-btn {
    align-self: flex-start;
    margin-top: auto;
  }

  /* Beat 3 — What this replaces. Strikethrough list, editorial. */
  .slv__replaces {
    margin: 0 0 var(--gap-beat);
    max-width: var(--col);
  }
  .slv__replaces-eyebrow {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .slv__replaces-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 clamp(20px, 3vw, 32px);
    text-wrap: balance;
  }
  .slv__strike-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 14px;
  }
  .slv__strike-list li {
    font-family: var(--sans);
    font-size: var(--t-body);
    color: var(--body);
    line-height: 1.55;
    padding-left: 20px;
    position: relative;
  }
  .slv__strike-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--muted);
  }
  .slv__strike {
    color: var(--muted);
    text-decoration: line-through;
    text-decoration-color: var(--rule);
    text-decoration-thickness: 1px;
  }

  /* FAQs — boring is the goal. Display serif Q, sans A, hairline rules. */
  .slv__faqs {
    margin: 0 0 var(--gap-beat);
    max-width: var(--col);
  }
  .slv__faqs-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 clamp(20px, 3vw, 32px);
  }
  .slv__faqs dl {
    margin: 0;
  }
  .slv__faq {
    padding: 20px 0;
    border-bottom: 1px solid var(--rule);
  }
  .slv__faq:last-child {
    border-bottom: none;
  }
  .slv__faq dt {
    font-family: var(--display);
    font-weight: 600;
    font-size: var(--t-large);
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .slv__faq dd {
    margin: 0;
    font-family: var(--sans);
    color: var(--body);
    font-size: var(--t-body);
    line-height: 1.6;
  }

  /* Sources — quiet evidence trail. */
  .slv__sources {
    margin: 0 0 var(--gap-beat);
    max-width: var(--col);
  }
  .slv__sources-title {
    font-family: var(--display);
    font-size: var(--t-large);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .slv__sources-lede {
    font-family: var(--sans);
    color: var(--muted);
    font-size: var(--t-small);
    margin: 0 0 16px;
    max-width: 60ch;
    line-height: 1.55;
  }
  .slv__sources-list {
    margin: 0;
    padding-left: 20px;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--body);
    line-height: 1.55;
  }
  .slv__sources-list li + li {
    margin-top: 8px;
  }
  .slv__sources-list a {
    color: var(--body);
  }
  .slv__sources-list a:hover {
    color: var(--ink);
  }

  /* Final CTA — quiet card, the .cta primitive does the lime moment. */
  .slv__cta {
    padding: clamp(28px, 4vw, 40px);
    background: var(--raised);
    border: 1px solid var(--rule);
    max-width: var(--col);
  }
  .slv__cta-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .slv__cta p {
    font-family: var(--sans);
    color: var(--body);
    margin: 0 0 20px;
    font-size: var(--t-body);
  }
  .slv__cta-btn {
    padding: 16px 28px;
  }
  .slv__cta-meta {
    margin: 20px 0 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }
  .slv__cta-meta a {
    color: var(--body);
  }
  .slv__cta-meta a:hover {
    color: var(--ink);
  }
</style>
