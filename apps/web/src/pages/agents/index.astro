---
// `/agents` — the agent-memory-specific mirror of the homepage
// (redesign-plan §5 `/agents`, SK-WEB-015). Same three-beat rhythm
// as `/`: HERO → DEMO → REPLACEMENT. The hero ships one input
// pre-seeded with an agent-memory goal (SK-WEB-002 honored — one
// input, no signup wall). The demo shows an MCP `nlqdb_remember` +
// `nlqdb_recall` tool-call pair with the resulting SQL and answer,
// side-by-side like the homepage's `<Demo>`. The replacement block
// reuses the editorial-serif strikethrough vocabulary from
// `<Replaces>` but lists what this kills for agent builders:
// vector store top-k, per-agent SQLite, embedding cache.
//
// The `AgentMemoryMatrix` (the four-up Mem0/Zep/Letta/nlqdb
// capability table) sits inside beat 2 as visual evidence of the
// "memory you can GROUP BY" claim — restyled inline against the new
// token system. The FAQPage JSON-LD is kept for AEO (rich results /
// answer-engine extraction) — every answer restates a claim already
// made visibly on the page, so the structured data stays honest
// (SK-PIVOT-004, Google FAQPage policy).
//
// Agent-memory pivot reading (docs/features/agent-memory-pivot/):
// GLOBAL-036 + WS-07 (this page) + WS-13/SK-PIVOT-013 (pivot copy).
// The MCP connector path (paste the URL into Claude / Cursor / Codex)
// is the real agent-builder action; the browser-try fallback is a
// secondary link below the final CTA.

import AgentMemoryMatrix from "../../components/AgentMemoryMatrix.astro";
import CreateForm from "../../components/CreateForm.tsx";
import Cta from "../../components/Cta.astro";
import Footer from "../../components/Footer.astro";
import McpInstall from "../../components/McpInstall.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";
import { faqPageJsonLd } from "../../lib/faq-jsonld";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";

// The hero input is pre-seeded with an agent-memory goal — the
// analytical-over-memory wedge (a GROUP BY a vector store can't run).
// An inline script writes this into the `nlqdb_draft` localStorage
// slot before the `<CreateForm>` island hydrates, so `loadDraft()`
// rehydrates the textarea on first paint. (SK-ANON-011 — same slot
// CreateForm reads from after a refresh.)
const heroGoal = "agents that remember feedback per user, ranked by count this month";

// The MCP connector config the agent builder pastes into their host
// (Claude Desktop, Cursor, Codex, Zed, Windsurf). Hosted server, OAuth
// on the first tool call, no key wired up front.
const mcpConfig = `{
  "mcpServers": {
    "nlqdb": { "url": "https://mcp.nlqdb.com/mcp" }
  }
}`;

// The DEMO block — an `nlqdb_remember` / `nlqdb_recall` MCP tool call
// pair, the compiled SQL, and the answer rows. Rendered from a fixture
// through the same typed-plan compile shape the product runs (NOT a
// live `/v1/ask` call — the proof stays server-rendered so it's
// crawlable / AEO-friendly and works with no JS, SK-PIVOT-004).
const rememberCall = `nlqdb_remember({
  category: "user_preference",
  content: "prefers concise replies",
  user_id: "u_412"
})`;
const rememberResult = `→ { id: 4129, ok: true }`;

const recallCall = `nlqdb_recall({
  question: "feedback per user, ranked by count this month"
})`;

const recallSql = `SELECT user_id, COUNT(*) AS feedback
  FROM agent_memory
 WHERE category = 'user_preference'
   AND created_at >= date_trunc('month', now())
 GROUP BY user_id
 ORDER BY feedback DESC;`;

const recallRows = [
  { user_id: "u_412", feedback: 14 },
  { user_id: "u_207", feedback: 9 },
  { user_id: "u_388", feedback: 6 },
  { user_id: "u_104", feedback: 4 },
  { user_id: "u_551", feedback: 2 },
];

// What this kills for agent builders — the third beat, editorial-serif
// strikethrough vocabulary from `<Replaces>`.
const replaces = [
  "Vector store top-k",
  "Per-agent SQLite",
  "Embedding cache",
  "Schema design",
  "Re-rank pipeline",
];

const faqs = [
  {
    q: "What is analytical memory for an AI agent?",
    a: "A real, queryable database an agent uses to remember — typed rows it can GROUP BY, JOIN, and aggregate over in plain English, not an opaque vector blob it can only search. Recall is table stakes; analysis over memory is the part a vector store structurally can't do.",
  },
  {
    q: "How is this different from a vector store or vector database for agent memory?",
    a: "A vector store returns the top-k most similar chunks — semantic recall with no query planner, so rollups become the model doing arithmetic over search hits. nlqdb stores typed rows in Postgres, so it answers “how many times did this user ask about pricing this month?” with one GROUP BY.",
  },
  {
    q: "Does my agent have to design a database schema first?",
    a: "No. The database is created from a goal, not a schema. Your agent writes typed rows as it learns and asks questions in English; nlqdb provisions the Postgres database and infers the shape.",
  },
  {
    q: "Is it safe to let an AI agent write SQL against its memory?",
    a: "The LLM never emits SQL. It returns a typed JSON plan; nlqdb's compiler emits parameterised SQL, an AST re-parse checks it against a verb and table allow-list, and destructive writes show a diff you confirm first — and every query returns the exact SQL it ran.",
  },
  {
    q: "Can my agent run similarity or vector recall too?",
    a: "Similarity search over an embedding column (pgvector) is an opt-in slice still landing. Today the wedge is the analytical side — the GROUP BY, JOIN, and per-group aggregate queries a vector store can't run.",
  },
  {
    q: "What does it cost, and can I use my own LLM key?",
    a: "Bring your own Anthropic, OpenAI, Gemini, or OpenRouter key at 0% markup on the free tier — no card, no per-call fees. The engine, CLI, MCP server, and SDKs are source-available under FSL-1.1 and self-hostable for any non-competing use.",
  },
];

const faqJsonLd = faqPageJsonLd(faqs);
---

<Base
  title="Analytical memory for AI agents — nlqdb"
  description="Memory your agents can GROUP BY. nlqdb gives an AI agent a real Postgres database as memory over MCP — so it can aggregate over what it remembered, not just recall the top-k similar rows a vector store returns."
  canonical="/agents"
  ogImage="/og/agents.png"
  ogImageAlt="GROUP BY your agent's memory — analytical memory for AI agents."
>
  <div class="page">
    <Topnav current="agents" />

    <main>
      {/* BEAT 1 — Hero. Display-serif lede, one sans explainer, one
          input pre-seeded with an agent-memory goal. Lime moment is
          the CreateForm submit. */}
      <section class="hero ag-hero">
        <h1 class="hero__lede">
          Memory your agents can <code class="ag-hero__code">GROUP BY</code>.
        </h1>
        <p class="hero__say">
          Give your agent a real database as its memory — typed rows it writes
          as it learns, queried in English. Not the top-k a vector store returns.
        </p>

        <CreateForm client:load apiBase={apiBase} />

        <p class="ag-hero__meta">
          Pre-loaded with an agent-memory goal — edit it, or paste your own.
        </p>

        {/* SK-WEB-016 — Install affordance lives adjacent to the hero
            CTA on `/agents` (the one venue where MCP install IS the
            on-message next step, not noise). Compact row of four
            host buttons; thin rule above for rhythm without competing
            with the form. SK-WEB-002 honored — form stays the primary
            input above. */}
        <div class="ag-hero__install">
          <McpInstall compact={true} />
        </div>
      </section>

      {/* BEAT 2 — Demo. The MCP tool-call pair (nlqdb_remember +
          nlqdb_recall), the compiled SQL, and the answer rows.
          Side-by-side at ≥880px like the homepage <Demo>. */}
      <section class="ag-demo" aria-labelledby="ag-demo-eyebrow">
        <p class="ag-demo__eyebrow" id="ag-demo-eyebrow">Two MCP tools. One database.</p>
        <h2 class="ag-demo__title">
          Your agent writes a row, then asks a question.
        </h2>
        <p class="ag-demo__lede">
          Over MCP your agent calls
          <code><span class="ag-demo__tag">nlqdb_remember</span></code> to write
          a typed row, then
          <code><span class="ag-demo__tag">nlqdb_recall</span></code> to ask in
          English. nlqdb compiles the question to SQL through a typed-plan
          trust boundary and runs it on Postgres.
        </p>

        <div class="ag-demo__pair">
          <article class="ag-demo__col" aria-label="Remember">
            <p class="ag-demo__col-label">1 · Remember</p>
            <pre class="ag-demo__code"><code>{rememberCall}</code></pre>
            <p class="ag-demo__col-out"><code>{rememberResult}</code></p>
            <p class="ag-demo__col-note">
              The row lands in <code>agent_memory</code> — typed columns, not
              an opaque vector blob.
            </p>
          </article>

          <article class="ag-demo__col" aria-label="Recall">
            <p class="ag-demo__col-label">2 · Recall</p>
            <pre class="ag-demo__code"><code>{recallCall}</code></pre>
            <p class="ag-demo__col-sub">Compiled SQL (the exact statement nlqdb ran):</p>
            <pre class="ag-demo__sql"><code>{recallSql}</code></pre>
          </article>
        </div>

        <div class="ag-demo__result" role="region" aria-label="Recall result">
          <p class="ag-demo__col-label">3 · The answer — one <code>GROUP BY</code></p>
          <div class="ag-demo__tablewrap">
            <table class="ag-demo__table">
              <thead>
                <tr><th>user_id</th><th>feedback</th></tr>
              </thead>
              <tbody>
                {recallRows.map((r) => (
                  <tr><td>{r.user_id}</td><td>{r.feedback}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="ag-demo__honest">
            Rendered from a fixture through the same typed-plan compile path
            the product runs — server-rendered so it stays crawlable and works
            with no JS. Numbers are illustrative.
          </p>
        </div>

        <div class="ag-demo__matrix">
          <AgentMemoryMatrix heading="Recall is table stakes. Only one of these can aggregate." />
        </div>
      </section>

      {/* BEAT 3 — The replacement. Editorial-serif strikethrough list
          of what this kills for agent builders, then one CTA. */}
      <section class="ag-replaces" aria-labelledby="ag-replaces-title">
        <h2 class="ag-replaces__title" id="ag-replaces-title">
          Five boxes&hairsp;&mdash;&hairsp;or one MCP tool.
        </h2>

        <ul class="ag-replaces__list" aria-label="Things your agent no longer needs">
          {
            replaces.map((item, i) => (
              <li class="ag-replaces__item" style={`--i:${i}`}>
                <span class="ag-replaces__strike">{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="ag-replaces__final">
          <code class="ag-replaces__code">
            <span class="ag-replaces__tag">nlqdb_recall</span>(…)
          </code>
        </div>

        <div class="ag-replaces__cta">
          <Cta href="#connect" label="Connect your agent →" />
        </div>
      </section>

      {/* Final connect card — the primary agent-builder action.
          Paste the MCP connector URL into a host, or run the CLI. */}
      <section class="ag-connect" id="connect" aria-labelledby="ag-connect-title">
        <h2 class="ag-connect__title" id="ag-connect-title">Connect over MCP.</h2>
        <p class="ag-connect__lede">
          nlqdb is a hosted MCP server. Add it to Claude, Cursor, Codex, or any
          MCP host — OAuth opens in your browser on the first tool call, no
          key wired up front.
        </p>

        <div class="ag-connect__grid">
          <div class="ag-connect__card ag-connect__card--primary">
            <p class="ag-connect__h">1 · Paste the connector URL</p>
            <p class="ag-connect__note">
              Into your host&rsquo;s MCP config — Claude Desktop, Cursor,
              Codex, Zed, Windsurf.
            </p>
            <pre class="ag-connect__code"><code>{mcpConfig}</code></pre>
            <button type="button" class="cta ag-connect__copy" data-copy-config>
              Copy config
            </button>
          </div>

          <div class="ag-connect__card">
            <p class="ag-connect__h">Or: one command (Claude Code)</p>
            <p class="ag-connect__note">
              One line adds the hosted server; one-click installs for
              Cursor, VS Code, and more on <a href="/integrations/">integrations</a>.
            </p>
            <pre class="ag-connect__code"><code>claude mcp add --transport http nlqdb https://mcp.nlqdb.com/mcp</code></pre>
            <a
              class="cta cta--ghost ag-connect__docs"
              href="https://docs.nlqdb.com/mcp/"
              data-connect-docs
              rel="noopener noreferrer"
              target="_blank"
            >
              Full MCP setup →
            </a>
          </div>
        </div>

        <p class="ag-connect__meta">
          No agent handy?
          <a href="/app/new/" class="ag-connect__try" data-try-goal={heroGoal}>
            Try a query in the browser
          </a>
          — an anonymous database, no sign-in, gone in 72 hours.
        </p>
      </section>

      {/* AEO — visible FAQ block + matching FAQPage JSON-LD. Every
          answer restates an on-page claim. */}
      <section class="ag-faqs" aria-labelledby="ag-faqs-title">
        <h2 class="ag-faqs__title" id="ag-faqs-title">Questions agent builders ask</h2>
        <dl class="ag-faqs__list">
          {
            faqs.map((f) => (
              <div class="ag-faqs__row">
                <dt>{f.q}</dt>
                <dd>{f.a}</dd>
              </div>
            ))
          }
        </dl>
        <p class="ag-faqs__more">
          See the <a href="/vs/">side-by-side comparisons</a> or the
          <a href="/manifesto/#not-title"> manifesto</a>.
        </p>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  {/* Pre-seed the `nlqdb_draft` localStorage slot BEFORE the
      CreateForm React island hydrates, so `loadDraft()` rehydrates
      the textarea with the agent-memory goal on first paint. Only
      writes when the slot is empty — never clobbers a draft the
      visitor was typing on another page. (SK-ANON-011.) */}
  <script is:inline define:vars={{ heroGoal }}>
    try {
      if (!localStorage.getItem("nlqdb_draft")) {
        localStorage.setItem("nlqdb_draft", heroGoal);
      }
    } catch { /* private mode / disabled storage — CreateForm shows the placeholder */ }
  </script>

  <script>
    import { emit } from "../../lib/logsnag";
    import { saveDraft } from "../../lib/prompt-storage";

    // Copy the MCP connector config + fire the connect demand signal
    // (GLOBAL-024). Clipboard failure still fires the signal and
    // leaves the config visible.
    const copyBtn = document.querySelector<HTMLButtonElement>("[data-copy-config]");
    const configCode = document.querySelector<HTMLElement>(
      ".ag-connect__card--primary .ag-connect__code code",
    );
    copyBtn?.addEventListener("click", async () => {
      emit("agents.connect_clicked", { method: "url" });
      try {
        await navigator.clipboard.writeText(configCode?.textContent ?? "");
        const original = copyBtn.textContent;
        copyBtn.textContent = "Copied ✓";
        copyBtn.classList.add("is-copied");
        setTimeout(() => {
          copyBtn.textContent = original;
          copyBtn.classList.remove("is-copied");
        }, 1600);
      } catch {
        /* clipboard blocked — signal already fired, config is selectable */
      }
    });

    // CLI / docs path — fire the signal; the anchor then navigates.
    document
      .querySelector<HTMLAnchorElement>("[data-connect-docs]")
      ?.addEventListener("click", () => emit("agents.connect_clicked", { method: "cli" }));

    // Browser-try fallback — seed the same `nlqdb_draft` slot the
    // CreateForm island reads from, then let the anchor navigate
    // normally (crawlable, no URL param leaking the goal).
    document.querySelectorAll<HTMLAnchorElement>(".ag-connect__try").forEach((a) => {
      a.addEventListener("click", () => {
        const goal = a.dataset["tryGoal"] ?? "";
        if (goal) saveDraft(goal);
        emit("agents.try_query_clicked", { goal });
      });
    });
  </script>
</Base>

<style is:global>
  /* Hero — composes with the global `.hero` chrome. The lime
   * `GROUP BY` literal in the lede is the page's one identifier
   * accent in beat 1; the submit CTA is the page's first earned
   * lime moment (`<CreateForm>` already uses `.cta`). */
  .ag-hero {
    max-width: var(--col);
  }

  .ag-hero__code {
    font-family: var(--mono);
    font-size: 0.78em;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .ag-hero__meta {
    margin: 4px 0 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  /* SK-WEB-016 — Hero-adjacent MCP install affordance. Thin 1px rule
   * separates it from the form without competing visually. The
   * `<McpInstall>` component already owns its own top margin, so we
   * only add the rule + a small breathing gap above. */
  .ag-hero__install {
    margin-top: clamp(24px, 4vw, 36px);
    padding-top: clamp(20px, 3vw, 28px);
    border-top: 1px solid var(--rule);
  }

  /* Demo — beat 2. Side-by-side at ≥880px (matches the homepage
   * `<Demo>` breakpoint), stacked below. Lime is reserved for the
   * `nlqdb_remember` / `nlqdb_recall` identifiers in the lede; the
   * code panels themselves stay ink-on-raised. */
  .ag-demo {
    padding: clamp(64px, 12vw, 120px) 0 clamp(40px, 6vw, 64px);
    max-width: var(--bleed);
  }

  .ag-demo__eyebrow {
    margin: 0 0 clamp(12px, 2vw, 18px);
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ag-demo__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 clamp(16px, 2vw, 20px);
    max-width: 22ch;
    line-height: 1.1;
    text-wrap: balance;
  }

  .ag-demo__lede {
    margin: 0 0 clamp(28px, 4vw, 40px);
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.45;
    max-width: 60ch;
  }

  .ag-demo__lede code,
  .ag-demo__result code,
  .ag-demo__col-note code {
    font-family: var(--mono);
    font-size: 0.9em;
    color: var(--body);
  }

  .ag-demo__tag {
    color: var(--accent);
    font-weight: 600;
  }

  .ag-demo__pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2.5vw, 24px);
    align-items: stretch;
  }

  @media (min-width: 880px) {
    .ag-demo__pair {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  .ag-demo__col {
    margin: 0;
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ag-demo__col-label {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ag-demo__col-sub {
    margin: 4px 0 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  .ag-demo__code,
  .ag-demo__sql {
    margin: 0;
    padding: 14px 16px;
    background: var(--ground);
    border: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.55;
    color: var(--body);
    overflow-x: auto;
    white-space: pre;
  }

  .ag-demo__col-out {
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--body);
  }

  .ag-demo__col-note {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.55;
  }

  .ag-demo__result {
    margin-top: clamp(20px, 3vw, 28px);
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
  }

  .ag-demo__tablewrap {
    margin: 12px 0 14px;
    overflow-x: auto;
  }

  .ag-demo__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 13px;
  }

  .ag-demo__table th {
    text-align: left;
    color: var(--muted);
    font-weight: 400;
    padding: 4px 24px 8px 0;
    border-bottom: 1px solid var(--rule);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
    white-space: nowrap;
  }

  .ag-demo__table td {
    color: var(--body);
    padding: 8px 24px 8px 0;
    border-bottom: 1px solid var(--rule);
    white-space: nowrap;
  }

  .ag-demo__table tbody tr:last-child td {
    border-bottom: none;
  }

  .ag-demo__table td:last-child {
    color: var(--ink);
    font-weight: 600;
  }

  .ag-demo__honest {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.55;
    max-width: 60ch;
  }

  .ag-demo__matrix {
    margin-top: clamp(40px, 6vw, 64px);
  }

  /* Beat 3 — the replacement. Editorial-serif strikethrough list,
   * shape and motion borrowed verbatim from `<Replaces>` (the page's
   * one earned scroll moment lives here, gated on no-preference). */
  .ag-replaces {
    padding: clamp(64px, 12vw, 120px) 0 clamp(48px, 8vw, 80px);
    max-width: var(--col);
    border-top: 1px solid var(--rule);
    margin-top: clamp(40px, 6vw, 80px);
  }

  .ag-replaces__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
    text-wrap: balance;
    max-width: 20ch;
    margin: 0 0 clamp(28px, 4vw, 40px);
  }

  .ag-replaces__list {
    list-style: none;
    margin: 0 0 clamp(36px, 5vw, 56px);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ag-replaces__item {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 400;
    line-height: 1.15;
    color: var(--muted);
    position: relative;
    display: inline-block;
    width: max-content;
    max-width: 100%;
  }

  .ag-replaces__strike {
    position: relative;
    display: inline-block;
  }

  /* The page's one earned scroll moment — gated on no-preference,
   * with a static fallback for browsers without `animation-timeline`. */
  @media (prefers-reduced-motion: no-preference) {
    .ag-replaces__strike::after {
      content: "";
      position: absolute;
      top: 52%;
      left: -2px;
      right: -2px;
      height: 3px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left center;
      animation: ag-replaces-strike linear both;
      animation-timeline: view();
      animation-range: entry 30% cover 60%;
      animation-delay: calc(var(--i, 0) * 40ms);
    }

    @keyframes ag-replaces-strike {
      to {
        transform: scaleX(1);
      }
    }

    @supports not (animation-timeline: view()) {
      .ag-replaces__strike::after {
        transform: scaleX(1);
        animation: none;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ag-replaces__strike::after {
      content: "";
      position: absolute;
      top: 52%;
      left: -2px;
      right: -2px;
      height: 3px;
