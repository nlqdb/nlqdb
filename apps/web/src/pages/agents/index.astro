---
import AgentMemoryMatrix from "../../components/AgentMemoryMatrix.astro";
import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

// `/agents` — the dedicated analytical-agent-memory front door
// (GLOBAL-036, agent-memory-pivot WS-07). A new route on nlqdb.com,
// not a new domain. This page is allowed to lead with the agent-memory
// story even though the sitewide lead strings (Hero.astro, README,
// llms.txt) stay gated to WS-13.
//
// Run 1 = skeleton + hero + AEO direct-answer. Run 2 = the WS-06
// capability matrix + the typed-plan-trust-boundary moat + the FSL
// self-host / BYO-key band (FSL-accurate per WS-10). Run 3 (this edit) =
// the conversion CTA — a memory-shaped "try this query" button that
// seeds the anonymous-create draft and fires the GLOBAL-024
// demand-signal event, mirroring the proven /vs + /solve pattern.

// Memory-shaped demo goal — the analytical-over-memory wedge (a GROUP BY
// a vector store can't run). Mirrors the /solve analytical sibling so the
// seeded draft lands the agent-builder on the read-side story.
const demoGoal = "Count of facts my agent logged per category this month, highest first";

// WS-09 — the live in-page demo. Rendered from a fixture through the same
// typed-plan compile path the product runs, NOT an open `/v1/ask` (the
// public API is pre-alpha gated — gate-honest per the worksheet). It shows
// the wedge end to end: typed memory rows the agent wrote → the English
// question → the compiled, parameterised SQL → the GROUP BY answer a vector
// store structurally can't return. Type + brand tables only, no screenshot
// or produced video (SK-PIVOT-004). Everything renders server-side so the
// proof is crawlable (AEO) and works with no JS; the button only replays a
// pulse + fires the GLOBAL-024 demand signal.
const demoMemoryRows = [
  {
    id: 412,
    category: "user_preference",
    content: "prefers metric units",
    created_at: "2026-06-19",
  },
  {
    id: 408,
    category: "task_outcome",
    content: "shipped the invoice export",
    created_at: "2026-06-18",
  },
  {
    id: 401,
    category: "user_preference",
    content: "timezone is Asia/Jerusalem",
    created_at: "2026-06-17",
  },
  {
    id: 396,
    category: "entity_fact",
    content: "primary repo is nlqdb/nlqdb",
    created_at: "2026-06-15",
  },
  {
    id: 390,
    category: "task_outcome",
    content: "fixed the flaky e2e test",
    created_at: "2026-06-14",
  },
];
const demoSql = `SELECT category, COUNT(*) AS facts
  FROM agent_memory
 WHERE created_at >= date_trunc('month', now())
 GROUP BY category
 ORDER BY facts DESC;`;
const demoResult = [
  { category: "user_preference", facts: 38 },
  { category: "task_outcome", facts: 24 },
  { category: "entity_fact", facts: 19 },
  { category: "tool_result", facts: 11 },
  { category: "correction", facts: 5 },
];
---

<Base
  title="Analytical memory for AI agents — nlqdb"
  description="Memory your AI agent can query. nlqdb gives an agent a real Postgres database as memory — so it can GROUP BY, JOIN, and aggregate over what it remembered, not just recall the top-k similar rows a vector store returns."
  canonical="/agents"
  ogImage="/og/agents.png"
  ogImageAlt="GROUP BY your agent's memory — analytical memory for AI agents."
>
  <div class="page">
    <Topnav current="agents" />

    <main class="agents">
      <header class="agents__head">
        <p class="agents__kicker">For AI agents</p>
        <h1 class="agents__title">Memory your agent can query.</h1>
        <p class="agents__lede">
          Give your AI agent a real database as its memory &mdash; created from
          a goal, not a schema. It writes typed rows as it learns, and later
          runs actual SQL over them: counts, top-N, averages per group.
        </p>
        <p class="agents__sub">
          A vector store returns the <em>k</em> most similar chunks. It can
          recall, but it can&rsquo;t answer &ldquo;how many times did this user
          ask about pricing this month?&rdquo; &mdash; that&rsquo;s a
          <code>GROUP BY</code>, and a similarity index has no query planner.
          nlqdb does, because the memory <em>is</em> a database.
        </p>
      </header>

      <section class="agents__answer" aria-label="Direct answer">
        <p>
          <strong>What is analytical agent memory?</strong> A real, queryable
          database an agent uses to remember &mdash; typed rows it can
          <code>GROUP BY</code>, <code>JOIN</code>, and aggregate over in plain
          English, not an opaque vector blob it can only search. The agent asks
          in natural language; nlqdb compiles the question to SQL through a
          typed-plan trust boundary, runs it on Postgres, and returns rows plus
          the exact SQL it ran. Recall is table stakes &mdash; <em>analysis</em>
          over memory is the part a vector store structurally can&rsquo;t do.
        </p>
      </section>

      <section class="agents__split" aria-labelledby="split-title">
        <h2 class="agents__h2" id="split-title">Retrieval is not analytics.</h2>
        <div class="agents__cols">
          <div class="agents__col">
            <p class="agents__col-h">A vector store gives your agent</p>
            <ul>
              <li>top-<em>k</em> similar chunks for a query</li>
              <li>semantic recall of past text</li>
              <li>no query planner &mdash; rollups become the model doing
                arithmetic over search hits</li>
            </ul>
          </div>
          <div class="agents__col agents__col--us">
            <p class="agents__col-h">nlqdb gives your agent</p>
            <ul>
              <li>the same recall <em>plus</em> real SQL over its memory</li>
              <li><code>GROUP BY</code> / <code>JOIN</code> / <code>HAVING</code>,
                top-N, per-period &mdash; run in Postgres</li>
              <li>the SQL it ran, every time &mdash; auditable, not a black box</li>
            </ul>
          </div>
        </div>
        <p class="agents__honest">
          Honest scope: similarity search over an <code>embedding</code> column
          (pgvector) is an opt-in slice still landing &mdash; today the wedge is
          the analytical side. nlqdb is a database, not a vector store
          (<a href="/manifesto#not-title">manifesto</a>).
        </p>
      </section>

      <section class="agents__demo" aria-labelledby="demo-title">
        <h2 class="agents__h2" id="demo-title">See it: a <code>GROUP BY</code> over agent memory.</h2>
        <p class="agents__demo-lede">
          Your agent writes typed rows as it learns. Later it asks a question
          in English &mdash; nlqdb compiles it to SQL through the typed-plan
          boundary and runs it on Postgres. Here is the whole round-trip.
        </p>

        <ol class="agents__demo-steps">
          <li class="agents__demo-step">
            <p class="agents__demo-label">1 &middot; What the agent remembered &mdash; <code>agent_memory</code></p>
            <div class="agents__demo-tablewrap">
              <table class="agents__demo-table">
                <thead>
                  <tr><th>id</th><th>category</th><th>content</th><th>created_at</th></tr>
                </thead>
                <tbody>
                  {demoMemoryRows.map((r) => (
                    <tr>
                      <td>{r.id}</td>
                      <td>{r.category}</td>
                      <td>{r.content}</td>
                      <td>{r.created_at}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="agents__demo-note">Typed rows, not an opaque vector blob &mdash; 412 facts and counting.</p>
          </li>

          <li class="agents__demo-step">
            <p class="agents__demo-label">2 &middot; The question, in English</p>
            <p class="agents__demo-goal">&ldquo;{demoGoal}&rdquo;</p>
            <button type="button" class="agents__demo-run" data-demo-goal={demoGoal}>
              Run this query &rarr;
            </button>
            <p class="agents__demo-label agents__demo-label--sql">Compiled SQL (the exact statement nlqdb ran)</p>
            <pre class="agents__demo-sql"><code>{demoSql}</code></pre>
          </li>

          <li class="agents__demo-step">
            <p class="agents__demo-label">3 &middot; The answer &mdash; one <code>GROUP BY</code>, run in Postgres</p>
            <div class="agents__demo-tablewrap" data-demo-result>
              <table class="agents__demo-table agents__demo-table--result">
                <thead>
                  <tr><th>category</th><th>facts</th></tr>
                </thead>
                <tbody>
                  {demoResult.map((r) => (
                    <tr><td>{r.category}</td><td>{r.facts}</td></tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="agents__demo-note">
              A vector store would return the rows most <em>similar</em> to your
              query text. It can&rsquo;t count them per category &mdash; that
              needs a query planner, which an index doesn&rsquo;t have.
            </p>
          </li>
        </ol>

        <p class="agents__demo-honest">
          Rendered from a fixture through the same typed-plan compile path the
          product runs &mdash; the public demo doesn&rsquo;t hit an open
          <code>/v1/ask</code> (pre-alpha). Numbers are illustrative.
        </p>
      </section>

      <section class="agents__matrix" aria-label="Capability matrix">
        <AgentMemoryMatrix
          heading="What can your agent actually DO with its memory?"
        />
      </section>

      <section class="agents__moat" aria-labelledby="moat-title">
        <h2 class="agents__h2" id="moat-title">The moat: a typed-plan trust boundary.</h2>
        <p class="agents__moat-lede">
          Letting an agent write SQL against your database is how a coding
          agent <a
            href="https://fortune.com/2025/07/23/ai-coding-tool-replit-wiped-database-called-it-a-catastrophic-failure/"
            rel="nofollow noopener noreferrer" target="_blank">wiped a production
            database</a> during a code freeze
          with three guardrails active. So in nlqdb the LLM never emits SQL.
        </p>
        <ol class="agents__pipeline">
          <li>
            <span class="agents__step">LLM &rarr; typed JSON plan</span>
            The model picks <em>structure</em> &mdash; tables, filters,
            aggregates &mdash; and returns it as a typed plan, not a SQL string.
          </li>
          <li>
            <span class="agents__step">compiler &rarr; parameterised SQL</span>
            nlqdb&rsquo;s code emits the SQL. Every value is a bound parameter;
            identifiers come only from the schema allow-list.
          </li>
          <li>
            <span class="agents__step">AST re-parse &rarr; allowlist</span>
            A SQL parser re-parses the compiled statement and checks it
            against a verb + table allowlist before it touches your data
            (the create path re-parses with the real Postgres parser,
            <code>libpg_query</code>).
          </li>
          <li>
            <span class="agents__step">diff preview &rarr; confirm</span>
            Destructive writes and schema changes show a diff you confirm
            first &mdash; and the exact SQL is returned in the trace, every time.
          </li>
        </ol>
        <p class="agents__moat-source">
          Same logic Snowflake&rsquo;s Cortex Analyst uses to hit <a
            href="https://www.snowflake.com/en/engineering-blog/cortex-analyst-text-to-sql-accuracy-bi/"
            rel="nofollow noopener noreferrer" target="_blank">~2&times;
            single-prompt accuracy</a>: the model picks
          from a curated structure instead of writing raw SQL.
        </p>
      </section>

      <section class="agents__fsl" aria-labelledby="fsl-title">
        <h2 class="agents__h2" id="fsl-title">Your key, your infra, no per-call fees.</h2>
        <ul class="agents__fsl-list">
          <li>
            <strong>BYO LLM at 0% markup.</strong> Paste an Anthropic, OpenAI,
            Gemini, or OpenRouter key &mdash; your agent&rsquo;s memory routes
            through it with no markup, on the free tier, no card.
          </li>
          <li>
            <strong>Source-available, self-hostable.</strong> The engine, CLI,
            MCP server, and SDKs are under <a
              href="https://github.com/nlqdb/nlqdb/blob/main/LICENSE"
              rel="noopener noreferrer" target="_blank">FSL-1.1-ALv2</a>
            &mdash; yours to read, fork, and self-host for any non-competing use.
            It auto-converts to Apache&nbsp;2.0 two years after each release.
          </li>
          <li>
            <strong>No per-call fees, no &ldquo;contact sales.&rdquo;</strong>
            Memory you can query shouldn&rsquo;t meter every recall.
          </li>
        </ul>
      </section>

      <section class="agents__cta" aria-labelledby="cta-title">
        <h2 class="agents__h2" id="cta-title">Give your agent memory it can query.</h2>
        <p class="agents__cta-lede">
          Start from a goal, not a schema. nlqdb provisions the database,
          your agent writes typed rows as it learns, and you ask in English.
        </p>
        <button
          type="button"
          class="agents__try-btn"
          data-try-goal={demoGoal}
        >
          Try: &ldquo;{demoGoal}&rdquo; &rarr;
        </button>
        <p class="agents__cta-meta">
          No sign-in. The anonymous database lasts 72 hours; adopt it with one
          click if you keep it. Or <a href="/app/new">start with your own goal</a>.
        </p>
      </section>

      <p class="agents__more">
        See the <a href="/vs">side-by-side comparisons</a> or the
        <a href="/manifesto#not-title">manifesto</a>.
      </p>
    </main>

    <Footer />
  </div>

  <script>
    // "Try this query" → seed the anonymous-create input via the same
    // `nlqdb_draft` localStorage slot CreateForm rehydrates from
    // (SK-ANON-011), emit the GLOBAL-024 demand signal, then navigate.
    // No URL param so the goal can't be sniffed from referrer / logs —
    // mirrors the /vs + /solve "try this query" pattern exactly.
    import { emit } from "../../lib/logsnag";
    import { saveDraft } from "../../lib/prompt-storage";
    document.querySelectorAll<HTMLButtonElement>(".agents__try-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const goal = btn.dataset["tryGoal"] ?? "";
        if (goal) saveDraft(goal);
        emit("agents.try_query_clicked", { goal });
        location.assign("/app/new");
      });
    });

    // WS-09 demo "Run this query" — gate-honest replay: the result is already
    // on the page (crawlable, no-JS), so the button just pulses the result
    // table and fires the GLOBAL-024 demand signal for demo engagement. No
    // network call — the public demo never hits an open `/v1/ask`.
    const demoResultEl = document.querySelector<HTMLElement>("[data-demo-result]");
    document.querySelectorAll<HTMLButtonElement>(".agents__demo-run").forEach((btn) => {
      btn.addEventListener("click", () => {
        emit("agents.demo_run_clicked", { goal: btn.dataset["demoGoal"] ?? "" });
        if (demoResultEl) {
          demoResultEl.classList.remove("is-ran");
          void demoResultEl.offsetWidth; // restart the CSS animation
          demoResultEl.classList.add("is-ran");
        }
      });
    });
  </script>
</Base>

<style is:global>
  .agents {
    padding: clamp(48px, 8vw, 96px) 0 clamp(48px, 6vw, 80px);
    max-width: 820px;
    margin: 0 auto;
  }

  .agents__head {
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .agents__kicker {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .agents__title {
    font-size: clamp(40px, 7vw, 72px);
    letter-spacing: -0.03em;
    line-height: 0.96;
    margin: 0 0 24px;
  }

  .agents__lede {
    font-family: var(--mono);
    font-size: clamp(16px, 2vw, 19px);
    color: var(--fg);
    margin: 0 0 16px;
    line-height: 1.5;
    max-width: 60ch;
  }

  .agents__sub {
    margin: 0;
    color: var(--fg-dim);
    font-size: clamp(15px, 1.7vw, 17px);
    max-width: 64ch;
    line-height: 1.6;
  }

  .agents__sub code,
  .agents__answer code,
  .agents__col code,
  .agents__honest code,
  .agents__pipeline code {
    font-family: var(--mono);
    font-size: 0.9em;
    color: var(--fg);
  }

  .agents__answer {
    margin: 0 0 clamp(32px, 5vw, 48px);
    padding: clamp(20px, 3vw, 28px);
    border: 2px solid var(--accent);
    background: var(--bg-elev);
    font-size: clamp(15px, 1.6vw, 16px);
    color: var(--fg);
    line-height: 1.6;
  }

  .agents__answer p {
    margin: 0;
  }

  .agents__answer strong {
    color: var(--accent);
    font-weight: 700;
  }

  .agents__h2 {
    font-family: var(--mono);
    font-size: clamp(20px, 3vw, 28px);
    letter-spacing: -0.02em;
    margin: 0 0 20px;
  }

  .agents__split {
    margin: 0 0 clamp(32px, 5vw, 48px);
  }

  .agents__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .agents__col {
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    padding: clamp(18px, 2.6vw, 24px);
  }

  .agents__col--us {
    border-color: var(--accent);
    box-shadow: var(--shadow-hard-accent);
  }

  .agents__col-h {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .agents__col ul {
    margin: 0;
    padding-left: 1.1em;
    display: grid;
    gap: 8px;
  }

  .agents__col li {
    color: var(--fg-dim);
    font-size: clamp(14px, 1.6vw, 15px);
    line-height: 1.5;
  }

  .agents__col--us li {
    color: var(--fg);
  }

  .agents__honest {
    margin: 16px 0 0;
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .agents__honest a,
  .agents__more a {
    color: var(--accent);
  }

  .agents__matrix,
  .agents__moat,
  .agents__fsl,
  .agents__demo {
    margin: 0 0 clamp(32px, 5vw, 48px);
  }

  .agents__demo-lede {
    margin: 0 0 24px;
    color: var(--fg-dim);
    font-size: clamp(15px, 1.7vw, 17px);
    max-width: 64ch;
    line-height: 1.6;
  }

  .agents__demo code {
    font-family: var(--mono);
    font-size: 0.9em;
    color: var(--fg);
  }

  .agents__demo-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 16px;
  }

  .agents__demo-step {
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    padding: clamp(16px, 2.4vw, 22px);
  }

  .agents__demo-label {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .agents__demo-label--sql {
    margin-top: 20px;
  }

  .agents__demo-tablewrap {
    overflow-x: auto;
  }

  .agents__demo-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: clamp(12px, 1.4vw, 13px);
  }

  .agents__demo-table th {
    text-align: left;
    color: var(--fg-muted);
    font-weight: 400;
    padding: 4px 16px 8px 0;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .agents__demo-table td {
    color: var(--fg-dim);
    padding: 6px 16px 6px 0;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .agents__demo-table--result td:last-child {
    color: var(--accent);
    font-weight: 700;
  }

  .agents__demo-note {
    margin: 12px 0 0;
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.55;
  }

  .agents__demo-goal {
    margin: 0 0 16px;
    font-size: clamp(15px, 1.7vw, 17px);
    color: var(--fg);
    line-height: 1.5;
  }

  .agents__demo-run {
    appearance: none;
    cursor: pointer;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--accent);
    background: transparent;
    border: 2px solid var(--accent);
    padding: 8px 16px;
    line-height: 1.4;
  }

  .agents__demo-run:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .agents__demo-sql {
    margin: 0;
    padding: clamp(14px, 2vw, 18px);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    overflow-x: auto;
  }

  .agents__demo-sql code {
    font-family: var(--mono);
    font-size: clamp(12px, 1.4vw, 13px);
    color: var(--fg);
    white-space: pre;
  }

  .agents__demo-tablewrap.is-ran {
    animation: agents-demo-pulse 0.6s ease-out;
  }

  @keyframes agents-demo-pulse {
    0% { box-shadow: 0 0 0 0 var(--accent); }
    100% { box-shadow: 0 0 0 6px transparent; }
  }

  @media (prefers-reduced-motion: reduce) {
    .agents__demo-tablewrap.is-ran {
      animation: none;
    }
  }

  .agents__demo-honest {
    margin: 16px 0 0;
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .agents__demo-honest code {
    font-size: 0.9em;
  }

  .agents__moat-lede {
    margin: 0 0 24px;
    color: var(--fg-dim);
    font-size: clamp(15px, 1.7vw, 17px);
    max-width: 64ch;
    line-height: 1.6;
  }

  .agents__moat-lede a,
  .agents__moat-source a,
  .agents__fsl a {
    color: var(--accent);
  }

  .agents__pipeline {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
    counter-reset: step;
  }

  .agents__pipeline li {
    counter-increment: step;
    border-left: 2px solid var(--accent);
    padding: 0 0 0 16px;
    color: var(--fg-dim);
    font-size: clamp(14px, 1.6vw, 15px);
    line-height: 1.55;
  }

  .agents__pipeline li::before {
    content: counter(step);
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    margin-right: 8px;
  }

  .agents__step {
    display: inline;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg);
    margin-right: 8px;
  }

  .agents__moat-source {
    margin: 20px 0 0;
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .agents__fsl-list {
    margin: 0;
    padding-left: 1.1em;
    display: grid;
    gap: 12px;
  }

  .agents__fsl-list li {
    color: var(--fg-dim);
    font-size: clamp(14px, 1.6vw, 15px);
    line-height: 1.55;
  }

  .agents__fsl-list strong {
    color: var(--fg);
  }

  .agents__cta {
    margin: 0 0 clamp(32px, 5vw, 48px);
    padding: clamp(24px, 3.5vw, 36px);
    border: 2px solid var(--accent);
    background: var(--bg-elev);
    box-shadow: var(--shadow-hard-accent);
  }

  .agents__cta-lede {
