---
// Magic-link prefetch protection (DESIGN §4.3 — magic-link UX).
//
// Email scanners (Outlook SafeLinks, Gmail's link checker, MS Defender)
// GET URLs from inbound emails before the user clicks. Better Auth's
// `/api/auth/magic-link/verify?token=…` consumes the token on GET, so
// a passive scanner burns it. We rewrite the email URL to point here:
// a static page that requires a user click to actually navigate to the
// verify endpoint.
//
// `?next=<url-encoded verify URL>` carries the original target. The
// button's href is the decoded next; passive scanners would have to
// follow that anchor too, but most stop at the first hop.

import Base from "../../layouts/Base.astro";

const params = Astro.url.searchParams;
const nextRaw = params.get("next") ?? "";
let nextSafe = "";
let nextHostMatches = false;
try {
  const parsed = new URL(nextRaw);
  // Accept https://app.nlqdb.com (production) and any localhost (dev).
  // Anything else is a tampering attempt or scanner mischief — render
  // the error state and let the user request a fresh link.
  if (
    parsed.protocol === "https:" &&
    (parsed.host === "app.nlqdb.com" || parsed.hostname === "localhost")
  ) {
    nextSafe = parsed.toString();
    nextHostMatches = true;
  } else if (parsed.protocol === "http:" && parsed.hostname === "localhost") {
    nextSafe = parsed.toString();
    nextHostMatches = true;
  }
} catch {
  // nextRaw wasn't a URL; nextSafe stays empty.
}
---
<Base
  title="Continue sign-in — nlqdb"
  description="One more click to sign in to nlqdb."
>
  <div class="page">
    <header class="topnav">
      <a class="topnav__brand" href="/">nlqdb</a>
    </header>

    <main class="signin">
      {nextHostMatches ? (
        <>
          <h1 class="signin__title">One more click</h1>
          <p class="signin__lede">
            We added a tap-to-confirm step to keep email security scanners from
            burning the link before you can use it. Tap below to sign in.
          </p>
          <a class="btn btn--accent signin__submit" href={nextSafe}>Continue sign-in &rarr;</a>
        </>
      ) : (
        <>
          <h1 class="signin__title">Link unrecognised</h1>
          <p class="signin__lede">
            We can't verify this sign-in link. Request a fresh one from the
            <a href="/sign-in" class="signin__link">sign-in page</a>.
          </p>
        </>
      )}
    </main>
  </div>
</Base>

<style>
  .signin {
    max-width: 480px;
    margin: 0 auto;
    padding: clamp(48px, 10vw, 96px) 0;
  }
  .signin__title {
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin: 0 0 12px;
  }
  .signin__lede {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--fg-dim);
    margin: 0 0 32px;
    line-height: 1.6;
  }
  .signin__submit {
    justify-content: center;
  }
  .signin__link {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
