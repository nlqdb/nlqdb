---
import Base from "../../layouts/Base.astro";

// Post-signin landing page (SK-ANON-012, SK-ANON-014).
//
// `callbackURL` from `sign-in.astro` points here. The inline script:
//   1. Probes `/api/auth/get-session` to confirm the cookie session
//      landed. If null, sends the user back to sign-in with a
//      `session_lost` hint.
//   2. Runs defense-in-depth `POST /api/auth/anon-adopt-now` so the
//      anon DB is adopted into the user's tenant even when the Better
//      Auth `after`-middleware adoption hop missed (network blip on
//      `/api/auth/anon-stash`, third-party-cookie partitioning, or a
//      sign-in path that didn't run the stash). Idempotent under
//      `SK-ANON-003`'s `ON CONFLICT DO NOTHING`; bounded with a 3 s
//      timeout so a hanging API never strands the user on the loading
//      page. The response carries `{ adopted, dbId }` (SK-ANON-014) —
//      we capture `dbId` to pin the adopted DB on the next hop.
//   3. Redirects to `next` (default `/app`) with `?db=<dbId>` appended
//      when adoption surfaced a dbId. ChatPanel reads the param
//      synchronously on mount and pins the DB before the LeftRail's
//      `/v1/databases` fetch resolves — no "newest by created_at"
//      heuristic, no flash of "All databases". The `nlqdb_pending`
//      slot is intentionally LEFT IN localStorage so ChatPanel can
//      rehydrate the composer; the user reviews and submits.
//
// Why not auto-POST `/v1/ask`:
//   - Signing in with an existing account preserves the user's
//     pre-existing DBs; auto-submitting would create a new DB they
//     never asked for, separate from the adopted anon DB.
//   - The user typed the goal anonymously; reviewing it under their
//     real identity (and the now-visible left rail of their actual
//     DBs) is the more honest UX.
---
<Base
  title="Signing you in — nlqdb"
  description="Finishing your sign-in."
  canonical="/auth/post-signin"
>
  <div class="page">
    <main class="post-signin">
      <section class="post-signin__card" aria-labelledby="post-signin-title">
        <h1 id="post-signin-title" class="post-signin__title">
          Signing you in…
        </h1>
        <p class="post-signin__lede">
          Bringing you back to your work.
        </p>
      </section>
    </main>
  </div>
</Base>

<script>
  import { fetchSession } from "../../lib/session";

  const params = new URLSearchParams(location.search);
  const next = params.get("next") ?? "/app";
  const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";

  function readAnonBearer(): string | null {
    try {
      const v = window.localStorage.getItem("nlqdb_anon") ?? "";
      return v.startsWith("anon_") ? v : null;
    } catch {
      return null;
    }
  }

  // SK-ANON-012 — defense-in-depth adoption retry. The Better Auth
  // `after`-middleware adoption hop fires only when the
  // `__Secure-anon-bearer` cookie was successfully stashed by
  // `sign-in.astro` BEFORE the OAuth redirect. If that POST
  // missed (network blip, third-party-cookie partitioning on
  // the stash hop, or the user landed here via a path that
  // didn't run the stash), the anon DB stays at `anon:<hash>`
  // and never surfaces in the user's `/v1/databases`. Re-running
  // `anon-adopt-now` here is idempotent (per `SK-ANON-003` the
  // adoption is a one-row update guarded by `ON CONFLICT DO NOTHING`)
  // and runs against the freshly-authed cookie, so it succeeds
  // even when the cookie path missed.
  //
  // SK-ANON-014 — the response carries `{ adopted, dbId }`. We return
  // `dbId` so the caller can append `?db=<id>` to the redirect URL
  // and ChatPanel pins the adopted DB synchronously on mount.
  async function adoptIfNeeded(): Promise<string | null> {
    const anon = readAnonBearer();
    if (!anon) return null;
    // Bounded with an AbortController so a hung API never strands the
    // user on the loading page. Adoption is best-effort; the redirect
    // must not be blocked by it. 3 s matches the typical p99 budget
    // for a D1 single-row update under the workers free tier.
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), 3000);
    try {
      const res = await fetch(`${apiBase}/api/auth/anon-adopt-now`, {
        method: "POST",
        credentials: "include",
        headers: { "x-anon-bearer": anon },
        signal: ac.signal,
      });
      if (!res.ok) return null;
      const body = (await res.json().catch(() => null)) as { dbId?: unknown } | null;
      const dbId = body && typeof body.dbId === "string" ? body.dbId : null;
      return dbId;
    } catch {
      // best-effort — timeout / network / 4xx all fall through here.
      return null;
    } finally {
      clearTimeout(timer);
    }
  }

  // Append `?db=<dbId>` to `next` (SK-ANON-014). `next` may already
  // carry query params; URL parsing preserves them. The redirect base
  // matters — `next` is always same-origin (set server-side by
  // sign-in.astro from `return_to`), so we resolve against the current
  // origin. The `URL` constructor throws on malformed input; a guarded
  // fallback drops the param rather than failing the redirect entirely.
  function withDbId(target: string, dbId: string | null): string {
    if (!dbId) return target;
    try {
      const url = new URL(target, location.origin);
      url.searchParams.set("db", dbId);
      return url.pathname + url.search + url.hash;
    } catch {
      return target;
    }
  }

  (async () => {
    const session = await fetchSession();
    if (!session) {
      // Sign-in didn't take — cookie blocked, third-party cookies
      // disabled in the IdP round-trip, or the user closed the tab
      // mid-flow. Send back to sign-in with a friendly hint.
      location.replace("/auth/sign-in?error=session_lost");
      return;
    }
    const dbId = await adoptIfNeeded();
    // ChatPanel reads `?db=<id>` from the URL on mount (SK-ANON-014)
    // and pins the DB before the rail fetch resolves; it also reads
    // `nlqdb_pending` from localStorage to rehydrate the composer.
    location.replace(withDbId(next, dbId));
  })();
</script>

<style is:global>
  .post-signin {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding: clamp(48px, 8vw, 96px) 24px;
  }

  .post-signin__card {
    border: 1px solid var(--rule-2);
    border-radius: var(--r-lg);
    background: var(--raised);
    padding: clamp(28px, 5vw, 48px);
    max-width: 520px;
    width: 100%;
    box-shadow: var(--shadow-3);
    text-align: center;
  }

  .post-signin__title {
    font-family: var(--sans);
    font-size: clamp(22px, 3.2vw, 28px);
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .post-signin__lede {
    margin: 0;
    font-size: clamp(14px, 1.6vw, 15px);
    color: var(--body);
  }
</style>
