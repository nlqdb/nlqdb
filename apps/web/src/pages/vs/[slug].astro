---
// One template, N comparison pages — generated at build via
// `getStaticPaths()` from `data/competitors.ts`. AEO patterning:
// direct-answer capsule above the fold, named-competitor in H1 + FAQ,
// FAQPage + BreadcrumbList JSON-LD, working `<nlq-data>` embed as proof.
//
// SK-WEB-015 page sweep (redesign-plan §5 `/vs/*`): the comparison
// table is the HERO of the page, not buried below feature copy.
// Three beats: (1) "What we replace" — one line; (2) "The same goal,
// two ways" — their approach beside ours, mirroring the homepage Demo
// block treatment, lime tag highlight only on ours; (3) "What's
// different" — tight 4-row table. Extra rows fold into a `<details>`.

import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import { COMPETITORS, type ComparisonClaim, competitorBySlug } from "../../data/competitors";
import Base from "../../layouts/Base.astro";
import { breadcrumbJsonLd } from "../../lib/breadcrumb";
import { faqPageJsonLd } from "../../lib/faq-jsonld";

export function getStaticPaths() {
  return COMPETITORS.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const c = competitorBySlug(slug as string);
if (!c) {
  return Astro.redirect("/vs");
}

const pageTitle = `nlqdb vs ${c.name} — natural-language databases`;
const description = c.oneLiner;
const canonical = `/vs/${c.slug}`;

// The agent-memory cluster (P2) ships on-brand wedge cards (WS-08); other
// comparisons fall back to the site-wide default until they get their own.
const ogImage = c.persona === "P2 agent builder" ? `/og/vs-${c.slug}.png` : undefined;
const ogImageAlt = `nlqdb vs ${c.name} — GROUP BY, JOIN, and HAVING over your agent's memory.`;

const claimGlyph: Record<ComparisonClaim, string> = {
  shipped: "✓",
  partial: "◐",
  no: "—",
};
const claimLabel: Record<ComparisonClaim, string> = {
  shipped: "Yes",
  partial: "Partial",
  no: "No",
};

const faqJsonLd = faqPageJsonLd(c.faqs);

const breadcrumbLd = breadcrumbJsonLd(
  [
    { name: "Home", path: "/" },
    { name: "Compare", path: "/vs" },
    { name: `nlqdb vs ${c.name}`, path: canonical },
  ],
  Astro.site,
);

// Redesign-plan §5: keep four decisive rows above the fold; fold the
// rest into a `<details>`. Rows are author-ordered in competitors.ts
// (highest-decisive first), so a head/tail split honours intent
// without ranking heuristics here.
const primaryRows = c.features.slice(0, 4);
const moreRows = c.features.slice(4);

// "Their way" descriptor — derived from the first `whenChooseThem`
// bullet, which is the author-curated "highest-decisive" reason. We
// don't fabricate a competitor code snippet; we render their
// positioning honestly beside our embed.
const theirApproach = c.whenChooseThem[0] ?? c.tagline;
---
<Base
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={ogImage ? ogImageAlt : undefined}
>
  <div class="page">
    <Topnav current="vs" />

    <main class="vs">
      <nav class="vs__crumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/vs/">Compare</a></li>
          <li aria-current="page">nlqdb vs {c.name}</li>
        </ol>
      </nav>

      <header class="vs__head">
        <p class="vs__eyebrow">Comparison</p>
        <h1 class="vs__title">nlqdb vs {c.name}</h1>
        <p class="vs__replace">{c.oneLiner}</p>
      </header>

      <section class="vs__demo" aria-labelledby="vs-demo-eyebrow">
        <p class="vs__demo-eyebrow" id="vs-demo-eyebrow">The same goal, two ways.</p>
        <p class="vs__demo-goal">
          <span class="vs__demo-arrow">&gt;</span>
          <code>{c.demo.goal}</code>
        </p>

        <div class="vs__demo-pair">
          <article class="vs__demo-card vs__demo-card--them" aria-label={`How ${c.name} answers`}>
            <p class="vs__demo-label">In {c.name}</p>
            <p class="vs__demo-text">{theirApproach}</p>
            <p class="vs__demo-foot">
              <a href={c.url} rel="nofollow noopener noreferrer" target="_blank">{c.tagline}</a>
            </p>
          </article>

          <article class="vs__demo-card vs__demo-card--us" aria-label="How nlqdb answers">
            <p class="vs__demo-label">In your HTML</p>
            <pre class="vs__demo-snippet"><code>&lt;<span class="vs__demo-tag">nlq-data</span> goal=&quot;{c.demo.goal}&quot;&gt;&lt;/<span class="vs__demo-tag">nlq-data</span>&gt;</code></pre>
            <p class="vs__demo-foot">{c.demo.why}</p>
            <button
              type="button"
              class="cta vs__try-btn"
              data-try-goal={c.demo.goal}
              data-competitor-slug={c.slug}
            >
              Try this query &rarr;
            </button>
          </article>
        </div>
      </section>

      <section class="vs__diff" aria-labelledby="vs-diff-title">
        <p class="vs__diff-eyebrow">What's different</p>
        <h2 class="vs__diff-title" id="vs-diff-title">Four dimensions that decide it</h2>
        <div class="vs__table-wrap">
          <table class="vs__table">
            <thead>
              <tr>
                <th scope="col">Dimension</th>
                <th scope="col">nlqdb</th>
                <th scope="col">{c.name}</th>
                <th scope="col" class="vs__th-note">Note</th>
              </tr>
            </thead>
            <tbody>
              {
                primaryRows.map((row) => (
                  <tr>
                    <th scope="row">{row.feature}</th>
                    <td class={`vs__claim vs__claim--${row.us}`} aria-label={claimLabel[row.us]}>
                      <span aria-hidden="true">{claimGlyph[row.us]}</span>
                    </td>
                    <td class={`vs__claim vs__claim--${row.them}`} aria-label={claimLabel[row.them]}>
                      <span aria-hidden="true">{claimGlyph[row.them]}</span>
                    </td>
                    <td class="vs__note">{row.note ?? ""}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        {
          moreRows.length > 0 && (
            <details class="vs__more">
              <summary>Show {moreRows.length} more {moreRows.length === 1 ? "row" : "rows"}</summary>
              <div class="vs__table-wrap">
                <table class="vs__table">
                  <thead>
                    <tr>
                      <th scope="col">Dimension</th>
                      <th scope="col">nlqdb</th>
                      <th scope="col">{c.name}</th>
                      <th scope="col" class="vs__th-note">Note</th>
                    </tr>
                  </thead>
                  <tbody>
                    {moreRows.map((row) => (
                      <tr>
                        <th scope="row">{row.feature}</th>
                        <td class={`vs__claim vs__claim--${row.us}`} aria-label={claimLabel[row.us]}>
                          <span aria-hidden="true">{claimGlyph[row.us]}</span>
                        </td>
                        <td class={`vs__claim vs__claim--${row.them}`} aria-label={claimLabel[row.them]}>
                          <span aria-hidden="true">{claimGlyph[row.them]}</span>
                        </td>
                        <td class="vs__note">{row.note ?? ""}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          )
        }

        <p class="vs__legend">
          <span class="vs__claim vs__claim--shipped" aria-hidden="true">✓</span> shipped &nbsp;·&nbsp;
          <span class="vs__claim vs__claim--partial" aria-hidden="true">◐</span> partial &nbsp;·&nbsp;
          <span class="vs__claim vs__claim--no" aria-hidden="true">—</span> not shipped
        </p>
      </section>

      <section class="vs__decision" aria-label="Direct answer">
        <div class="vs__choice">
          <h2 class="vs__choice-title">When to choose nlqdb</h2>
          <ul>
            {c.whenChooseUs.map((b) => <li>{b}</li>)}
          </ul>
        </div>
        <div class="vs__choice">
          <h2 class="vs__choice-title">When to choose {c.name}</h2>
          <ul>
            {c.whenChooseThem.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      </section>

      <section class="vs__faqs" aria-labelledby="vs-faqs-title">
        <h2 class="vs__faqs-title" id="vs-faqs-title">Questions buyers ask</h2>
        <dl>
          {
            c.faqs.map((f) => (
              <div class="vs__faq">
                <dt>{f.q}</dt>
                <dd>{f.a}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <section class="vs__cta">
        <h2 class="vs__cta-title">Try nlqdb in 30 seconds</h2>
        <p>No sign-in. The anonymous database lasts 72 hours; adopt it with one click if you keep it.</p>
        <a class="cta vs__cta-btn" href="/app/new/">Start with a goal &rarr;</a>
        <p class="vs__cta-meta">
          Want a comparison against another tool?{" "}
          <a href="mailto:hello@nlqdb.com?subject=Comparison request">Email us</a> or browse
          <a href="/vs/"> all comparisons</a>.
        </p>
        {
          /* Agent-memory cluster (P2) → cross-link the dedicated front door
             (agent-memory-pivot WS-07). Keyed on persona so it renders on
             exactly the P2-agent-builder memory comparisons (pinned by
             competitors.test.ts WS-07). */
          c.persona === "P2 agent builder" && (
            <p class="vs__cta-meta">
              Building an AI agent?{" "}
              <a href="/agents/">See analytical memory for agents &rarr;</a>
            </p>
          )
        }
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script>
    // "Try this query" → seed the anonymous-create input via the same
    // `nlqdb_draft` localStorage slot CreateForm rehydrates from
    // (SK-ANON-011), emit a per-slug demand signal (GLOBAL-024), then
    // navigate. No URL param so the goal can't be sniffed from
    // referrer / access logs.
    import { emit } from "../../lib/logsnag";
    import { saveDraft } from "../../lib/prompt-storage";
    document.querySelectorAll<HTMLButtonElement>(".vs__try-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const goal = btn.dataset["tryGoal"] ?? "";
        const slug = btn.dataset["competitorSlug"] ?? "";
        if (goal) saveDraft(goal);
        emit("vs.try_query_clicked", { slug, goal });
        location.assign("/app/new");
      });
    });
  </script>
</Base>

<style>
  .vs {
    max-width: var(--bleed);
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) 0;
  }

  .vs__crumbs {
    font-family: var(--mono);
    font-size: var(--t-small);
    margin: 0 0 var(--gap-block);
  }
  .vs__crumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--muted);
  }
  .vs__crumbs li + li::before {
    content: "/";
    margin-right: 8px;
    opacity: 0.6;
  }
  .vs__crumbs a {
    color: var(--muted);
    text-decoration: none;
  }
  .vs__crumbs a:hover {
    color: var(--ink);
  }
  .vs__crumbs [aria-current="page"] {
    color: var(--ink);
  }

  /* Beat 1 — "What we replace". One line, no decoration. */
  .vs__head {
    max-width: var(--col);
    margin: 0 0 var(--gap-beat);
  }
  .vs__eyebrow {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vs__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
  }
  .vs__replace {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.5;
    max-width: 60ch;
    text-wrap: balance;
  }

  /* Beat 2 — "The same goal, two ways". Mirrors the homepage Demo
     block: two cards on --raised, --rule border, --ground snippet
     ground, lime tag-highlight on ours only. */
  .vs__demo {
    margin: 0 0 var(--gap-beat);
    max-width: var(--bleed);
  }
  .vs__demo-eyebrow {
    margin: 0 0 16px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vs__demo-goal {
    margin: 0 0 clamp(20px, 3vw, 32px);
    font-family: var(--mono);
    font-size: var(--t-large);
    color: var(--ink);
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .vs__demo-goal code {
    font-family: inherit;
  }
  .vs__demo-arrow {
    color: var(--muted);
    font-weight: 700;
  }
  .vs__demo-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 32px);
    align-items: stretch;
  }
  @media (min-width: 880px) {
    .vs__demo-pair {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
  }
  .vs__demo-card {
    margin: 0;
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .vs__demo-label {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vs__demo-text {
    margin: 0;
    font-family: var(--display);
    font-size: var(--t-large);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.4;
    text-wrap: balance;
  }
  .vs__demo-snippet {
    margin: 0;
    padding: 18px;
    background: var(--ground);
    border: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--body);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .vs__demo-snippet code {
    font-family: inherit;
  }
  /* The lime moment for this beat — only the tag identifier glows,
     and only on our side (redesign-plan §5: lime tag highlight on ours). */
  .vs__demo-tag {
    color: var(--accent);
    font-weight: 600;
  }
  .vs__demo-foot {
    margin: 0;
    font-family: var(--sans);
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.55;
  }
  .vs__demo-foot a {
    color: var(--muted);
  }
  .vs__demo-foot a:hover {
    color: var(--ink);
  }
  .vs__try-btn {
    align-self: flex-start;
    margin-top: auto;
  }

  /* Beat 3 — "What's different". Tight 4-row table; the rest folds
     into a <details>. */
  .vs__diff {
    margin: 0 0 var(--gap-beat);
    max-width: var(--bleed);
  }
  .vs__diff-eyebrow {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vs__diff-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 clamp(20px, 3vw, 32px);
    text-wrap: balance;
  }
  .vs__table-wrap {
    overflow-x: auto;
  }
  .vs__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--sans);
    font-size: var(--t-body);
  }
  .vs__table th,
  .vs__table td {
    text-align: left;
    padding: 14px 12px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
  }
  .vs__table thead th {
    font-family: var(--mono);
    color: var(--muted);
    text-transform: uppercase;
    font-size: var(--t-small);
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--ink);
    font-weight: 500;
  }
  .vs__table tbody th {
    font-family: var(--mono);
    font-weight: 500;
    color: var(--ink);
  }
  .vs__claim {
    font-family: var(--mono);
    text-align: center;
    width: 72px;
  }
  .vs__claim--shipped {
    color: var(--accent);
  }
  .vs__claim--partial {
    color: var(--body);
  }
  .vs__claim--no {
    color: var(--muted);
  }
  .vs__note {
    color: var(--body);
    font-size: var(--t-small);
    line-height: 1.5;
  }
  .vs__more {
    margin: 20px 0 0;
  }
  .vs__more summary {
    cursor: pointer;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule);
    list-style: none;
  }
  .vs__more summary::-webkit-details-marker {
    display: none;
  }
  .vs__more summary::before {
    content: "+ ";
    color: var(--muted);
  }
  .vs__more[open] summary::before {
    content: "− ";
  }
  .vs__more summary:hover {
    color: var(--ink);
  }
  .vs__more[open] .vs__table-wrap {
    margin-top: 12px;
  }
  .vs__legend {
    margin: 16px 0 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }

  /* Secondary — "When to choose" cards, demoted below the diff table.
     One column on mobile, two on desktop; quiet neutral border, no
     lime accent (the diff table is the eye now). */
  .vs__decision {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 32px);
    margin: 0 0 var(--gap-beat);
    max-width: var(--bleed);
  }
  @media (min-width: 720px) {
    .vs__decision {
      grid-template-columns: 1fr 1fr;
    }
  }
  .vs__choice {
    padding: clamp(20px, 3vw, 28px);
    background: var(--raised);
    border: 1px solid var(--rule);
  }
  .vs__choice-title {
    font-family: var(--display);
    font-size: var(--t-large);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 16px;
  }
  .vs__choice ul {
    margin: 0;
    padding-left: 20px;
    color: var(--body);
    font-size: var(--t-body);
    line-height: 1.55;
  }
  .vs__choice li + li {
    margin-top: 10px;
  }

  /* FAQs — boring is the goal. Display serif Q, sans A, hairline rules. */
  .vs__faqs {
    margin: 0 0 var(--gap-beat);
    max-width: var(--col);
  }
  .vs__faqs-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 clamp(20px, 3vw, 32px);
  }
  .vs__faqs dl {
    margin: 0;
  }
  .vs__faq {
    padding: 20px 0;
    border-bottom: 1px solid var(--rule);
  }
  .vs__faq:last-child {
    border-bottom: none;
  }
  .vs__faq dt {
    font-family: var(--display);
    font-weight: 600;
    font-size: var(--t-large);
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .vs__faq dd {
    margin: 0;
    color: var(--body);
    font-size: var(--t-body);
    line-height: 1.6;
  }

  /* Final CTA — quiet card, the .cta primitive does the lime moment. */
  .vs__cta {
    padding: clamp(28px, 4vw, 40px);
    background: var(--raised);
    border: 1px solid var(--rule);
    max-width: var(--col);
  }
  .vs__cta-title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .vs__cta p {
    color: var(--body);
    margin: 0 0 20px;
    font-size: var(--t-body);
  }
  .vs__cta-btn {
    padding: 16px 28px;
  }
  .vs__cta-meta {
    margin: 20px 0 0;
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
  }
  .vs__cta-meta a {
    color: var(--body);
  }
  .vs__cta-meta a:hover {
    color: var(--ink);
  }
</style>
