---
// Index of comparison pages — sits at /vs as a fallback landing for
// people who typed the prefix without a slug, and as an internal-link
// hub the per-comparison pages cross-link to.

import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import { COMPETITORS } from "../../data/competitors";
import Base from "../../layouts/Base.astro";
---
<Base
  title="Compare nlqdb to alternatives — natural-language databases"
  description="Honest side-by-side comparisons against Supabase, Vanna, Mem0, Outerbase and other adjacent tools. Pick the right shape for your stack."
  canonical="/vs"
>
  <div class="page">
    <Topnav current="vs" />

    <main class="vsidx">
      <header class="vsidx__head">
        <p class="vsidx__kicker">Comparisons</p>
        <h1 class="vsidx__title">Compare nlqdb to alternatives</h1>
        <p class="vsidx__lede">
          Honest side-by-sides. Each comparison names what the other tool
          does better — pages that hide weaknesses don't earn citations,
          and they don't earn trust.
        </p>
      </header>

      <ul class="vsidx__list">
        {
          COMPETITORS.map((c) => (
            <li class="vsidx__item">
              <a href={`/vs/${c.slug}`} class="vsidx__link">
                <div class="vsidx__row">
                  <h2 class="vsidx__name">nlqdb vs {c.name}</h2>
                  <span class="vsidx__persona">{c.persona}</span>
                </div>
                <p class="vsidx__one-liner">{c.oneLiner}</p>
              </a>
            </li>
          ))
        }
      </ul>

      <section class="vsidx__cta">
        <h2>Comparing against a tool we don't list?</h2>
        <p>
          <a href="mailto:hello@nlqdb.com?subject=Comparison request">Email us</a>
          the product name; the comparison ships the same week if the tool is in our
          <a href="https://github.com/nlqdb/nlqdb/blob/main/docs/competitors.md">competitor analysis</a>.
        </p>
      </section>
    </main>

    <Footer />
  </div>
</Base>

<style>
  .vsidx {
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) clamp(16px, 4vw, 32px);
  }
  .vsidx__kicker {
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-dim);
    font-size: 13px;
    margin: 0 0 12px;
  }
  .vsidx__title {
    font-family: var(--mono);
    font-size: clamp(28px, 4.5vw, 44px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .vsidx__lede {
    font-size: clamp(16px, 1.8vw, 18px);
    color: var(--fg);
    max-width: 60ch;
    margin: 0 0 48px;
  }
  .vsidx__list {
    list-style: none;
    padding: 0;
    margin: 0 0 48px;
    display: grid;
    gap: 16px;
  }
  .vsidx__link {
    display: block;
    padding: 20px;
    border: 2px solid var(--border-strong);
    background: var(--bg-elev);
    text-decoration: none;
    color: inherit;
  }
  .vsidx__link:hover {
    border-color: var(--accent);
  }
  .vsidx__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 8px;
  }
  .vsidx__name {
    font-family: var(--mono);
    font-size: 18px;
    margin: 0;
    color: var(--fg);
  }
  .vsidx__persona {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .vsidx__one-liner {
    color: var(--fg-dim);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }
  .vsidx__cta {
    padding: 24px;
    border: 1px dashed var(--border-strong);
    text-align: center;
  }
  .vsidx__cta h2 {
    font-family: var(--mono);
    font-size: 18px;
    margin: 0 0 8px;
  }
  .vsidx__cta p {
    margin: 0;
    color: var(--fg-dim);
    font-size: 14px;
  }
  .vsidx__cta a {
    color: var(--accent);
  }
</style>
