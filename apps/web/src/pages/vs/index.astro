---
// Index of comparison pages — sits at /vs as a fallback landing for
// people who typed the prefix without a slug, and as an internal-link
// hub the per-comparison pages cross-link to.
//
// SK-WEB-015 page sweep: same token system as `/vs/[slug]`. Display
// serif for the narrative header; mono only for identifier columns
// (competitor name + persona tag); quiet sans body.

import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import { COMPETITORS } from "../../data/competitors";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/itemlist-jsonld";

// ItemList JSON-LD (SK-CMP-006) — enumerate the full comparison set for answer
// engines, built from the same COMPETITORS the list below renders so the two
// can't drift. `name` mirrors the visible `nlqdb vs X` heading.
const itemListLd = itemListJsonLd(
  "Compare nlqdb to alternatives",
  COMPETITORS.map((c) => ({ name: `nlqdb vs ${c.name}`, path: `/vs/${c.slug}` })),
  Astro.site,
);
---
<Base
  title="Compare nlqdb to alternatives — natural-language databases"
  description="Honest side-by-side comparisons against the alternatives you're evaluating. Pick the right shape for your stack."
  canonical="/vs"
>
  <div class="page">
    <Topnav current="vs" />

    <main class="vsidx">
      <header class="vsidx__head">
        <p class="vsidx__eyebrow">Comparisons</p>
        <h1 class="vsidx__title">Compare nlqdb to alternatives</h1>
        <p class="vsidx__lede">
          Honest side-by-sides. Each comparison names what the other tool
          does better — pages that hide weaknesses don't earn citations,
          and they don't earn trust.
        </p>
      </header>

      <ul class="vsidx__list">
        {
          COMPETITORS.map((c) => (
            <li class="vsidx__item">
              <a href={`/vs/${c.slug}/`} class="vsidx__link">
                <div class="vsidx__row">
                  <h2 class="vsidx__name">nlqdb vs {c.name}</h2>
                  <span class="vsidx__persona">{c.persona}</span>
                </div>
                <p class="vsidx__one-liner">{c.oneLiner}</p>
              </a>
            </li>
          ))
        }
      </ul>

      <section class="vsidx__cta">
        <h2 class="vsidx__cta-title">Comparing against a tool we don't list?</h2>
        <p>
          <a href="mailto:hello@nlqdb.com?subject=Comparison request">Email us</a>
          the product name; the comparison ships the same week if the tool is in our
          <a href="https://github.com/nlqdb/nlqdb/blob/main/docs/competitors.md">competitor analysis</a>.
        </p>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
</Base>

<style>
  .vsidx {
    max-width: var(--col);
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) 0;
  }
  .vsidx__head {
    margin: 0 0 clamp(40px, 6vw, 64px);
  }
  .vsidx__eyebrow {
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-size: var(--t-small);
    margin: 0 0 16px;
  }
  .vsidx__title {
    font-family: var(--display);
    font-size: var(--t-section);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .vsidx__lede {
    font-family: var(--sans);
    font-size: var(--t-large);
    color: var(--body);
    line-height: 1.5;
    max-width: 60ch;
    margin: 0;
    text-wrap: balance;
  }
  .vsidx__list {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(40px, 6vw, 64px);
    display: grid;
    gap: 12px;
  }
  .vsidx__link {
    display: block;
    padding: 20px;
    background: var(--raised);
    border: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
  }
  .vsidx__link:hover {
    border-color: var(--ink);
    color: inherit;
    text-decoration: none;
  }
  .vsidx__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 8px;
  }
  .vsidx__name {
    font-family: var(--mono);
    font-size: var(--t-body);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--ink);
  }
  .vsidx__persona {
    font-family: var(--mono);
    font-size: var(--t-small);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .vsidx__one-liner {
    font-family: var(--sans);
    color: var(--body);
    font-size: var(--t-small);
    line-height: 1.55;
    margin: 0;
  }
  .vsidx__cta {
    padding: clamp(24px, 4vw, 32px);
    background: var(--raised);
    border: 1px solid var(--rule);
  }
  .vsidx__cta-title {
    font-family: var(--display);
    font-size: var(--t-large);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .vsidx__cta p {
    font-family: var(--sans);
    margin: 0;
    color: var(--body);
    font-size: var(--t-body);
    line-height: 1.55;
  }
  .vsidx__cta a {
    color: var(--ink);
  }
</style>
