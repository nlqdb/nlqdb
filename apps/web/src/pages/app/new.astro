---
// Anonymous-create surface (SK-ANON-008 / SK-HDC-001 / SK-WEB-008).
//
// Permalink alias of the marketing hero — both render `<CreateForm>`
// against `/v1/ask` with `Authorization: Bearer anon_<token>`. Same
// orchestrator, same global anon cap (SK-ANON-010), same prompt
// persistence (SK-ANON-011). Surface route exists so third-party
// links / docs / CLI prompts can target a stable URL even if the
// homepage layout changes.
//
// Post-Worksheet-1 this page is served from `app.nlqdb.com` (same
// origin as the API), so `apiBase` defaults to `""` and `/v1/ask`
// resolves same-origin.

import CreateForm from "../../components/CreateForm.tsx";
import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<Base
  title="Create a database — nlqdb"
  description="Spin up a Postgres schema from a goal. No sign-in required for the first 72h."
>
  <div class="page">
    <Topnav />
    <main>
      <CreateForm client:load apiBase={apiBase} />
    </main>
    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token early so it's in localStorage
  // before CreateForm.tsx hydrates (SK-ANON-001).
  import { getOrMintAnonToken } from "../../lib/anon";
  getOrMintAnonToken();
</script>
