---
// Anonymous-create permalink alias of the marketing hero
// (`SK-ANON-008` / `SK-HDC-001` / `SK-WEB-008`).

import CreateForm from "../../components/CreateForm.tsx";
import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<Base
  title="Create a database — nlqdb"
  description="Spin up a Postgres schema from a goal. No sign-in required for the first 72h."
>
  <div class="page">
    <Topnav />
    <main>
      <CreateForm client:load apiBase={apiBase} />
    </main>
    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token early so it's in localStorage
  // before CreateForm.tsx hydrates (SK-ANON-001).
  import { getOrMintAnonToken } from "../../lib/anon";
  getOrMintAnonToken();
</script>
