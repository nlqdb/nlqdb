---
// Chat surface (Slice 10 — DESIGN §3.2 "Signed-in surface").
//
// Static Astro page; vanilla-JS island for the conversation. On
// load: GET /v1/chat/messages with cookies. 401 → redirect to
// /sign-in?return_to=/app. Anything else → render history + the
// composer.
//
// Streaming is deferred to Slice 11 (TODO in apps/api/src/index.ts);
// this is request/response. The composer requires a `dbId` because
// /v1/ask does — there is no DB-on-first-reference yet.

import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "https://app.nlqdb.com";
---
<Base
  title="Chat — nlqdb"
  description="Query your database in English."
>
  <div class="page app">
    <header class="topnav">
      <a class="topnav__brand" href="/">nlqdb</a>
      <nav class="topnav__links">
        <button type="button" id="signout" class="signin__link">Sign out</button>
      </nav>
    </header>

    <main class="chat">
      <div id="chat-loading" class="chat__loading">Loading…</div>

      <div id="chat-empty" class="chat__empty" hidden>
        <h1 class="chat__title">Ask your database.</h1>
        <p class="chat__lede">Type a question. The reply includes the SQL we ran.</p>
      </div>

      <ol id="chat-messages" class="chat__messages" hidden></ol>

      <form id="chat-form" class="chat__form" hidden>
        <input
          id="chat-db"
          name="dbId"
          type="text"
          placeholder="db_id (e.g. db_orders)"
          class="chat__db"
          autocomplete="off"
          required
        />
        <textarea
          id="chat-input"
          name="goal"
          placeholder="Show me the 10 most recent orders…"
          class="chat__input"
          rows="2"
          required
        ></textarea>
        <button type="submit" class="btn btn--accent chat__send">Send</button>
        <p id="chat-error" class="chat__error" hidden></p>
      </form>
    </main>
  </div>

  <script is:inline define:vars={{ apiBase }}>
    const loading = document.getElementById("chat-loading");
    const empty = document.getElementById("chat-empty");
    const list = document.getElementById("chat-messages");
    const form = document.getElementById("chat-form");
    const dbInput = /** @type {HTMLInputElement} */ (document.getElementById("chat-db"));
    const goalInput = /** @type {HTMLTextAreaElement} */ (document.getElementById("chat-input"));
    const sendBtn = form.querySelector("button[type=submit]");
    const errorEl = document.getElementById("chat-error");
    const signoutBtn = document.getElementById("signout");

    const LAST_DB_KEY = "nlqdb:last-db";

    function redirectToSignIn() {
      const ret = encodeURIComponent("/app");
      location.href = `/sign-in?return_to=${ret}`;
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    function renderRowsAsTable(rows) {
      if (!rows || rows.length === 0) {
        return '<p class="chat__rows-empty">No rows.</p>';
      }
      const cols = Object.keys(rows[0]);
      const head = cols.map((c) => `<th>${escapeHtml(c)}</th>`).join("");
      const body = rows
        .slice(0, 50)
        .map(
          (row) =>
            `<tr>${cols.map((c) => `<td>${escapeHtml(row[c] === null || row[c] === undefined ? "" : typeof row[c] === "object" ? JSON.stringify(row[c]) : row[c])}</td>`).join("")}</tr>`,
        )
        .join("");
      const more = rows.length > 50 ? `<p class="chat__rows-more">… ${rows.length - 50} more rows</p>` : "";
      return `<table class="nlq-table"><thead><tr>${head}</tr></thead><tbody>${body}</tbody></table>${more}`;
    }

    function renderMessage(msg) {
      const li = document.createElement("li");
      li.className = `chat__msg chat__msg--${msg.role}`;
      if (msg.role === "user") {
        li.innerHTML = `
          <div class="chat__msg-meta">you · db=${escapeHtml(msg.dbId || "")}</div>
          <div class="chat__msg-body">${escapeHtml(msg.goal || "")}</div>
        `;
      } else if (msg.errorStatus) {
        li.innerHTML = `
          <div class="chat__msg-meta">nlqdb · error</div>
          <div class="chat__msg-error">
            <strong>${escapeHtml(msg.errorStatus)}</strong>
            ${msg.errorMessage ? `<div>${escapeHtml(msg.errorMessage)}</div>` : ""}
          </div>
        `;
      } else {
        const summary = msg.summary
          ? `<div class="chat__msg-summary">${escapeHtml(msg.summary)}</div>`
          : "";
        const sql = msg.sql
          ? `<pre class="chat__msg-sql"><code>${escapeHtml(msg.sql)}</code></pre>`
          : "";
        const rows = renderRowsAsTable(msg.rows);
        const cached = msg.cached ? " · cached" : "";
        const meta = `nlqdb · ${msg.rowCount ?? 0} row${msg.rowCount === 1 ? "" : "s"}${cached}`;
        li.innerHTML = `
          <div class="chat__msg-meta">${escapeHtml(meta)}</div>
          ${summary}
          <div class="chat__msg-rows">${rows}</div>
          ${sql}
        `;
      }
      return li;
    }

    function appendMessage(msg) {
      list.appendChild(renderMessage(msg));
      list.scrollTop = list.scrollHeight;
    }

    async function load() {
      try {
        const res = await fetch(`${apiBase}/v1/chat/messages`, {
          credentials: "include",
        });
        if (res.status === 401) {
          redirectToSignIn();
          return;
        }
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const body = await res.json();
        loading.hidden = true;
        form.hidden = false;
        const msgs = body.messages ?? [];
        if (msgs.length === 0) {
          empty.hidden = false;
        } else {
          list.hidden = false;
          for (const m of msgs) appendMessage(m);
        }
        const lastDb = localStorage.getItem(LAST_DB_KEY);
        if (lastDb) dbInput.value = lastDb;
      } catch (err) {
        loading.textContent = `Couldn't load: ${err && err.message ? err.message : "unknown error"}`;
      }
    }

    async function send() {
      const goal = goalInput.value.trim();
      const dbId = dbInput.value.trim();
      if (!goal || !dbId) return;
      errorEl.hidden = true;
      sendBtn.disabled = true;
      sendBtn.textContent = "Sending…";
      try {
        localStorage.setItem(LAST_DB_KEY, dbId);
        const res = await fetch(`${apiBase}/v1/chat/messages`, {
          method: "POST",
          credentials: "include",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ goal, dbId }),
        });
        if (res.status === 401) {
          redirectToSignIn();
          return;
        }
        if (!res.ok) {
          const detail = await res.text();
          throw new Error(detail.slice(0, 240) || `HTTP ${res.status}`);
        }
        const body = await res.json();
        empty.hidden = true;
        list.hidden = false;
        appendMessage(body.user);
        appendMessage(body.assistant);
        goalInput.value = "";
      } catch (err) {
        errorEl.textContent = err && err.message ? err.message : "Send failed.";
        errorEl.hidden = false;
      } finally {
        sendBtn.disabled = false;
        sendBtn.textContent = "Send";
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      send();
    });

    // Cmd/Ctrl+Enter submits without leaving the textarea.
    goalInput.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
        e.preventDefault();
        send();
      }
    });

    signoutBtn.addEventListener("click", async () => {
      await fetch(`${apiBase}/api/auth/sign-out`, {
        method: "POST",
        credentials: "include",
      });
      redirectToSignIn();
    });

    load();
  </script>

  <style>
    .app .topnav__links {
      display: flex;
      gap: 16px;
    }
    .chat {
      display: grid;
      grid-template-rows: 1fr auto;
      gap: 16px;
      padding: 24px 0 32px;
      min-height: calc(100dvh - 120px);
    }
    .chat__loading,
    .chat__empty {
      font-family: var(--mono);
      color: var(--fg-dim);
      padding: 32px 0;
    }
    .chat__title {
      font-size: clamp(28px, 5vw, 44px);
      margin: 0 0 8px;
      letter-spacing: -0.03em;
    }
    .chat__lede {
      font-family: var(--mono);
      color: var(--fg-dim);
      margin: 0;
    }
    .chat__messages {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 16px;
      overflow-y: auto;
    }
    .chat__msg {
      padding: 14px 16px;
      border: 2px solid var(--border-strong);
      background: var(--bg-elev);
      box-shadow: 4px 4px 0 0 var(--border-strong);
    }
    .chat__msg--user {
      border-color: var(--accent);
      box-shadow: 4px 4px 0 0 var(--accent);
    }
    .chat__msg-meta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }
    .chat__msg-body {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg);
      white-space: pre-wrap;
      word-break: break-word;
    }
    .chat__msg-summary {
      font-size: 14px;
      color: var(--fg);
      margin-bottom: 10px;
    }
    .chat__msg-rows {
      overflow-x: auto;
      margin-bottom: 8px;
    }
    .chat__rows-empty,
    .chat__rows-more {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-muted);
      margin: 4px 0;
    }
    .chat__msg-sql {
      margin: 8px 0 0;
      padding: 8px 10px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-dim);
      background: var(--bg);
      border: 1px solid var(--border);
      overflow-x: auto;
    }
    .chat__msg-error {
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
    }
    .chat__form {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px;
      background: var(--bg-elev);
      border: 3px solid var(--border-strong);
      box-shadow: var(--shadow-hard);
      position: sticky;
      bottom: 12px;
    }
    .chat__db,
    .chat__input {
      width: 100%;
      padding: 10px 12px;
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg);
      background: var(--bg);
      border: 2px solid var(--border-strong);
      outline: none;
      resize: vertical;
    }
    .chat__db:focus,
    .chat__input:focus {
      border-color: var(--accent);
    }
    .chat__send {
      justify-self: end;
    }
    .chat__error {
      margin: 0;
      padding: 8px 10px;
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
      background: #2a1212;
      border: 2px solid #ff8a8a;
    }
  </style>
</Base>
