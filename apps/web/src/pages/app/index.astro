---
// Product chat page (`SK-WEB-005`). DB id rides `?db=<dbId>` rather
// than a path segment because the static build can't pre-render
// `[dbId].astro` without an SSR adapter.

import AppAnalytics from "../../components/AppAnalytics.astro";
import ChatPanel from "../../components/chat/ChatPanel.tsx";
import Footer from "../../components/Footer.astro";
import SupportChat from "../../components/SupportChat.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<Base
  title="Chat — nlqdb"
  description="Talk to your databases."
>
  <div class="page page--chat" id="app-shell" data-api-base={apiBase} hidden>
    <Topnav current="chat" />
    <main class="page__main page__main--chat">
      <!-- Empty, present-from-load role="status" region: the message text
           is injected by JS (see below), which is the announcement path
           screen readers fire on — exposing pre-filled text is unreliable. -->
      <aside id="checkout-banner" class="checkout-banner" role="status">
        <p class="checkout-banner__text" id="checkout-banner-text"></p>
        <button
          type="button"
          id="checkout-banner-dismiss"
          class="checkout-banner__dismiss"
          aria-label="Dismiss"
          hidden
        >&times;</button>
      </aside>
      <!-- Dunning banner (SK-WEB-012): an empty role="alert" region, present
           from load; the text is injected only when GET /v1/billing/status
           reports a past_due/unpaid subscription (the injection is what a
           screen reader announces, same pattern as the checkout banner). -->
      <aside id="dunning-banner" class="dunning-banner" role="alert">
        <p class="dunning-banner__text" id="dunning-banner-text"></p>
        <button
          type="button"
          id="dunning-banner-action"
          class="dunning-banner__action"
          hidden
        >Update payment method</button>
      </aside>
      <ChatPanel client:only="react" apiBase={apiBase} />
    </main>
    <Footer />
  </div>
  <AppAnalytics />
  <SupportChat />
</Base>

<script>
  // Inline auth guard. Runs before the chat shell paints — the
  // shell is `hidden` until `fetchSession` resolves. On null
  // (unauthenticated, expired, or cross-site cookie blocked),
  // navigate to the sign-in page with a return target so the user
  // doesn't see the chat in a broken-401 state. On hit, reveal
  // the shell so React hydration can take over.
  import { fetchSession, invalidateSession } from "../../lib/session";
  import { fetchBillingStatus, openBillingPortal } from "../../lib/billing";

  const shell = document.getElementById("app-shell");
  if (shell) {
    const apiBase = (shell as HTMLElement).dataset["apiBase"];

    // Bounce to sign-in when there's no live session. Returns true when
    // signed in. Reused on initial load and on bfcache restore (below).
    async function requireSession(): Promise<boolean> {
      const user = await fetchSession(apiBase);
      if (!user) {
        const returnTo = `${location.pathname}${location.search}${location.hash}`;
        const signInUrl = new URL("/auth/sign-in/", location.origin);
        signInUrl.searchParams.set("return_to", returnTo);
        location.replace(signInUrl.toString());
        return false;
      }
      return true;
    }

    // WS02-T2: a bfcache restore keeps the revealed shell even after
    // sign-out (here or in another tab) cleared the cookie. Re-probe the
    // live cookie on `pageshow` (persisted) and bounce to sign-in if it's
    // gone — invalidating session.ts's cache alone can't re-render a
    // restored page whose guard script never re-runs.
    window.addEventListener("pageshow", (event) => {
      if (event.persisted) {
        invalidateSession();
        void requireSession();
      }
    });

    void (async () => {
      if (!(await requireSession())) return;
      shell.hidden = false;

      // Post-checkout confirmation (SK-WEB-011). Stripe Checkout redirects
      // the subscriber here as `?checkout=success`; show a one-time banner
      // and strip the param via replaceState so a refresh or shared link
      // doesn't replay it. Revealed only after the auth guard passes, so it
      // never flashes for anon visitors. Copy stays honest — the
      // subscription is `incomplete` until `customer.subscription.created`
      // lands (SK-STRIPE-004), so we don't claim the plan is already active.
      const params = new URLSearchParams(location.search);
      if (params.get("checkout") === "success") {
        const banner = document.getElementById("checkout-banner");
        const text = document.getElementById("checkout-banner-text");
        if (banner && text) {
          banner.classList.add("checkout-banner--shown");
          document.getElementById("checkout-banner-dismiss")?.removeAttribute("hidden");
          // Inject on the next frame so the now-exposed region is registered
          // empty first, then the content change triggers the announcement.
          requestAnimationFrame(() => {
            text.textContent =
              "Payment received — thanks for upgrading. Your new plan is being activated.";
          });
        }
        params.delete("checkout");
        const query = params.toString();
        history.replaceState(
          null,
          "",
          `${location.pathname}${query ? `?${query}` : ""}${location.hash}`,
        );
      }

      // Dunning banner (SK-WEB-012). A failed renewal flips the subscription
      // to past_due/unpaid, and Stripe has no redirect for that, so we read
      // the live status (a single indexed D1 read — SK-STRIPE-009) in the
      // background — off the render path, after the shell already painted —
      // and surface the banner only for that rare unhealthy case. Healthy
      // and free users pay nothing visible.
      void fetchBillingStatus(apiBase ?? "").then((status) => {
        if (!status || (status.status !== "past_due" && status.status !== "unpaid")) return;
        const banner = document.getElementById("dunning-banner");
        const text = document.getElementById("dunning-banner-text");
        document.getElementById("dunning-banner-action")?.removeAttribute("hidden");
        if (!banner || !text) return;
        banner.classList.add("dunning-banner--shown");
        // Inject one frame later so the now-exposed alert region registers
        // empty first, then the text change fires the announcement.
        requestAnimationFrame(() => {
          text.textContent =
            "Your last payment didn't go through. Update your payment method to keep your plan active.";
        });
      });

      document
        .getElementById("dunning-banner-action")
        ?.addEventListener("click", async (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          btn.disabled = true;
          const original = btn.textContent;
          btn.textContent = "Redirecting…";
          const outcome = await openBillingPortal(apiBase ?? "");
          if (outcome === "ok") return; // browser is already navigating to Stripe
          if (outcome === "not_configured") {
            // Live keys absent — leave the button disabled so it doesn't invite
            // a retry that can't succeed yet (mirrors the /pricing manage button).
            btn.textContent = "Not available yet";
            return;
          }
          // no_customer is unreachable for a past_due row; on a transient error
          // re-enable so the user can retry.
          btn.disabled = false;
          btn.textContent = original;
          if (outcome === "error") {
            alert("Something went wrong. Please try again or email hello@nlqdb.com.");
          }
        });
    })();
  }

  document
    .getElementById("checkout-banner-dismiss")
    ?.addEventListener("click", () => {
      document.getElementById("checkout-banner")?.classList.remove("checkout-banner--shown");
      const text = document.getElementById("checkout-banner-text");
      if (text) text.textContent = "";
      document.getElementById("checkout-banner-dismiss")?.setAttribute("hidden", "");
    });
</script>

<style is:global>
  @import "../../styles/chat.css";
</style>

<style>
  /* The live region stays in the DOM at all times (empty → zero-height,
   * invisible); only the `--shown` modifier paints the box, so revealing
   * is a content injection the screen reader can announce. */
  .checkout-banner--shown {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin: 8px 16px 0;
    padding: 14px 18px;
    border: 1px solid var(--accent-line);
    border-radius: var(--r-md);
    background: var(--accent-soft);
    font-family: var(--sans);
    font-size: 14px;
  }

  .checkout-banner__text {
    margin: 0;
    color: var(--ink);
  }

  .checkout-banner__dismiss {
    flex-shrink: 0;
    padding: 0 4px;
    border: none;
    background: none;
    color: var(--body);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
  }

  .checkout-banner__dismiss:hover {
    color: var(--ink);
  }

  /* Same empty-until-shown live-region trick as the checkout banner, but
   * danger-tinted so a payment failure reads as urgent, not a success. */
  .dunning-banner--shown {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin: 8px 16px 0;
    padding: 14px 18px;
    border: 1px solid rgba(226, 109, 109, 0.4);
    border-radius: var(--r-md);
    background: rgba(226, 109, 109, 0.1);
    font-family: var(--sans);
    font-size: 14px;
  }

  .dunning-banner__text {
    margin: 0;
    color: var(--ink);
  }

  .dunning-banner__action {
    flex-shrink: 0;
    padding: 8px 14px;
    border: 1px solid rgba(226, 109, 109, 0.4);
    border-radius: var(--r-sm);
    background: transparent;
    color: var(--ink);
    font-family: var(--sans);
    font-size: 13px;
    cursor: pointer;
  }

  .dunning-banner__action:hover {
    background: rgba(226, 109, 109, 0.18);
    color: var(--ink);
  }

  .dunning-banner__action:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
