---
// Product chat page (SK-WEB-005). One static route handles the
// whole chat surface — `/app` lands here without a DB selected
// (the left rail prompts to pick one), `/app?db=<dbId>` deep-
// links into a specific conversation. The DB id rides a query
// param rather than a path segment because `apps/web` is a
// static-output Astro site (no SSR adapter); a static build
// can't pre-render `[dbId].astro` for unknown ids without an
// adapter or wholesale SPA fallback.
//
// `selectDb` in ChatPanel updates the query string via
// `history.pushState` so refresh + back/forward both round-trip
// the active DB without a server hop. Auth is the cross-
// subdomain `__Secure-session` cookie (SK-WEB-006).
//
// Auth guard: a pre-render probe to `/api/auth/get-session`
// redirects unauthenticated visitors to `/auth/sign-in` instead
// of letting them sit on a chat shell whose every API call 401s.
// The guard is what stops the post-OAuth redirect from landing on
// a "signed in but every request fails" state when the browser
// can't deliver the session cookie (e.g. SameSite=Lax blocking
// the cross-eTLD+1 fetch on Workers-Versions previews per
// SK-AUTH-013/SK-AUTH-015 — same symptom the user would see if
// the cookie genuinely expired).

import ChatPanel from "../../components/chat/ChatPanel.tsx";
import Footer from "../../components/Footer.astro";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "https://app.nlqdb.com";
---
<Base
  title="Chat — nlqdb"
  description="Talk to your databases."
>
  <div class="page page--chat" id="app-shell" data-api-base={apiBase} hidden>
    <Topnav current="chat" />
    <main class="page__main page__main--chat">
      <ChatPanel client:only="react" apiBase={apiBase} />
    </main>
    <Footer />
  </div>
</Base>

<script>
  // Inline auth guard. Runs before the chat shell paints — the
  // shell is `hidden` until `fetchSession` resolves. On null
  // (unauthenticated, expired, or cross-site cookie blocked),
  // navigate to the sign-in page with a return target so the user
  // doesn't see the chat in a broken-401 state. On hit, reveal
  // the shell so React hydration can take over.
  import { fetchSession } from "../../lib/session";

  const shell = document.getElementById("app-shell");
  if (shell) {
    const apiBase = (shell as HTMLElement).dataset["apiBase"];
    void (async () => {
      const user = await fetchSession(apiBase);
      if (!user) {
        const returnTo = `${location.pathname}${location.search}${location.hash}`;
        const signInUrl = new URL("/auth/sign-in", location.origin);
        signInUrl.searchParams.set("return_to", returnTo);
        location.replace(signInUrl.toString());
        return;
      }
      shell.hidden = false;
    })();
  }
</script>

<style is:global>
  @import "../../styles/chat.css";
</style>
