---
// Chat surface (Slice 10 — DESIGN §3.2 "Signed-in surface").
//
// Two-pane layout: left = chronological turn list (compact, just
// the goal / summary / error blurb per row), right = detail pane
// showing the SQL + result table for the currently-selected
// message. Defaults the selection to the most recent message;
// clicking a row in the list updates the right pane in place.
//
// Why split: in v0 we rendered SQL + table inline with each turn,
// which made history scroll like a wall of monospace tables.
// Master/detail keeps the conversation legible AND lets each
// result occupy real estate when actually being read.
//
// On load: GET /v1/chat/messages with cookies. 401 → redirect to
// /sign-in?return_to=/app via shared client (lib/auth-client). New
// turns POST /v1/chat/messages and append the returned user +
// assistant rows. Streaming is deferred to Slice 11; this is
// request/response.

import Base from "../../layouts/Base.astro";
---
<Base
  title="Chat — nlqdb"
  description="Query your database in English."
>
  <div class="page app">
    <header class="topnav">
      <a class="topnav__brand" href="/">nlqdb</a>
      <nav class="topnav__links">
        <button type="button" id="signout" class="signin__link">Sign out</button>
      </nav>
    </header>

    <main class="chat">
      <div id="chat-loading" class="chat__loading">Loading…</div>

      <div id="chat-empty" class="chat__empty" hidden>
        <h1 class="chat__title">Ask your database.</h1>
        <p class="chat__lede">
          Type your question and the <code>db_id</code> you want to query. The reply
          includes the SQL we ran — for review or copy-paste.
        </p>
        <p class="chat__lede chat__lede--muted">
          No DB of your own yet?  Use <code>db_id = demo</code> to query our
          sample dataset (orders, contacts, leaderboard, feedback). Replies are
          canned so you can see the surface end-to-end.
          <strong>Slice 11</strong> collapses this to one input — type your goal,
          we infer or create the DB for you.
        </p>
      </div>

      <div id="chat-layout" class="chat__layout" hidden>
        <section class="chat__pane chat__pane--list" aria-label="Conversation">
          <ol id="chat-messages" class="chat__list"></ol>

          <form id="chat-form" class="chat__form">
            <input
              id="chat-db"
              name="dbId"
              type="text"
              placeholder="db_id (e.g. db_orders)"
              class="chat__db"
              autocomplete="off"
              required
            />
            <textarea
              id="chat-input"
              name="goal"
              placeholder="Show me the 10 most recent orders…"
              class="chat__input"
              rows="2"
              required
            ></textarea>
            <div class="chat__send-row">
              <span class="chat__hint" aria-hidden="true">Enter to send · Shift+Enter for newline</span>
              <button type="submit" id="chat-send" class="btn btn--accent chat__send">Send</button>
            </div>
            <p id="chat-error" class="chat__error" hidden></p>
          </form>
        </section>

        <aside class="chat__pane chat__pane--detail" aria-label="Selected turn detail">
          <div id="chat-detail" class="chat__detail">
            <p class="chat__detail-empty">Select a message to see its results and SQL.</p>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <script>
    import { API_BASE, escapeHtml, getJson, postJson, redirectToSignIn } from "../../lib/auth-client";

    type AssistantSuccess = {
      kind: "ok";
      sql: string;
      rows: Record<string, unknown>[];
      rowCount: number;
      truncated: boolean;
      cached: boolean;
      summary?: string;
    };
    type AssistantError = {
      kind: "error";
      status: string;
      message?: string;
    };
    type ChatMessage =
      | { id: string; role: "user"; userId: string; dbId: string; goal: string; createdAt: number }
      | {
          id: string;
          role: "assistant";
          userId: string;
          dbId: string;
          createdAt: number;
          result: AssistantSuccess | AssistantError;
        };

    const loading = document.getElementById("chat-loading") as HTMLDivElement;
    const empty = document.getElementById("chat-empty") as HTMLDivElement;
    const layout = document.getElementById("chat-layout") as HTMLDivElement;
    const list = document.getElementById("chat-messages") as HTMLOListElement;
    const detail = document.getElementById("chat-detail") as HTMLDivElement;
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const dbInput = document.getElementById("chat-db") as HTMLInputElement;
    const goalInput = document.getElementById("chat-input") as HTMLTextAreaElement;
    const sendBtn = document.getElementById("chat-send") as HTMLButtonElement;
    const errorEl = document.getElementById("chat-error") as HTMLParagraphElement;
    const signoutBtn = document.getElementById("signout") as HTMLButtonElement;

    const LAST_DB_KEY = "nlqdb:last-db";
    const RENDER_ROW_CAP = 50;
    const LIST_GOAL_PREVIEW_CHARS = 90;

    // In-memory message store, indexed by id. Detail-pane re-renders
    // off this map so we don't have to re-parse rendered HTML when the
    // user clicks between rows. Append-only within a session.
    const messages = new Map<string, ChatMessage>();
    let selectedId: string | null = null;

    function applyPrefill() {
      const params = new URLSearchParams(location.search);
      const goal = params.get("goal");
      const dbIdHint = params.get("dbId");
      if (goal) goalInput.value = goal;
      if (dbIdHint) dbInput.value = dbIdHint;
    }

    function truncate(s: string, max: number): string {
      return s.length > max ? `${s.slice(0, max - 1)}…` : s;
    }

    // List-row rendering: ONE line of meaning per turn. The detail
    // pane shows the full SQL + table — keeping the list compact is
    // the entire point of the master/detail split.
    function listLabel(msg: ChatMessage): { meta: string; preview: string; tone: "user" | "ok" | "error" } {
      if (msg.role === "user") {
        return { meta: `you · db=${msg.dbId}`, preview: truncate(msg.goal, LIST_GOAL_PREVIEW_CHARS), tone: "user" };
      }
      if (msg.result.kind === "error") {
        return {
          meta: "nlqdb · error",
          preview: msg.result.message ? truncate(msg.result.message, LIST_GOAL_PREVIEW_CHARS) : msg.result.status,
          tone: "error",
        };
      }
      const r = msg.result;
      const summary = r.summary ?? `${r.rowCount} row${r.rowCount === 1 ? "" : "s"}`;
      return { meta: `nlqdb · ${r.rowCount} row${r.rowCount === 1 ? "" : "s"}${r.cached ? " · cached" : ""}`, preview: truncate(summary, LIST_GOAL_PREVIEW_CHARS), tone: "ok" };
    }

    function renderListItem(msg: ChatMessage): HTMLLIElement {
      const li = document.createElement("li");
      const label = listLabel(msg);
      li.className = `chat__list-item chat__list-item--${label.tone}`;
      li.dataset.messageId = msg.id;
      li.setAttribute("role", "button");
      li.setAttribute("tabindex", "0");
      li.innerHTML = `
        <div class="chat__list-meta">${escapeHtml(label.meta)}</div>
        <div class="chat__list-preview">${escapeHtml(label.preview)}</div>
      `;
      return li;
    }

    function renderRowsAsTable(rows: Record<string, unknown>[]): string {
      if (rows.length === 0) {
        return '<p class="chat__rows-empty">No rows.</p>';
      }
      const cols = Object.keys(rows[0] ?? {});
      const head = cols.map((c) => `<th>${escapeHtml(c)}</th>`).join("");
      const body = rows
        .slice(0, RENDER_ROW_CAP)
        .map((row) => {
          const cells = cols
            .map((c) => {
              const v = row[c];
              const text =
                v === null || v === undefined
                  ? ""
                  : typeof v === "object"
                    ? JSON.stringify(v)
                    : v;
              return `<td>${escapeHtml(text)}</td>`;
            })
            .join("");
          return `<tr>${cells}</tr>`;
        })
        .join("");
      const more =
        rows.length > RENDER_ROW_CAP
          ? `<p class="chat__rows-more">… ${rows.length - RENDER_ROW_CAP} more rows in this page</p>`
          : "";
      return `<table class="nlq-table"><thead><tr>${head}</tr></thead><tbody>${body}</tbody></table>${more}`;
    }

    function renderDetail(msg: ChatMessage | null): string {
      if (!msg) {
        return '<p class="chat__detail-empty">Select a message to see its results and SQL.</p>';
      }
      if (msg.role === "user") {
        return `
          <div class="chat__detail-meta">you · db=${escapeHtml(msg.dbId)}</div>
          <div class="chat__detail-goal">${escapeHtml(msg.goal)}</div>
          <p class="chat__detail-hint">Click the assistant reply below this turn for SQL + rows.</p>
        `;
      }
      if (msg.result.kind === "error") {
        return `
          <div class="chat__detail-meta">nlqdb · error</div>
          <div class="chat__detail-error">
            <strong>${escapeHtml(msg.result.status)}</strong>
            ${msg.result.message ? `<div>${escapeHtml(msg.result.message)}</div>` : ""}
          </div>
        `;
      }
      const r = msg.result;
      const cached = r.cached ? " · cached" : "";
      const truncated = r.truncated ? ` · stored first ${r.rows.length} of ${r.rowCount}` : "";
      const meta = `nlqdb · ${r.rowCount} row${r.rowCount === 1 ? "" : "s"}${cached}${truncated}`;
      const summary = r.summary
        ? `<div class="chat__detail-summary">${escapeHtml(r.summary)}</div>`
        : "";
      const sql = r.sql
        ? `<pre class="chat__detail-sql"><code>${escapeHtml(r.sql)}</code></pre>`
        : "";
      return `
        <div class="chat__detail-meta">${escapeHtml(meta)}</div>
        ${summary}
        <div class="chat__detail-rows">${renderRowsAsTable(r.rows)}</div>
        ${sql}
      `;
    }

    function setSelected(id: string | null) {
      selectedId = id;
      detail.innerHTML = renderDetail(id ? (messages.get(id) ?? null) : null);
      for (const el of list.querySelectorAll<HTMLLIElement>(".chat__list-item")) {
        const isSel = el.dataset.messageId === id;
        el.classList.toggle("chat__list-item--selected", isSel);
        if (isSel) el.scrollIntoView({ block: "nearest", behavior: "smooth" });
      }
    }

    function appendMessage(msg: ChatMessage, opts: { select: boolean }) {
      messages.set(msg.id, msg);
      list.appendChild(renderListItem(msg));
      if (opts.select) setSelected(msg.id);
      list.scrollTop = list.scrollHeight;
    }

    list.addEventListener("click", (e) => {
      const target = (e.target as HTMLElement).closest<HTMLLIElement>(".chat__list-item");
      if (!target) return;
      const id = target.dataset.messageId;
      if (id) setSelected(id);
    });

    list.addEventListener("keydown", (e) => {
      if (e.key !== "Enter" && e.key !== " ") return;
      const target = (e.target as HTMLElement).closest<HTMLLIElement>(".chat__list-item");
      if (!target) return;
      e.preventDefault();
      const id = target.dataset.messageId;
      if (id) setSelected(id);
    });

    async function load() {
      try {
        const body = await getJson<{ messages: ChatMessage[] }>("/v1/chat/messages");
        loading.hidden = true;
        const msgs = body.messages ?? [];
        if (msgs.length === 0) {
          empty.hidden = false;
          // Composer still needed even on empty state — but the layout
          // is the natural home for it. Keep layout shown either way.
          layout.hidden = false;
        } else {
          layout.hidden = false;
          for (const m of msgs) appendMessage(m, { select: false });
          // Default selection: latest message in the conversation.
          // Almost always the assistant reply; if a user row landed
          // without a reply (e.g. mid-error), we still surface it.
          setSelected(msgs[msgs.length - 1].id);
        }
        const lastDb = localStorage.getItem(LAST_DB_KEY);
        if (lastDb) dbInput.value = lastDb;
        applyPrefill();
        if (goalInput.value) goalInput.focus();
      } catch (err) {
        if (err instanceof Error && err.message === "unauthorized") return;
        loading.textContent = `Couldn't load: ${
          err instanceof Error ? err.message : "unknown error"
        }`;
      }
    }

    async function send() {
      const goal = goalInput.value.trim();
      const dbId = dbInput.value.trim();
      if (!goal || !dbId) return;
      errorEl.hidden = true;
      sendBtn.disabled = true;
      sendBtn.textContent = "Sending…";
      try {
        localStorage.setItem(LAST_DB_KEY, dbId);
        const body = await postJson<{ user: ChatMessage; assistant: ChatMessage }>(
          "/v1/chat/messages",
          { goal, dbId },
        );
        empty.hidden = true;
        layout.hidden = false;
        appendMessage(body.user, { select: false });
        // Auto-select the assistant reply — that's the new
        // information the user is here to see.
        appendMessage(body.assistant, { select: true });
        goalInput.value = "";
      } catch (err) {
        if (err instanceof Error && err.message === "unauthorized") return;
        errorEl.textContent = err instanceof Error ? err.message : "Send failed.";
        errorEl.hidden = false;
      } finally {
        sendBtn.disabled = false;
        sendBtn.textContent = "Send";
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      send();
    });

    goalInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey && !e.isComposing) {
        e.preventDefault();
        send();
      }
    });

    signoutBtn.addEventListener("click", async () => {
      await fetch(`${API_BASE}/api/auth/sign-out`, {
        method: "POST",
        credentials: "include",
      });
      redirectToSignIn();
    });

    load();
  </script>

  <style>
    .app .topnav__links {
      display: flex;
      gap: 16px;
    }
    .chat {
      display: grid;
      gap: 16px;
      padding: 24px 0 32px;
      min-height: calc(100dvh - 120px);
    }
    .chat__loading,
    .chat__empty {
      font-family: var(--mono);
      color: var(--fg-dim);
      padding: 32px 0;
    }
    .chat__title {
      font-size: clamp(28px, 5vw, 44px);
      margin: 0 0 8px;
      letter-spacing: -0.03em;
      color: var(--fg);
    }
    .chat__lede {
      font-family: var(--mono);
      color: var(--fg-dim);
      margin: 0 0 12px;
      max-width: 60ch;
    }
    .chat__lede--muted {
      color: var(--fg-muted);
      font-size: 13px;
    }
    .chat__lede code {
      padding: 1px 6px;
      background: var(--bg-elev);
      border: 1px solid var(--border);
      color: var(--fg);
    }

    /* Two-pane layout. On wide screens the list is the narrower side
       (40%), the detail takes the rest — that's where SQL + tables
       live, so it deserves the room. Below 880px we stack: list on
       top scrollable, detail below. */
    .chat__layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      align-items: stretch;
      min-height: 0;
    }
    @media (min-width: 880px) {
      .chat__layout {
        grid-template-columns: minmax(280px, 40%) 1fr;
      }
    }
    .chat__pane {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .chat__pane--list {
      gap: 12px;
    }

    /* List of turns — compact rows, click/keyboard to select. */
    .chat__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
      overflow-y: auto;
      max-height: 60vh;
    }
    .chat__list-item {
      padding: 10px 12px;
      border: 2px solid var(--border);
      background: var(--bg-elev);
      cursor: pointer;
      transition: border-color 0.12s ease, background-color 0.12s ease;
      outline: none;
    }
    .chat__list-item:hover,
    .chat__list-item:focus-visible {
      border-color: var(--border-strong);
    }
    .chat__list-item--user {
      border-left: 4px solid var(--accent);
    }
    .chat__list-item--ok {
      border-left: 4px solid var(--border-strong);
    }
    .chat__list-item--error {
      border-left: 4px solid #ff8a8a;
    }
    .chat__list-item--selected {
      border-color: var(--accent);
      background: var(--bg);
    }
    .chat__list-meta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 4px;
    }
    .chat__list-preview {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Detail pane — the rendered surface for the selected turn. */
    .chat__pane--detail {
      gap: 0;
    }
    .chat__detail {
      padding: 18px 20px;
      border: 2px solid var(--border-strong);
      background: var(--bg-elev);
      box-shadow: 4px 4px 0 0 var(--border-strong);
      min-height: 240px;
      overflow: auto;
      max-height: calc(100dvh - 200px);
    }
    .chat__detail-empty {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-muted);
      margin: 0;
    }
    .chat__detail-meta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .chat__detail-goal {
      font-family: var(--mono);
      font-size: 15px;
      color: var(--fg);
      white-space: pre-wrap;
      word-break: break-word;
      padding: 10px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
    }
    .chat__detail-hint {
      margin: 12px 0 0;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-muted);
    }
    .chat__detail-summary {
      font-size: 14px;
      color: var(--fg);
      margin-bottom: 14px;
    }
    .chat__detail-rows {
      overflow-x: auto;
      margin-bottom: 12px;
    }
    .chat__detail-sql {
      margin: 14px 0 0;
      padding: 10px 12px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-dim);
      background: var(--bg);
      border: 1px solid var(--border);
      overflow-x: auto;
    }
    .chat__detail-error {
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
    }
    .chat__rows-empty,
    .chat__rows-more {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-muted);
      margin: 4px 0;
    }

    /* Composer — pinned at the bottom of the list pane. */
    .chat__form {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px;
      background: var(--bg-elev);
      border: 3px solid var(--border-strong);
      box-shadow: var(--shadow-hard);
      margin-top: auto;
    }
    .chat__db,
    .chat__input {
      width: 100%;
      padding: 10px 12px;
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg);
      background: var(--bg);
      border: 2px solid var(--border-strong);
      outline: none;
      resize: vertical;
    }
    .chat__db:focus,
    .chat__input:focus {
      border-color: var(--accent);
    }
    .chat__send-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .chat__hint {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-muted);
    }
    .chat__error {
      margin: 0;
      padding: 8px 10px;
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
      background: #2a1212;
      border: 2px solid #ff8a8a;
    }
  </style>
</Base>
