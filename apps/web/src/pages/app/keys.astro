---
// API-key management dashboard (SK-APIKEYS-010 / SK-APIKEYS-011 /
// SK-APIKEYS-012). Wraps `POST /v1/keys`, `GET /v1/keys`, and
// `DELETE /v1/keys/:id` per the open question in
// `docs/features/api-keys/FEATURE.md`. The `packages/mcp/src/tools.ts`
// `auth_required` envelope points users at `app.nlqdb.com/app/keys` —
// this is that page.

import AppAnalytics from "../../components/AppAnalytics.astro";
import Footer from "../../components/Footer.astro";
import KeysPanel from "../../components/keys/KeysPanel.tsx";
import Topnav from "../../components/Topnav.astro";
import Base from "../../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
---
<Base
  title="API keys — nlqdb"
  description="Mint, list, and revoke nlqdb API keys."
>
  <div class="page page--keys" id="keys-shell" data-api-base={apiBase} hidden>
    <Topnav current="chat" />
    <main class="page__main page__main--keys">
      <KeysPanel client:only="react" apiBase={apiBase} />
    </main>
    <Footer />
  </div>
  <AppAnalytics />
</Base>

<script>
  // Inline auth guard — mirrors `/app/index.astro` (SK-AUTH-016 /
  // SK-WEB-009). The shell stays `hidden` until `fetchSession`
  // resolves; an unauthenticated probe redirects to sign-in with a
  // `return_to` so post-signin lands back here.
  import { fetchSession, invalidateSession } from "../../lib/session";

  const shell = document.getElementById("keys-shell");
  if (shell) {
    const apiBase = (shell as HTMLElement).dataset["apiBase"];

    async function requireSession(): Promise<boolean> {
      const user = await fetchSession(apiBase);
      if (!user) {
        const returnTo = `${location.pathname}${location.search}${location.hash}`;
        const signInUrl = new URL("/auth/sign-in/", location.origin);
        signInUrl.searchParams.set("return_to", returnTo);
        location.replace(signInUrl.toString());
        return false;
      }
      return true;
    }

    // WS02-T2: re-probe on bfcache restore so a signed-out cookie can't
    // leave the keys shell visible (mirrors /app/index.astro).
    window.addEventListener("pageshow", (event) => {
      if (event.persisted) {
        invalidateSession();
        void requireSession();
      }
    });

    void (async () => {
      if (!(await requireSession())) return;
      shell.hidden = false;
    })();
  }
</script>

<style is:global>
  @import "../../styles/keys.css";
</style>
