---
// Homepage — two-door chooser (SK-WEB-018, the literal expression of
// GLOBAL-036's dual front door). Replaces the SK-WEB-015/017 three-beat
// hero→demo→replaces scroll with one headline + two side-by-side doors:
// Door A "Use as agent memory" (the <McpInstall> host row + a quiet
// /app/new link preserving GLOBAL-007's no-login-wall first value), and
// Door B "Question your ClickHouse" (CTA → sign-in → /app/connect,
// SK-WEB-019). Hero/Demo/Replaces stay in the repo — only `/agents`
// still uses them.

import AuthedHomeBanner from "../components/AuthedHomeBanner.astro";
import Footer from "../components/Footer.astro";
import HomeDoors from "../components/HomeDoors.astro";
import Topnav from "../components/Topnav.astro";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — analytical memory for AI agents"
  description="Give your AI agent a real Postgres database as memory — typed rows it writes as it learns, queried in English. Connect it over MCP to Claude, Cursor, Windsurf, or Zed; aggregate over what it remembered, not just the top-k a vector store recalls."
  ogImage="/og/agents.png"
  ogImageAlt="GROUP BY your agent's memory — analytical memory for AI agents."
>
  <div class="page">
    <Topnav />

    <main>
      <AuthedHomeBanner />
      <HomeDoors />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // Mint the anon token up front — no cost; useful when the
  // visitor crosses to /app/new from the footer / replaces CTA.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();
</script>
