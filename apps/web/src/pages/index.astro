---
import AuthedHomeBanner from "../components/AuthedHomeBanner.astro";
import Carousel from "../components/Carousel.astro";
import CodePanel from "../components/CodePanel.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ManifestoExcerpt from "../components/ManifestoExcerpt.astro";
import Replaces from "../components/Replaces.astro";
import ResearchReceipts from "../components/ResearchReceipts.astro";
import Topnav from "../components/Topnav.astro";
import Waitlist from "../components/Waitlist.astro";
import { SHOWCASE_EXAMPLES } from "../data/showcase-examples";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — natural-language databases"
  description="Create a database in a word. Query it in English. Schema, engine, indexes, and backups stay invisible — unless you want to see them."
>
  <div class="page">
    <Topnav />

    <main>
      <AuthedHomeBanner />
      {/* Hero's marketing chrome (wordmark, lede, sub) renders
          unconditionally; the live <CreateForm> inside is gated
          behind Cmd+G (Ctrl+G on non-Mac) via the `#hero-gate` div
          in `apps/web/src/components/Hero.astro`. The toggle
          persists in localStorage so the tester sees it on every
          reload from the same browser. */}
      <Hero />
      <Carousel examples={SHOWCASE_EXAMPLES} />
      <Waitlist />
      <CodePanel />
      <Replaces />
      <ResearchReceipts />
      <ManifestoExcerpt />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // Mints even when the hero is gated — no cost; useful when the
  // visitor crosses to /app/new from the carousel / footer.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();

  // Hero reveal gate — Cmd+G (or Ctrl+G) toggles visibility, sticky
  // via localStorage["nlqdb_hero_visible"]. preventDefault() on the
  // chord because Chrome binds Cmd+G to "find next"; we want the
  // chord exclusive while testing. Toggle (not just reveal) so the
  // tester can hide it again without clearing storage.
  const FLAG = "nlqdb_hero_visible";
  const gate = document.getElementById("hero-gate");

  function setVisible(on: boolean) {
    if (!gate) return;
    if (on) {
      gate.removeAttribute("hidden");
      localStorage.setItem(FLAG, "1");
    } else {
      gate.setAttribute("hidden", "");
      localStorage.removeItem(FLAG);
    }
  }

  if (localStorage.getItem(FLAG) === "1") setVisible(true);

  document.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "g") {
      event.preventDefault();
      setVisible(gate?.hasAttribute("hidden") ?? false);
    }
  });
</script>
