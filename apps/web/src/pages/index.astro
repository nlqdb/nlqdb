---
import AgentMemoryBand from "../components/AgentMemoryBand.astro";
import AlsoWorksFor from "../components/AlsoWorksFor.astro";
import AuthedHomeBanner from "../components/AuthedHomeBanner.astro";
import Carousel from "../components/Carousel.astro";
import CodePanel from "../components/CodePanel.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ManifestoExcerpt from "../components/ManifestoExcerpt.astro";
import Replaces from "../components/Replaces.astro";
import ResearchReceipts from "../components/ResearchReceipts.astro";
import Topnav from "../components/Topnav.astro";
import Waitlist from "../components/Waitlist.astro";
import { SHOWCASE_EXAMPLES } from "../data/showcase-examples";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — analytical memory for AI agents"
  description="Memory your AI agent can query, not just recall. Connect a real database over MCP — your agent writes typed rows and runs GROUP BY, JOIN, and aggregates over them in English. Also a natural-language database for any app."
  ogImage="/og/agents.png"
  ogImageAlt="GROUP BY your agent's memory — analytical memory for AI agents."
>
  <div class="page">
    <Topnav />

    <main>
      <AuthedHomeBanner />
      <Hero />
      <AgentMemoryBand />
      <Carousel examples={SHOWCASE_EXAMPLES} />
      <Waitlist />
      <AlsoWorksFor />
      <CodePanel />
      <Replaces />
      <ResearchReceipts />
      <ManifestoExcerpt />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // Mint the anon token up front — no cost; useful when the
  // visitor crosses to /app/new from the carousel / footer.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();
</script>
