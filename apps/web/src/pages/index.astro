---
import Carousel from "../components/Carousel.astro";
import CodePanel from "../components/CodePanel.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ManifestoExcerpt from "../components/ManifestoExcerpt.astro";
import Replaces from "../components/Replaces.astro";
import ResearchReceipts from "../components/ResearchReceipts.astro";
import Topnav from "../components/Topnav.astro";
import Waitlist from "../components/Waitlist.astro";
import { SHOWCASE_EXAMPLES } from "../data/showcase-examples";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — natural-language databases"
  description="Create a database in a word. Query it in English. Schema, engine, indexes, and backups stay invisible — unless you want to see them."
>
  <div class="page">
    <Topnav />

    <main>
      {/* Narrative order: positioning → capability showcase → primary
          CTA → technical proof → competitive framing → research
          receipts → philosophy. The hero now talks to real `/v1/ask`
          with an anonymous bearer (SK-WEB-008) — the canned-fixture
          /v1/demo/ask endpoint was retired. The carousel below
          remains the only static-fixture surface; its examples
          (`SHOWCASE_EXAMPLES`) are pre-rendered HTML, no fetch. */}
      <Hero />
      <Carousel examples={SHOWCASE_EXAMPLES} />
      <Waitlist />
      <CodePanel />
      <Replaces />
      <ResearchReceipts />
      <ManifestoExcerpt />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // The hero's `<CreateForm>` would mint on first call anyway, but
  // landing the bearer in localStorage at first paint means the
  // network request that follows already has its `Authorization:
  // Bearer anon_*` header.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();
</script>
