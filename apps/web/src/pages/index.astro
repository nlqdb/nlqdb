---
import AuthedHomeBanner from "../components/AuthedHomeBanner.astro";
import Carousel from "../components/Carousel.astro";
import CodePanel from "../components/CodePanel.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ManifestoExcerpt from "../components/ManifestoExcerpt.astro";
import Replaces from "../components/Replaces.astro";
import ResearchReceipts from "../components/ResearchReceipts.astro";
import Topnav from "../components/Topnav.astro";
import Waitlist from "../components/Waitlist.astro";
import { SHOWCASE_EXAMPLES } from "../data/showcase-examples";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — natural-language databases"
  description="Create a database in a word. Query it in English. Schema, engine, indexes, and backups stay invisible — unless you want to see them."
>
  <div class="page">
    <Topnav />

    <main>
      <AuthedHomeBanner />
      {/* Hero's marketing chrome (wordmark, lede, sub) renders
          unconditionally; the live <CreateForm> inside is gated
          behind Cmd+G (Ctrl+G on non-Mac) via the `#hero-gate` div
          in `apps/web/src/components/Hero.astro`. The shared
          keydown handler lives in `Topnav.astro` and toggles every
          `[data-cmdg-gate]` element on the page in lockstep
          (currently the hero form + the Sign-in link in the nav).
          State persists in localStorage so the tester sees both on
          every reload from the same browser. */}
      <Hero />
      <Carousel examples={SHOWCASE_EXAMPLES} />
      <Waitlist />
      <CodePanel />
      <Replaces />
      <ResearchReceipts />
      <ManifestoExcerpt />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // Mints even when the hero is gated — no cost; useful when the
  // visitor crosses to /app/new from the carousel / footer.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();
</script>
