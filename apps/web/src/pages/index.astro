---
// Homepage — three beats (redesign-plan §5, SK-WEB-015 foundation):
// hero → demo → replaces. Everything else moved off `/` (legacy
// component files survive until Phase 2 page-sweep agents port their
// content; the `Waitlist` block is deleted outright because the
// product is open per d63fb01).

import AuthedHomeBanner from "../components/AuthedHomeBanner.astro";
import Demo from "../components/Demo.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Replaces from "../components/Replaces.astro";
import Topnav from "../components/Topnav.astro";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — analytical memory for AI agents"
  description="Memory your AI agent can query, not just recall. Connect a real database over MCP — your agent writes typed rows and runs GROUP BY, JOIN, and aggregates over them in English. Also a natural-language database for any app."
  ogImage="/og/agents.png"
  ogImageAlt="GROUP BY your agent's memory — analytical memory for AI agents."
>
  <div class="page">
    <Topnav />

    <main>
      <AuthedHomeBanner />
      <Hero />
      <Demo />
      <Replaces />
    </main>

    <Footer />
  </div>
</Base>

<script>
  // Provision the anonymous-mode token on first visit (SK-ANON-001).
  // Mint the anon token up front — no cost; useful when the
  // visitor crosses to /app/new from the footer / replaces CTA.
  import { getOrMintAnonToken } from "../lib/anon";
  getOrMintAnonToken();
</script>
