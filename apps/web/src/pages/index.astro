---
import Carousel from "../components/Carousel.astro";
import CodePanel from "../components/CodePanel.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ManifestoExcerpt from "../components/ManifestoExcerpt.astro";
import Replaces from "../components/Replaces.astro";
import Topnav from "../components/Topnav.astro";
import Waitlist from "../components/Waitlist.astro";
import { SHOWCASE_EXAMPLES } from "../data/showcase-examples";
import Base from "../layouts/Base.astro";
---
<Base
  title="nlqdb — natural-language databases"
  description="Create a database in a word. Query it in English. Schema, engine, indexes, and backups stay invisible — unless you want to see them."
>
  <div class="page">
    <Topnav />

    <main>
      {/* Narrative order: positioning → capability showcase →
          values + manifesto link → primary CTA → technical proof →
          competitive framing. Promoting ManifestoExcerpt up front
          (was at the bottom after Replaces) so the "Free, forever"
          tenet + manifesto link land BEFORE the waitlist CTA — the
          values frame the ask. PR #49's pivot dropped both
          CodePanel + ManifestoExcerpt; PR #58 restored them. */}
      <Hero />
      <Carousel examples={SHOWCASE_EXAMPLES} />
      <ManifestoExcerpt />
      <Waitlist />
      <CodePanel />
      <Replaces />
    </main>

    <Footer />
  </div>
</Base>
