---
// Magic-link sign-in page (Slice 10 — DESIGN §4.1, §4.3).
//
// Static Astro page with a vanilla-JS island. Posts the email to
// Better Auth's magic-link endpoint at the API origin
// (cross-subdomain: nlqdb.com → app.nlqdb.com), then swaps to a
// "check your email" panel. No client framework — the entire form
// is ~80 lines of JS, React would be 100× the bundle weight.
//
// `?return_to=` is honored: the magic-link callback URL points back
// at this app's chat surface, with `?return_to=` preserved so the
// callback re-enters the originally requested page.

import Base from "../layouts/Base.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE ?? "https://app.nlqdb.com";
const appBase = import.meta.env.PUBLIC_APP_BASE ?? "https://nlqdb.com";
---
<Base
  title="Sign in — nlqdb"
  description="Sign in to nlqdb with a magic link. No passwords."
>
  <div class="page">
    <header class="topnav">
      <a class="topnav__brand" href="/">nlqdb</a>
    </header>

    <main class="signin">
      <h1 class="signin__title">Sign in</h1>
      <p class="signin__lede">A magic link, no passwords. Expires in 15 minutes.</p>

      <form id="signin-form" class="signin__form" novalidate>
        <label class="signin__label" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="signin__field"
        />
        <button type="submit" class="btn btn--accent signin__submit">
          Send magic link
        </button>
        <p id="signin-error" class="signin__error" hidden></p>
      </form>

      <div id="signin-sent" class="signin__sent" hidden>
        <h2 class="signin__sent-title">Check your email</h2>
        <p class="signin__sent-body">
          We sent a sign-in link to <strong id="signin-sent-email"></strong>.
          Click it within 15 minutes to sign in.
        </p>
        <p class="signin__sent-meta">
          Didn't get it? <button type="button" id="signin-resend" class="signin__link">Send another</button>
        </p>
      </div>
    </main>

    <footer class="foot">
      <span>&copy; nlqdb &middot; Pre-alpha</span>
    </footer>
  </div>

  <script is:inline define:vars={{ apiBase, appBase }}>
    const form = document.getElementById("signin-form");
    const errorEl = document.getElementById("signin-error");
    const sentEl = document.getElementById("signin-sent");
    const sentEmailEl = document.getElementById("signin-sent-email");
    const resendBtn = document.getElementById("signin-resend");
    const submitBtn = form.querySelector("button[type=submit]");

    const params = new URLSearchParams(location.search);
    const returnTo = params.get("return_to") ?? "/app";
    const callbackURL = new URL(returnTo, appBase).toString();

    async function send(email) {
      errorEl.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
      try {
        const res = await fetch(`${apiBase}/api/auth/sign-in/magic-link`, {
          method: "POST",
          credentials: "include",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email, callbackURL }),
        });
        if (!res.ok) {
          let detail = `HTTP ${res.status}`;
          try {
            const body = await res.json();
            if (body && body.message) detail = body.message;
          } catch {}
          throw new Error(detail);
        }
        sentEmailEl.textContent = email;
        form.hidden = true;
        sentEl.hidden = false;
      } catch (err) {
        errorEl.textContent = err && err.message ? err.message : "Couldn't send. Try again.";
        errorEl.hidden = false;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send magic link";
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = /** @type {HTMLInputElement} */ (document.getElementById("email")).value.trim();
      if (!email) return;
      send(email);
    });

    resendBtn.addEventListener("click", () => {
      const email = sentEmailEl.textContent || "";
      if (email) send(email);
    });
  </script>

  <style>
    .signin {
      max-width: 420px;
      margin: 0 auto;
      padding: clamp(48px, 10vw, 96px) 0;
    }
    .signin__title {
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 700;
      letter-spacing: -0.04em;
      margin: 0 0 12px;
    }
    .signin__lede {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg-dim);
      margin: 0 0 32px;
    }
    .signin__form {
      display: grid;
      gap: 12px;
    }
    .signin__label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .signin__field {
      width: 100%;
      padding: 14px 16px;
      font-family: var(--mono);
      font-size: 16px;
      color: var(--fg);
      background: var(--bg-elev);
      border: 3px solid var(--border-strong);
      border-radius: var(--radius);
      box-shadow: var(--shadow-hard);
      outline: none;
    }
    .signin__field:focus {
      border-color: var(--accent);
      box-shadow: var(--shadow-hard-accent);
    }
    .signin__submit {
      justify-content: center;
      margin-top: 8px;
    }
    .signin__error {
      margin: 8px 0 0;
      padding: 10px 12px;
      font-family: var(--mono);
      font-size: 13px;
      color: #ff8a8a;
      background: #2a1212;
      border: 2px solid #ff8a8a;
    }
    .signin__sent {
      padding: 24px;
      border: 3px solid var(--accent);
      background: var(--bg-elev);
      box-shadow: var(--shadow-hard-accent);
    }
    .signin__sent-title {
      font-size: 22px;
      margin: 0 0 12px;
    }
    .signin__sent-body {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg);
      margin: 0 0 16px;
    }
    .signin__sent-meta {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-dim);
      margin: 0;
    }
    .signin__link {
      background: none;
      border: none;
      color: var(--accent);
      text-decoration: underline;
      font: inherit;
      cursor: pointer;
      padding: 0;
    }
  </style>
</Base>
