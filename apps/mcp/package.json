{
  "name": "@nlqdb/mcp-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "secrets:local": "../../scripts/mirror-secrets-workers.sh local mcp",
    "secrets:remote": "../../scripts/mirror-secrets-workers.sh remote mcp"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "0.6.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@nlqdb/mcp": "workspace:*",
    "@nlqdb/otel": "workspace:*",
    "@nlqdb/sdk": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "agents": "0.12.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "latest",
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
