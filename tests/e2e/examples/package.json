{
  "name": "@nlqdb/e2e-examples",
  "private": true,
  "version": "0.0.0",
  "description": "Examples-as-tests harness (SK-E2E-005). One Playwright install, one shared harness, per-example specs under examples/<framework>/e2e/.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:html": "playwright test --grep @html",
    "test:nextjs": "playwright test --grep @nextjs",
    "test:nuxt": "playwright test --grep @nuxt",
    "test:sveltekit": "playwright test --grep @sveltekit",
    "test:astro": "playwright test --grep @astro",
    "test:curl": "bash ../../../examples/curl/e2e/smoke.sh",
    "test:cli": "bash ../../../examples/cli/e2e/smoke.sh",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^5.6.0"
  }
}
