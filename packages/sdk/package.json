{
  "name": "@nlqdb/sdk",
  "version": "0.0.0",
  "description": "Typed HTTP client for the nlqdb /v1 API — works in browsers, Node, Bun, Workers.",
  "type": "module",
  "sideEffects": false,
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nlqdb/nlqdb.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://nlqdb.com",
  "bugs": "https://github.com/nlqdb/nlqdb/issues",
  "keywords": [
    "nlqdb",
    "sdk",
    "natural-language",
    "database",
    "sql",
    "llm"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
