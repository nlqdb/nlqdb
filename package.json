{
  "name": "nlqdb",
  "private": true,
  "version": "0.0.0",
  "description": "Analytical memory for AI agents — a real database your agent queries over MCP in English (GROUP BY, JOIN, aggregate), not just recall. Also a natural-language database for any app.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '*' build",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check",
    "fix": "biome check --write",
    "check:go": "gofumpt -l cli && go -C cli vet ./... && cd cli && golangci-lint run ./...",
    "check:py": "ruff check && ruff format --check",
    "check:all": "bun run check && bun run check:go && bun run check:py",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit",
    "changeset": "changeset",
    "changeset:version": "changeset version && bun install --lockfile-only",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "~1.60.0",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "hono": "^4.12.25",
    "shell-quote": "^1.8.4",
    "devalue": "^5.8.1",
    "ws": "^8.21.0",
    "qs": "^6.15.2",
    "yaml": "^2.9.0",
    "cookie": "^0.7.2",
    "postcss": "^8.5.14"
  }
}
