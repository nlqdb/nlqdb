{
  // Renovate config (replaces ad-hoc version bumps).
  //
  // Default schedule: weekly on Mondays so PR noise lands at the start
  // of the week. Lockfile-only auto-merges; minor/major need review.
  // Group rules collapse cross-package bumps (Astro, Hono, Stripe SDK,
  // OpenTelemetry) into single PRs to cut churn.
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "schedule:weekly",
    "group:monorepos",
    "group:recommended",
  ],
  timezone: "Europe/Zurich",
  prHourlyLimit: 4,
  prConcurrentLimit: 8,
  rangeStrategy: "bump",
  rebaseWhen: "auto",
  semanticCommitType: "chore",
  semanticCommitScope: "deps",
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    schedule: ["before 5am on Monday"],
  },
  packageRules: [
    {
      matchUpdateTypes: ["patch", "pin", "digest"],
      automerge: true,
    },
    {
      matchPackageNames: ["@cloudflare/workers-types", "wrangler", "@cloudflare/vitest-pool-workers"],
      groupName: "cloudflare-tooling",
    },
    {
      matchPackageNames: ["@opentelemetry/api"],
      matchPackagePatterns: ["^@opentelemetry/"],
      groupName: "opentelemetry",
    },
    {
      matchPackageNames: ["astro", "@astrojs/check"],
      groupName: "astro",
    },
    {
      matchPackageNames: ["stripe"],
      // Stripe SDK majors track API versions; require manual review.
      matchUpdateTypes: ["major"],
      automerge: false,
    },
    {
      matchManagers: ["github-actions"],
      pinDigests: true,
      groupName: "github-actions",
    },
  ],
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["security"],
    automerge: false,
  },
}
